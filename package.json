{
  "name": "cake-shop-tests",
  "version": "1.0.0",
  "description": "蛋糕销售小程序测试",
  "private": true,
  "scripts": {
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "lint": "eslint cloudfunctions/ miniprogram/",
    "lint:fix": "eslint cloudfunctions/ miniprogram/ --fix"
  },
  "devDependencies": {
    "@types/jest": "^29.5.12",
    "eslint": "^8.57.0",
    "jest": "^29.7.0"
  },
  "jest": {
    "testEnvironment": "node",
    "testMatch": [
      "**/tests/**/*.test.js"
    ],
    "collectCoverageFrom": [
      "cloudfunctions/**/*.js",
      "miniprogram/utils/**/*.js"
    ],
    "coverageDirectory": "coverage",
    "moduleFileExtensions": [
      "js",
      "json"
    ],
    "transform": {}
  }
}
