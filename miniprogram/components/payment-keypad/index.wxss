.payment-keypad-mask {
  position: fixed;
  inset: 0;
  background: rgba(0, 0, 0, 0.55);
  z-index: 9999;
  display: flex;
  align-items: flex-end;
}
.payment-keypad-modal {
  width: 100%;
  background: #fff;
  border-top-left-radius: 24rpx;
  border-top-right-radius: 24rpx;
  padding-bottom: env(safe-area-inset-bottom);
  user-select: none;
  -webkit-user-select: none;
}
.title-bar {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 24rpx 32rpx;
  border-bottom: 1rpx solid #f0f0f0;
}
.title-bar .cancel,
.title-bar .help {
  color: #576b95;
  font-size: 28rpx;
  cursor: pointer;
}
.title-bar .title {
  font-size: 30rpx;
  font-weight: 500;
  color: #333;
}
.dots {
  display: flex;
  justify-content: center;
  gap: 16rpx;
  padding: 48rpx 0;
}
.dot {
  width: 64rpx;
  height: 64rpx;
  border: 2rpx solid #dcdfe6;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 36rpx;
  color: #333;
  background: #fafafa;
}
.dot.filled {
  border-color: #333;
  background: #333;
  color: transparent;
}
.dot.filled::before {
  content: '•';
  color: #333;
  font-size: 64rpx;
  line-height: 1;
}
.dot.error {
  border-color: #fa5151;
  animation: shake 0.4s ease;
}
@keyframes shake {
  0%, 100% { transform: translateX(0); }
  25% { transform: translateX(-8rpx); }
  50% { transform: translateX(0); }
  75% { transform: translateX(8rpx); }
}
.error {
  text-align: center;
  color: #fa5151;
  font-size: 24rpx;
  padding: 0 32rpx 16rpx;
}
.locked {
  text-align: center;
  color: #fa5151;
  font-size: 24rpx;
  padding: 24rpx;
}
.keypad {
  padding: 16rpx 0 32rpx;
  display: flex;
  flex-direction: column;
  gap: 2rpx;
  background: #f5f5f5;
}
.row {
  display: flex;
  gap: 2rpx;
}
.key {
  flex: 1;
  height: 96rpx;
  background: #fff;
  text-align: center;
  line-height: 96rpx;
  font-size: 40rpx;
  color: #333;
  font-weight: 500;
}
.key.empty {
  background: #ebedf0;
  pointer-events: none;
}
.key.del {
  font-size: 36rpx;
  background: #ebedf0;
  color: #333;
}
.key-hover {
  background: #d6e0ff !important;
}
