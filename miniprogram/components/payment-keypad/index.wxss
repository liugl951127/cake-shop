/* payment-keypad/index.wxss - 适配浅色卡片 + indigo 主题 */
@import "/styles/theme.wxss";

.payment-keypad-mask {
  position: fixed;
  inset: 0;
  background: rgba(0, 0, 0, 0.55);
  z-index: 9999;
  display: flex;
  align-items: flex-end;
}
.payment-keypad-modal {
  width: 100%;
  background: var(--c-bg-card);
  border-top-left-radius: var(--r-xl);
  border-top-right-radius: var(--r-xl);
  padding-bottom: env(safe-area-inset-bottom);
  user-select: none;
  -webkit-user-select: none;
}
.title-bar {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 28rpx 32rpx;
  border-bottom: 1rpx solid var(--c-border-soft);
}
.title-bar .cancel,
.title-bar .help {
  color: var(--c-indigo-600);
  font-size: 28rpx;
  cursor: pointer;
  font-weight: 500;
}
.title-bar .title {
  font-size: 30rpx;
  font-weight: 600;
  color: var(--c-text-1);
}
.dots {
  display: flex;
  justify-content: center;
  gap: 24rpx;
  padding: 56rpx 0;
}
.dot {
  width: 64rpx;
  height: 64rpx;
  border: 2rpx solid var(--c-indigo-200);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 36rpx;
  color: var(--c-text-1);
  background: var(--c-indigo-50);
  transition: all 0.2s;
}
.dot.filled {
  border-color: var(--c-indigo-500);
  background: var(--grad-primary);
  color: transparent;
  box-shadow: 0 4rpx 12rpx rgba(99, 102, 241, 0.32);
}
.dot.filled::before {
  content: '•';
  color: #fff;
  font-size: 64rpx;
  line-height: 1;
}
.dot.error {
  border-color: var(--c-danger);
  animation: shake 0.4s ease;
}
@keyframes shake {
  0%, 100% { transform: translateX(0); }
  25% { transform: translateX(-8rpx); }
  50% { transform: translateX(0); }
  75% { transform: translateX(8rpx); }
}
.error {
  text-align: center;
  color: var(--c-danger);
  font-size: 24rpx;
  padding: 0 32rpx 16rpx;
}
.locked {
  text-align: center;
  color: var(--c-danger);
  font-size: 24rpx;
  padding: 24rpx;
  background: var(--c-indigo-50);
  margin: 0 32rpx 16rpx;
  border-radius: var(--r-md);
}
.keypad {
  padding: 20rpx 0 40rpx;
  display: flex;
  flex-direction: column;
  gap: 2rpx;
  background: var(--c-indigo-50);
}
.row {
  display: flex;
  gap: 2rpx;
}
.key {
  flex: 1;
  height: 100rpx;
  background: var(--c-bg-card);
  text-align: center;
  line-height: 100rpx;
  font-size: 44rpx;
  color: var(--c-text-1);
  font-weight: 500;
  transition: all 0.1s;
}
.key.empty {
  background: transparent;
  pointer-events: none;
}
.key.del {
  font-size: 36rpx;
  background: var(--c-indigo-100);
  color: var(--c-indigo-700);
}
.key-hover {
  background: var(--c-indigo-100) !important;
}
