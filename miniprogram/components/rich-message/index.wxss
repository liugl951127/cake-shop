.rich-message {
  display: block;
  word-break: break-word;
  font-size: 28rpx;
  line-height: 1.5;
  color: #333;
}
.rich-message.self {
  color: #fff;
}
.rich-message.self .rich-link,
.rich-message.self .rich-card-title {
  color: #fff;
}

.rich-text { display: inline; }
.rich-b { font-weight: bold; }
.rich-i { font-style: italic; }
.rich-u { text-decoration: underline; }
.rich-s { text-decoration: line-through; }
.rich-code {
  font-family: monospace;
  background: rgba(0, 0, 0, 0.06);
  padding: 2rpx 6rpx;
  border-radius: 4rpx;
  font-size: 24rpx;
}
.rich-message.self .rich-code {
  background: rgba(255, 255, 255, 0.2);
}
.rich-blockquote {
  border-left: 4rpx solid #b3d4fc;
  padding-left: 12rpx;
  color: #777;
  display: block;
}
.rich-at {
  color: #576b95;
  font-weight: 600;
}
.rich-message.self .rich-at { color: #ffd966; }

.rich-link {
  color: #576b95;
  text-decoration: underline;
  display: inline;
}

/* 图片 */
.rich-img {
  display: inline-block;
  margin: 6rpx 6rpx 6rpx 0;
  position: relative;
}
.rich-img image {
  border-radius: 8rpx;
  background: #f4f4f4;
  max-width: 100%;
}
.rich-img-lock,
.rich-video-meta,
.rich-audio-duration,
.rich-location-accuracy {
  position: absolute;
  bottom: 6rpx;
  right: 6rpx;
  background: rgba(0, 0, 0, 0.55);
  color: #fff;
  padding: 2rpx 8rpx;
  border-radius: 6rpx;
  font-size: 20rpx;
  line-height: 1.4;
}

/* 视频 */
.rich-video {
  position: relative;
  display: inline-block;
  margin: 6rpx 0;
  width: 360rpx;
  height: 240rpx;
  background: #000;
  border-radius: 8rpx;
  overflow: hidden;
}
.rich-video-thumb {
  width: 100%;
  height: 100%;
}
.rich-video-play {
  position: absolute;
  top: 50%;
  left: 50%;
  transform: translate(-50%, -50%);
  width: 72rpx;
  height: 72rpx;
  background: rgba(0, 0, 0, 0.5);
  border-radius: 50%;
  color: #fff;
  text-align: center;
  line-height: 72rpx;
  font-size: 32rpx;
}

/* 音频 */
.rich-audio {
  display: flex;
  align-items: center;
  gap: 12rpx;
  padding: 12rpx 16rpx;
  background: rgba(0, 0, 0, 0.04);
  border-radius: 12rpx;
  margin: 6rpx 0;
  min-width: 280rpx;
  position: relative;
}
.rich-message.self .rich-audio {
  background: rgba(255, 255, 255, 0.15);
}
.rich-audio-icon { font-size: 32rpx; }
.rich-audio-name {
  flex: 1;
  font-size: 24rpx;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}
.rich-audio-duration {
  position: static;
  background: transparent;
  color: #888;
  font-size: 22rpx;
}

/* 文件 */
.rich-file {
  display: flex;
  align-items: center;
  gap: 12rpx;
  padding: 16rpx;
  background: rgba(0, 0, 0, 0.04);
  border-radius: 12rpx;
  margin: 6rpx 0;
  min-width: 360rpx;
  position: relative;
}
.rich-message.self .rich-file {
  background: rgba(255, 255, 255, 0.15);
}
.rich-file-icon { font-size: 40rpx; }
.rich-file-info { flex: 1; }
.rich-file-name {
  font-size: 26rpx;
  font-weight: 500;
  word-break: break-all;
}
.rich-file-meta {
  font-size: 20rpx;
  color: #999;
  margin-top: 4rpx;
}
.rich-message.self .rich-file-meta { color: rgba(255, 255, 255, 0.7); }

/* 位置 */
.rich-location {
  display: flex;
  align-items: center;
  gap: 12rpx;
  padding: 16rpx;
  background: rgba(0, 0, 0, 0.04);
  border-radius: 12rpx;
  margin: 6rpx 0;
  min-width: 360rpx;
  position: relative;
}
.rich-message.self .rich-location {
  background: rgba(255, 255, 255, 0.15);
}
.rich-location-icon { font-size: 40rpx; color: #fa5151; }
.rich-location-info { flex: 1; }
.rich-location-name {
  font-size: 26rpx;
  font-weight: 500;
}
.rich-location-address {
  font-size: 22rpx;
  color: #888;
  margin-top: 4rpx;
}
.rich-message.self .rich-location-address { color: rgba(255, 255, 255, 0.7); }

/* 卡片(订单/商品) */
.rich-card {
  display: flex;
  align-items: center;
  gap: 12rpx;
  padding: 16rpx;
  background: rgba(0, 0, 0, 0.04);
  border-radius: 12rpx;
  margin: 8rpx 0;
  min-width: 420rpx;
}
.rich-message.self .rich-card { background: rgba(255, 255, 255, 0.15); }
.rich-card-icon { font-size: 36rpx; }
.rich-card-thumb {
  width: 80rpx;
  height: 80rpx;
  border-radius: 8rpx;
  background: #f4f4f4;
}
.rich-card-info { flex: 1; }
.rich-card-title {
  font-size: 26rpx;
  font-weight: 500;
}
.rich-card-meta,
.rich-card-price {
  font-size: 22rpx;
  color: #888;
  margin-top: 4rpx;
}
.rich-card-price {
  color: #fa5151;
  font-weight: 600;
}
.rich-card-arrow {
  color: #ccc;
  font-size: 36rpx;
}
.rich-message.self .rich-card-arrow { color: rgba(255, 255, 255, 0.6); }
