/* rich-message/index.wxss - 适配浅色卡片 + indigo 主题 */
@import "/styles/theme.wxss";

.rich-message {
  display: block;
  word-break: break-word;
  font-size: 28rpx;
  line-height: 1.5;
  color: var(--c-text-1);
}
.rich-message.self {
  color: #fff;
}
.rich-message.self .rich-link,
.rich-message.self .rich-card-title {
  color: #fff;
}

.rich-text { display: inline; }
.rich-b { font-weight: bold; }
.rich-i { font-style: italic; }
.rich-u { text-decoration: underline; }
.rich-s { text-decoration: line-through; }
.rich-code {
  font-family: monospace;
  background: var(--c-indigo-50);
  color: var(--c-indigo-700);
  padding: 2rpx 8rpx;
  border-radius: var(--r-sm);
  font-size: 24rpx;
}
.rich-message.self .rich-code {
  background: rgba(255, 255, 255, 0.2);
  color: #fff;
}
.rich-blockquote {
  border-left: 4rpx solid var(--c-indigo-300);
  padding-left: 12rpx;
  color: var(--c-text-2);
  display: block;
}
.rich-at {
  color: var(--c-indigo-600);
  font-weight: 600;
}
.rich-message.self .rich-at { color: #ffd966; }

.rich-link {
  color: var(--c-indigo-600);
  text-decoration: underline;
  display: inline;
}

/* 图片 */
.rich-img {
  display: inline-block;
  margin: 8rpx 8rpx 8rpx 0;
  position: relative;
  border-radius: var(--r-md);
  overflow: hidden;
}
.rich-img image {
  border-radius: var(--r-md);
  background: var(--c-indigo-50);
  max-width: 100%;
}
.rich-img-lock,
.rich-video-meta,
.rich-audio-duration,
.rich-location-accuracy {
  position: absolute;
  bottom: 8rpx;
  right: 8rpx;
  background: rgba(0, 0, 0, 0.55);
  color: #fff;
  padding: 4rpx 10rpx;
  border-radius: var(--r-sm);
  font-size: 20rpx;
  line-height: 1.4;
  backdrop-filter: blur(4rpx);
}

/* 视频 */
.rich-video {
  position: relative;
  display: inline-block;
  margin: 8rpx 0;
  width: 360rpx;
  height: 240rpx;
  background: #000;
  border-radius: var(--r-md);
  overflow: hidden;
}
.rich-video-thumb { width: 100%; height: 100%; }
.rich-video-play {
  position: absolute;
  top: 50%; left: 50%;
  transform: translate(-50%, -50%);
  width: 80rpx; height: 80rpx;
  background: var(--grad-primary);
  border-radius: 50%;
  color: #fff;
  text-align: center;
  line-height: 80rpx;
  font-size: 36rpx;
  box-shadow: 0 4rpx 16rpx rgba(99, 102, 241, 0.4);
}

/* 音频 */
.rich-audio {
  display: flex;
  align-items: center;
  gap: 12rpx;
  padding: 14rpx 18rpx;
  background: var(--c-indigo-50);
  border-radius: var(--r-md);
  margin: 8rpx 0;
  min-width: 300rpx;
  position: relative;
}
.rich-message.self .rich-audio { background: rgba(255, 255, 255, 0.15); }
.rich-audio-icon { font-size: 36rpx; }
.rich-audio-name {
  flex: 1; font-size: 26rpx; color: var(--c-text-1);
  white-space: nowrap; overflow: hidden; text-overflow: ellipsis;
}
.rich-audio-duration {
  position: static;
  background: transparent;
  color: var(--c-text-3);
  font-size: 22rpx;
}

/* 文件 */
.rich-file {
  display: flex;
  align-items: center;
  gap: 12rpx;
  padding: 18rpx;
  background: var(--c-indigo-50);
  border-radius: var(--r-md);
  margin: 8rpx 0;
  min-width: 380rpx;
  position: relative;
}
.rich-message.self .rich-file { background: rgba(255, 255, 255, 0.15); }
.rich-file-icon {
  font-size: 44rpx;
  width: 64rpx; height: 64rpx;
  display: flex; align-items: center; justify-content: center;
  background: var(--grad-primary);
  border-radius: var(--r-md);
  color: #fff;
}
.rich-file-info { flex: 1; }
.rich-file-name {
  font-size: 26rpx;
  font-weight: 500;
  word-break: break-all;
  color: var(--c-text-1);
}
.rich-file-meta {
  font-size: 20rpx;
  color: var(--c-text-3);
  margin-top: 4rpx;
}
.rich-message.self .rich-file-meta { color: rgba(255, 255, 255, 0.7); }

/* 位置 */
.rich-location {
  display: flex;
  align-items: center;
  gap: 12rpx;
  padding: 18rpx;
  background: var(--c-indigo-50);
  border-radius: var(--r-md);
  margin: 8rpx 0;
  min-width: 380rpx;
  position: relative;
}
.rich-message.self .rich-location { background: rgba(255, 255, 255, 0.15); }
.rich-location-icon {
  font-size: 40rpx;
  width: 64rpx; height: 64rpx;
  display: flex; align-items: center; justify-content: center;
  background: #fee2e2;
  border-radius: var(--r-md);
  color: var(--c-danger);
}
.rich-location-info { flex: 1; }
.rich-location-name {
  font-size: 26rpx;
  font-weight: 500;
  color: var(--c-text-1);
}
.rich-location-address {
  font-size: 22rpx;
  color: var(--c-text-2);
  margin-top: 4rpx;
}
.rich-message.self .rich-location-address { color: rgba(255, 255, 255, 0.7); }

/* 卡片(订单/商品) */
.rich-card {
  display: flex;
  align-items: center;
  gap: 12rpx;
  padding: 18rpx;
  background: var(--c-indigo-50);
  border-radius: var(--r-md);
  margin: 8rpx 0;
  min-width: 440rpx;
  position: relative;
}
.rich-message.self .rich-card { background: rgba(255, 255, 255, 0.15); }
.rich-card-icon {
  font-size: 40rpx;
  width: 64rpx; height: 64rpx;
  display: flex; align-items: center; justify-content: center;
  background: var(--grad-primary);
  border-radius: var(--r-md);
  color: #fff;
}
.rich-card-thumb {
  width: 80rpx; height: 80rpx;
  border-radius: var(--r-sm);
  background: var(--c-indigo-100);
}
.rich-card-info { flex: 1; }
.rich-card-title {
  font-size: 26rpx;
  font-weight: 500;
  color: var(--c-text-1);
}
.rich-card-meta,
.rich-card-price {
  font-size: 22rpx;
  color: var(--c-text-3);
  margin-top: 4rpx;
}
.rich-card-price {
  color: var(--c-danger);
  font-weight: 600;
}
.rich-card-arrow {
  color: var(--c-text-3);
  font-size: 36rpx;
}
.rich-message.self .rich-card-arrow { color: rgba(255, 255, 255, 0.6); }
