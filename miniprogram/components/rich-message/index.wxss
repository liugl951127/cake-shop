/* components/rich-message/index.wxss */
.rich-msg {
  display: block;
  word-break: break-word;
  white-space: pre-wrap;
}
.rich-fallback {
  white-space: pre-wrap;
  word-break: break-word;
}

.rk {
  display: inline;
}
.rk-text { color: #333; }
.rk-b { font-weight: 600; }
.rk-i { font-style: italic; }
.rk-u { text-decoration: underline; }
.rk-s { text-decoration: line-through; }
.rk-code {
  font-family: monospace;
  background: #f4f4f4;
  padding: 0 4rpx;
  border-radius: 4rpx;
}
.rk-link {
  color: #1aad19;
  text-decoration: underline;
}
.rk-at {
  color: #576b95;
  font-weight: 500;
}
.rk-emoji {
  display: inline-block;
  font-size: 36rpx;
  line-height: 1;
}
.rk-img {
  display: block;
  max-width: 240rpx;
  max-height: 240rpx;
  border-radius: 8rpx;
  margin: 8rpx 0;
}

.rk-bq {
  display: block;
  border-left: 4rpx solid #ddd;
  padding: 4rpx 12rpx;
  margin: 6rpx 0;
  color: #888;
  background: #fafafa;
}

.rk-product {
  display: flex;
  align-items: center;
  padding: 12rpx;
  margin: 8rpx 0;
  border: 1rpx solid #f0c5d8;
  border-radius: 12rpx;
  background: #fff;
  width: 420rpx;
}
.rk-p-thumb {
  width: 80rpx;
  height: 80rpx;
  border-radius: 8rpx;
  margin-right: 12rpx;
  flex-shrink: 0;
}
.rk-p-info { flex: 1; min-width: 0; }
.rk-p-name {
  font-size: 26rpx;
  color: #333;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}
.rk-p-price {
  font-size: 26rpx;
  color: #e94e6e;
  font-weight: 600;
  margin-top: 4rpx;
}

.rk-order {
  display: block;
  padding: 12rpx 16rpx;
  margin: 8rpx 0;
  border: 1rpx solid #f0c5d8;
  border-radius: 12rpx;
  background: linear-gradient(135deg, #fff5f8, #fde6f0);
  width: 420rpx;
}
.rk-o-title {
  font-size: 26rpx;
  color: #555;
}
.rk-o-status {
  font-size: 22rpx;
  color: #e94e6e;
  margin-top: 4rpx;
}
.rk-o-amount {
  font-size: 30rpx;
  color: #e94e6e;
  font-weight: 600;
  margin-top: 4rpx;
}
