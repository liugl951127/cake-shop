.sms-code-input {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 32rpx 24rpx;
}
.hint {
  font-size: 26rpx;
  color: #666;
  margin-bottom: 24rpx;
}
.boxes {
  display: flex;
  gap: 16rpx;
  margin-bottom: 16rpx;
  position: relative;
}
.box {
  width: 80rpx;
  height: 88rpx;
  border: 2rpx solid #dcdfe6;
  border-radius: 8rpx;
  text-align: center;
  line-height: 84rpx;
  font-size: 40rpx;
  color: #333;
  background: #fff;
  transition: all 0.15s ease;
}
.box.focused {
  border-color: #fa5151;
  box-shadow: 0 0 0 4rpx rgba(250, 81, 81, 0.1);
}
.box.filled {
  border-color: #b3d4fc;
}
.box.error {
  border-color: #fa5151;
  animation: shake 0.4s ease;
}
@keyframes shake {
  0%, 100% { transform: translateX(0); }
  20%, 60% { transform: translateX(-8rpx); }
  40%, 80% { transform: translateX(8rpx); }
}
.hidden-input {
  position: absolute;
  top: -9999rpx;
  left: -9999rpx;
  width: 1rpx;
  height: 1rpx;
  opacity: 0;
}
.error {
  color: #fa5151;
  font-size: 24rpx;
  margin-top: 8rpx;
  min-height: 36rpx;
}
.resend {
  margin-top: 16rpx;
  font-size: 26rpx;
  color: #999;
}
.resend .link {
  color: #fa5151;
  cursor: pointer;
  text-decoration: underline;
}
