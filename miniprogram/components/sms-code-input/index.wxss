/* sms-code-input/index.wxss - 适配浅色卡片 + indigo 主题 */
@import "/styles/theme.wxss";

.sms-code-input {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 32rpx 24rpx;
}
.hint {
  font-size: 26rpx;
  color: var(--c-text-2);
  margin-bottom: 24rpx;
}
.boxes {
  display: flex;
  gap: 20rpx;
  margin-bottom: 16rpx;
  position: relative;
}
.box {
  width: 88rpx;
  height: 96rpx;
  border: 2rpx solid var(--c-indigo-100);
  border-radius: var(--r-md);
  text-align: center;
  line-height: 92rpx;
  font-size: 44rpx;
  color: var(--c-text-1);
  background: var(--c-bg-card);
  transition: all 0.15s ease;
}
.box.focused {
  border-color: var(--c-indigo-500);
  background: #fff;
  box-shadow: 0 0 0 6rpx var(--c-indigo-100);
}
.box.filled {
  border-color: var(--c-indigo-300);
}
.box.error {
  border-color: var(--c-danger);
  animation: shake 0.4s ease;
}
@keyframes shake {
  0%, 100% { transform: translateX(0); }
  20%, 60% { transform: translateX(-8rpx); }
  40%, 80% { transform: translateX(8rpx); }
}
.hidden-input {
  position: absolute;
  top: -9999rpx;
  left: -9999rpx;
  width: 1rpx;
  height: 1rpx;
  opacity: 0;
}
.error {
  color: var(--c-danger);
  font-size: 24rpx;
  margin-top: 8rpx;
  min-height: 36rpx;
}
.resend {
  margin-top: 16rpx;
  font-size: 26rpx;
  color: var(--c-text-3);
}
.resend .link {
  color: var(--c-indigo-600);
  cursor: pointer;
  text-decoration: none;
  padding: 4rpx 16rpx;
  background: var(--c-indigo-50);
  border-radius: var(--r-full);
  font-weight: 500;
}
