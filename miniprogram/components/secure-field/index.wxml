<view class="secure-field">
  <view class="sf-label" wx:if="{{label}}">{{label}}</view>
  <view class="sf-input-wrap">
    <input
      class="sf-input {{error ? 'error' : ''}}"
      type="{{isPassword && obscure ? 'password' : 'text'}}"
      placeholder="{{placeholder}}"
      maxlength="{{maxLength}}"
      value="{{text}}"
      bindinput="onInput"
      placeholder-class="sf-placeholder" />
    <view class="sf-toggle" wx:if="{{showToggle && isPassword}}" bindtap="toggleObscure">
      <text wx:if="{{obscure}}">🙈</text>
      <text wx:else>👀</text>
    </view>
  </view>
  <view class="sf-error" wx:if="{{error}}">{{error}}</view>
  <view class="sf-tip" wx:else>
    <text wx:if="{{fieldType === 'idcard'}}">仅在服务端加密存储,不会明文保存</text>
    <text wx:elif="{{fieldType === 'bankcard'}}">使用加密机 AES-256 加密</text>
    <text wx:elif="{{fieldType === 'phone'}}">用于接收订单通知</text>
    <text wx:elif="{{fieldType === 'email'}}">用于电子发票</text>
  </view>
</view>
