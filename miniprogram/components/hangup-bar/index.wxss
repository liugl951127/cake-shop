/* components/hangup-bar/index.wxss */
.hu-bar {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 12rpx 24rpx;
  background: var(--bg-primary, #fff);
  border-top: 1rpx solid #f0f0f0;
  flex-wrap: wrap;
  gap: 8rpx;
}
.hu-state {
  display: flex;
  align-items: center;
  gap: 8rpx;
  font-size: 24rpx;
  color: #666;
  padding: 6rpx 16rpx;
  background: #f5f5f5;
  border-radius: 999rpx;
}
.hu-state .hu-dot {
  width: 12rpx; height: 12rpx;
  border-radius: 50%;
  background: #ccc;
}
.hu-state.ai .hu-dot { background: #2196f3; }
.hu-state.agent .hu-dot { background: #4caf50; }
.hu-state.transferred .hu-dot { background: #ff7b9c; }
.hu-state.closed .hu-dot { background: #999; }

.hu-actions { display: flex; gap: 12rpx; }
.hu-btn {
  background: transparent;
  border: 1rpx solid #ddd;
  color: #666;
  font-size: 24rpx;
  padding: 10rpx 24rpx;
  border-radius: 999rpx;
  line-height: 1;
}
.hu-btn.primary {
  background: linear-gradient(135deg, #ff7b9c, #ff9a6e);
  color: white;
  border: none;
  box-shadow: 0 2rpx 8rpx rgba(255, 123, 156, 0.3);
}
.hu-btn[disabled] { opacity: 0.6; }

.hu-mask {
  position: fixed;
  inset: 0;
  background: rgba(0,0,0,0.5);
  z-index: 999;
}
.hu-rate {
  position: fixed;
  left: 50%;
  top: 50%;
  transform: translate(-50%, -50%) scale(0.9);
  width: 88%;
  max-width: 600rpx;
  background: #fff;
  border-radius: 24rpx;
  padding: 32rpx 24rpx;
  z-index: 1000;
  opacity: 0;
  transition: all 0.2s;
}
.hu-rate.show {
  transform: translate(-50%, -50%) scale(1);
  opacity: 1;
}
.hu-rate-title {
  text-align: center;
  font-size: 32rpx;
  font-weight: 600;
  margin-bottom: 24rpx;
}
.hu-rate-stars {
  text-align: center;
  margin-bottom: 24rpx;
}
.hu-star {
  font-size: 60rpx;
  color: #ddd;
  margin: 0 8rpx;
}
.hu-star.on { color: #ffb300; }
.hu-rate-tags {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
  margin-bottom: 24rpx;
  justify-content: center;
}
.hu-tag {
  padding: 8rpx 20rpx;
  background: #f5f5f5;
  border-radius: 999rpx;
  font-size: 24rpx;
  color: #666;
}
.hu-tag.on {
  background: #ffd6e2;
  color: #e85a82;
}
.hu-rate-comment {
  width: 100%;
  min-height: 100rpx;
  border: 1rpx solid #e8e8e8;
  border-radius: 12rpx;
  padding: 12rpx;
  font-size: 26rpx;
  box-sizing: border-box;
  margin-bottom: 24rpx;
}
.hu-rate-btns {
  display: flex;
  gap: 16rpx;
}
.hu-rate-btn {
  flex: 1;
  text-align: center;
  padding: 20rpx;
  background: #f5f5f5;
  border-radius: 12rpx;
  font-size: 28rpx;
}
.hu-rate-btn.primary {
  background: linear-gradient(135deg, #ff7b9c, #ff9a6e);
  color: white;
}
