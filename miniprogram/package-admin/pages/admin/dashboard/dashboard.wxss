.page { padding-bottom: 40rpx; }
.cards { display: flex; flex-wrap: wrap; padding: 20rpx 10rpx 0; }
.c-card {
  width: calc(50% - 20rpx); margin: 10rpx;
  background: linear-gradient(135deg, #ff7b9c, #e85a82);
  color: #fff; border-radius: 16rpx; padding: 30rpx;
}
.c-card:nth-child(2) { background: linear-gradient(135deg, #ffa726, #ff9800); }
.c-card:nth-child(3) { background: linear-gradient(135deg, #66bb6a, #43a047); }
.c-card:nth-child(4) { background: linear-gradient(135deg, #42a5f5, #1976d2); }
.c-label { font-size: 24rpx; opacity: 0.9; }
.c-val { font-size: 44rpx; font-weight: bold; margin-top: 10rpx; }

.card { background: #fff; margin: 20rpx; border-radius: 16rpx; padding: 24rpx; }
.card-title { font-size: 28rpx; font-weight: 600; margin-bottom: 20rpx; }
.row { display: flex; padding: 12rpx 0; font-size: 26rpx; }
.label { width: 200rpx; color: #666; }
.val { flex: 1; text-align: right; }

/* 柱状图 */
.chart { display: flex; height: 300rpx; align-items: flex-end; padding: 30rpx 0; }
.bar-col { flex: 1; text-align: center; height: 100%; display: flex; flex-direction: column; justify-content: flex-end; align-items: center; }
.bar-val { font-size: 20rpx; color: #999; }
.bar {
  width: 50rpx; background: linear-gradient(180deg, #ff7b9c, #e85a82);
  border-radius: 8rpx 8rpx 0 0; min-height: 30rpx;
  display: flex; align-items: flex-start; justify-content: center; padding-top: 8rpx;
  color: #fff; font-size: 18rpx;
}
.bar-date { font-size: 20rpx; color: #999; margin-top: 8rpx; }

.status-grid { display: flex; flex-wrap: wrap; }
.s-block { width: 25%; text-align: center; padding: 16rpx 0; }
.s-name { font-size: 24rpx; }
.s-count { font-size: 36rpx; font-weight: bold; margin-top: 6rpx; }

.funnel .f-row { display: flex; align-items: center; margin: 16rpx 0; }
.f-label { width: 80rpx; font-size: 26rpx; color: #666; }
.f-bar {
  height: 60rpx; border-radius: 0 60rpx 60rpx 0;
  display: flex; align-items: center; padding: 0 20rpx;
  color: #fff; font-size: 24rpx; min-width: 100rpx;
}

.hot-list { }
.hot-item {
  display: flex; align-items: center; padding: 16rpx 0;
  border-bottom: 1rpx solid #f5f5f5;
}
.hot-item:last-child { border-bottom: none; }
.hot-rank {
  width: 40rpx; height: 40rpx; border-radius: 50%;
  background: #eee; color: #999; text-align: center; line-height: 40rpx;
  font-size: 22rpx; margin-right: 16rpx;
}
.hot-rank.top { background: #ff5722; color: #fff; }
.hot-img { width: 80rpx; height: 80rpx; border-radius: 8rpx; background: #f0f0f0; }
.hot-info { flex: 1; margin-left: 16rpx; min-width: 0; }
.hot-name { font-size: 26rpx; }
.hot-price { font-size: 22rpx; }
.hot-sales { font-size: 22rpx; color: #999; }

.big-screen-btn {
  background: linear-gradient(135deg, #5b8cff, #1e3a5f);
  color: #fff; text-align: center; padding: 28rpx 0;
  border-radius: 999rpx; font-size: 30rpx; margin: 40rpx 0;
}
.big-screen-btn.secondary { background: linear-gradient(135deg, #ff5722, #ff9800); margin-top: 20rpx; }
