.page { padding-bottom: 40rpx; }
.head { background: linear-gradient(135deg, #1e3a5f, #0a1929); color: #fff; padding: 40rpx 30rpx 30rpx; }
.head .big { font-size: 36rpx; font-weight: bold; }
.head .sub { font-size: 22rpx; margin-top: 8rpx; opacity: 0.85; }

.tabs { display: flex; background: #fff; overflow-x: auto; }
.t { flex-shrink: 0; padding: 24rpx 30rpx; font-size: 24rpx; color: #666; position: relative; }
.t.on { color: #1e3a5f; font-weight: 600; }
.t.on::after { content: ''; position: absolute; left: 30rpx; right: 30rpx; bottom: 0; height: 4rpx; background: #1e3a5f; border-radius: 2rpx; }

.kpi { display: flex; padding: 20rpx; gap: 12rpx; }
.k { flex: 1; background: #fff; border-radius: 12rpx; padding: 24rpx 0; text-align: center; }
.k-n { display: block; font-size: 36rpx; font-weight: bold; color: #1e3a5f; }
.k-n.green { color: #4caf50; }
.k-n.orange { color: #ff9800; }
.k-n.red { color: #ff5722; }
.k-l { display: block; font-size: 22rpx; color: #999; margin-top: 4rpx; }
.kpi-sm { display: flex; padding: 0 20rpx 20rpx; gap: 12rpx; }
.k2 { flex: 1; background: #fff; border-radius: 12rpx; padding: 16rpx 0; text-align: center; }

.card { background: #fff; margin: 20rpx; border-radius: 12rpx; padding: 20rpx; }
.c-title { font-size: 28rpx; font-weight: 600; margin-bottom: 16rpx; }

.trend { padding: 20rpx 0; }
.t-row { display: flex; align-items: flex-end; padding: 4rpx 0; }
.t-date { width: 100rpx; font-size: 22rpx; color: #999; }
.t-bars { display: flex; gap: 4rpx; align-items: flex-end; }
.bar { width: 30rpx; border-radius: 4rpx 4rpx 0 0; transition: height 0.3s; }
.bar.pass { background: #4caf50; }
.bar.verify { background: #2196f3; }
.bar.manual { background: #ff9800; }
.bar.reject { background: #ff5722; }
.legend { display: flex; gap: 16rpx; padding: 16rpx 0; font-size: 22rpx; color: #666; }
.lg::before { content: '■ '; }
.lg.pass::before { color: #4caf50; }
.lg.verify::before { color: #2196f3; }
.lg.manual::before { color: #ff9800; }
.lg.reject::before { color: #ff5722; }

.rule-row { display: flex; padding: 12rpx 0; border-bottom: 1rpx solid #f0f0f0; font-size: 24rpx; }
.r-code { flex: 1; color: #333; font-family: 'Courier New', monospace; }
.r-cnt { color: #ff5722; font-weight: 600; }

.r-head { display: flex; justify-content: space-between; align-items: center; margin-bottom: 12rpx; }
.r-scenario {
  padding: 4rpx 12rpx; background: #e3f2fd; color: #1976d2;
  border-radius: 6rpx; font-size: 22rpx;
}
.r-score { font-size: 28rpx; font-weight: bold; }
.r-decision {
  padding: 4rpx 12rpx; border-radius: 6rpx; font-size: 22rpx;
  background: #f5f5f5; color: #666;
}
.r-decision.decision-pass { background: #e8f5e9; color: #2e7d32; }
.r-decision.decision-verify { background: #e3f2fd; color: #1976d2; }
.r-decision.decision-manual { background: #fff3e0; color: #ef6c00; }
.r-decision.decision-reject { background: #ffebee; color: #c62828; }

.r-row { display: flex; padding: 8rpx 0; font-size: 24rpx; }
.r-l { color: #999; min-width: 80rpx; }
.text-sub { color: #999; font-size: 22rpx; }

.r-factors { display: flex; flex-wrap: wrap; gap: 8rpx; margin-top: 12rpx; }
.factor { font-size: 20rpx; padding: 4rpx 10rpx; background: #ffebee; color: #c62828; border-radius: 6rpx; }

.r-actions { padding: 16rpx 0; text-align: center; color: #ff5722; font-size: 24rpx; border-top: 1rpx solid #f0f0f0; margin-top: 12rpx; }

.filters { display: flex; padding: 16rpx 20rpx; background: #fff; }
.f { padding: 8rpx 20rpx; background: #f5f5f5; color: #666; font-size: 24rpx; border-radius: 999rpx; margin-right: 12rpx; }
.f.on { background: #1e3a5f; color: #fff; }

.th { display: flex; padding: 12rpx 0; border-bottom: 1rpx solid #f0f0f0; font-size: 24rpx; }
.th-name { flex: 1; color: #333; font-weight: 600; }
.th-r, .th-m, .th-v { color: #999; margin-right: 12rpx; }
.th-r { color: #ff5722; }
.th-m { color: #ff9800; }
.th-v { color: #2196f3; }

.rl { display: flex; padding: 12rpx 0; border-bottom: 1rpx solid #f0f0f0; font-size: 24rpx; }
.rl-cat {
  padding: 2rpx 10rpx; font-size: 20rpx; border-radius: 6rpx;
  background: #f5f5f5; color: #666; margin-right: 12rpx;
}
.rl-cat.cat-identity { background: #ffebee; color: #c62828; }
.rl-cat.cat-auth { background: #e3f2fd; color: #1976d2; }
.rl-cat.cat-behavior { background: #fff3e0; color: #ef6c00; }
.rl-cat.cat-device { background: #f3e5f5; color: #6a1b9a; }
.rl-code { flex: 1; color: #333; font-family: 'Courier New', monospace; font-size: 22rpx; }
.rl-w { color: #ff5722; font-weight: 600; }

.add-bar {
  background: linear-gradient(135deg, #ff5722, #ff9800); color: #fff;
  text-align: center; padding: 20rpx 0; border-radius: 999rpx;
  font-size: 28rpx; margin: 20rpx;
}

.empty { text-align: center; color: #ccc; padding: 60rpx 0; }
