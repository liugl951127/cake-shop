.page { padding-bottom: 40rpx; }
.head { background: linear-gradient(135deg, #5b8cff, #1e3a5f); color: #fff; padding: 40rpx 30rpx 30rpx; }
.head .big { font-size: 36rpx; font-weight: bold; }
.head .sub { font-size: 22rpx; margin-top: 8rpx; opacity: 0.85; }

.categories { display: flex; padding: 16rpx 20rpx; background: #fff; }
.c { padding: 8rpx 20rpx; background: #f5f5f5; color: #666; font-size: 24rpx; border-radius: 999rpx; margin-right: 12rpx; }
.c.on { background: #5b8cff; color: #fff; }

.list { padding: 0 20rpx; }
.p {
  display: flex; align-items: center; background: #fff;
  border-radius: 12rpx; padding: 24rpx; margin-bottom: 16rpx;
}
.p-emoji { font-size: 60rpx; margin-right: 20rpx; }
.p-info { flex: 1; }
.p-name { font-size: 28rpx; font-weight: 600; color: #333; }
.p-version { font-size: 20rpx; color: #999; margin-left: 8rpx; }
.p-installed { font-size: 20rpx; color: #4caf50; margin-left: 8rpx; padding: 2rpx 10rpx; background: #e8f5e9; border-radius: 6rpx; }
.p-desc { font-size: 22rpx; color: #999; margin-top: 6rpx; line-height: 1.5; }
.p-meta { font-size: 20rpx; color: #bbb; margin-top: 8rpx; }
.p-meta text { margin-right: 6rpx; }
.p-btn {
  font-size: 24rpx; padding: 12rpx 24rpx; border-radius: 999rpx;
  background: #5b8cff; color: #fff; white-space: nowrap;
}
.p-btn.un { background: #fff; color: #ff5722; border: 1rpx solid #ff5722; }
