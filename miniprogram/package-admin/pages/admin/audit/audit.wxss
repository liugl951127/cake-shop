.page { padding-bottom: 40rpx; }
.head { background: linear-gradient(135deg, #5b8cff, #1e3a5f); color: #fff; padding: 40rpx 30rpx 30rpx; }
.head .big { font-size: 36rpx; font-weight: bold; }
.head .sub { font-size: 22rpx; margin-top: 8rpx; opacity: 0.85; }

.filters { display: flex; padding: 16rpx 20rpx; background: #fff; }
.f { padding: 8rpx 20rpx; background: #f5f5f5; color: #666; font-size: 24rpx; border-radius: 999rpx; margin-right: 12rpx; }
.f.on { background: #5b8cff; color: #fff; }

.list { padding: 0 20rpx; }
.l-row { background: #fff; border-radius: 12rpx; padding: 20rpx; margin-bottom: 16rpx; }
.l-head { display: flex; justify-content: space-between; align-items: center; }
.l-action {
  padding: 4rpx 12rpx; border-radius: 6rpx; font-size: 22rpx;
  background: #f5f5f5; color: #666;
}
.l-action.action-create { background: #e8f5e9; color: #2e7d32; }
.l-action.action-update { background: #e3f2fd; color: #1976d2; }
.l-action.action-delete { background: #ffebee; color: #c62828; }
.l-action.action-finance { background: #fff3e0; color: #ef6c00; }
.l-action.action-refund { background: #fce4ec; color: #c2185b; }
.l-time { font-size: 22rpx; color: #999; }
.l-detail { font-size: 24rpx; color: #666; margin-top: 8rpx; line-height: 1.5; word-break: break-all; }
.empty { text-align: center; color: #ccc; padding: 40rpx 0; }
.more { text-align: center; color: #1976d2; padding: 30rpx 0; font-size: 26rpx; }
