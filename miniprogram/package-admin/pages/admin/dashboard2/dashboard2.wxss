.page { background: #0a1929; min-height: 100vh; color: #fff; padding: 20rpx; }
.page.dark { background: #0a1929; color: #fff; }

.header { display: flex; align-items: center; padding: 10rpx 0 20rpx; }
.title { font-size: 32rpx; font-weight: bold; flex: 1; color: #4fc3f7; }
.time { font-size: 22rpx; color: #888; margin-right: 20rpx; }
.refresh, .theme { padding: 6rpx 16rpx; background: rgba(79,195,247,0.2); color: #4fc3f7; border-radius: 999rpx; font-size: 22rpx; margin-left: 10rpx; }

.kpi-row { display: flex; gap: 16rpx; margin-bottom: 16rpx; }
.kpi {
  flex: 1; background: linear-gradient(135deg, #1e3a5f, #0d2540);
  border: 1rpx solid #2a4a7a; border-radius: 12rpx; padding: 24rpx;
}
.kpi.sm { padding: 16rpx; }
.k-label { font-size: 24rpx; color: #88a; margin-bottom: 8rpx; }
.k-value { font-size: 48rpx; font-weight: bold; color: #4fc3f7; font-family: 'Courier New', monospace; }
.k-value.sm-v { font-size: 36rpx; }
.k-sub { font-size: 22rpx; color: #88a; margin-top: 4rpx; }
.k-sub.up { color: #4caf50; }
.k-sub.down { color: #ff5722; }

.card {
  background: linear-gradient(135deg, #1e3a5f, #0d2540);
  border: 1rpx solid #2a4a7a; border-radius: 12rpx;
  padding: 24rpx; margin-bottom: 20rpx;
}
.c-title { font-size: 28rpx; font-weight: 600; color: #4fc3f7; margin-bottom: 20rpx; display: flex; justify-content: space-between; }
.c-tip { font-size: 22rpx; color: #88a; font-weight: normal; }

.chart { }
.bar-row { display: flex; align-items: center; padding: 6rpx 0; }
.bar-date { width: 90rpx; font-size: 22rpx; color: #88a; }
.bar-track { flex: 1; background: rgba(79,195,247,0.1); border-radius: 4rpx; margin: 0 12rpx; height: 24rpx; overflow: hidden; }
.bar-fill {
  background: linear-gradient(90deg, #4fc3f7, #29b6f6);
  border-radius: 4rpx; transition: width 0.3s;
}
.bar-val { font-size: 22rpx; color: #4fc3f7; min-width: 120rpx; text-align: right; }

.funnel { }
.f-step { display: flex; align-items: center; margin-bottom: 12rpx; }
.f-name { width: 100rpx; font-size: 24rpx; color: #88a; }
.f-bar {
  height: 36rpx; background: linear-gradient(90deg, #4fc3f7, #29b6f6);
  border-radius: 6rpx; transition: width 0.3s;
  min-width: 40rpx;
}
.f-val { margin-left: 12rpx; font-size: 24rpx; color: #fff; font-family: 'Courier New', monospace; }

.realtime { height: 320rpx; }
.r-row {
  display: flex; padding: 12rpx 0; border-bottom: 1rpx solid rgba(255,255,255,0.05);
  font-size: 24rpx;
}
.r-amount { color: #4fc3f7; font-weight: bold; min-width: 100rpx; }
.r-no { color: #88a; flex: 1; }
.r-time { color: #888; }

.top-list { }
.t-row { display: flex; align-items: center; padding: 12rpx 0; border-bottom: 1rpx solid rgba(255,255,255,0.05); }
.t-rank { width: 50rpx; height: 50rpx; line-height: 48rpx; text-align: center; font-size: 26rpx; color: #888; font-weight: bold; }
.t-rank.top3 { background: linear-gradient(135deg, #ff9800, #ff5722); color: #fff; border-radius: 50%; }
.t-img { width: 60rpx; height: 60rpx; border-radius: 8rpx; background: #2a4a7a; }
.t-info { flex: 1; margin-left: 16rpx; }
.t-name { font-size: 26rpx; color: #fff; }
.t-sub { font-size: 22rpx; color: #88a; margin-top: 4rpx; }

.cs-row { display: flex; }
.cs { flex: 1; text-align: center; padding: 16rpx 0; }
.cs-n { display: block; font-size: 40rpx; color: #4fc3f7; font-weight: bold; }
.cs-l { display: block; font-size: 22rpx; color: #88a; margin-top: 4rpx; }

.m-row { display: flex; justify-content: space-between; padding: 12rpx 0; border-bottom: 1rpx solid rgba(255,255,255,0.05); }
.m-row:last-child { border-bottom: none; }
.m-l { color: #88a; font-size: 26rpx; }
.m-v { color: #4fc3f7; font-size: 28rpx; font-weight: bold; }
.m-v.red { color: #ff5722; }

.empty { text-align: center; color: #88a; padding: 30rpx 0; }
