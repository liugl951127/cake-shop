.page { padding-bottom: 40rpx; }
.head { background: linear-gradient(135deg, #5b8cff, #1e3a5f); color: #fff; padding: 40rpx 30rpx 30rpx; }
.head .big { font-size: 36rpx; font-weight: bold; }
.head .sub { font-size: 22rpx; margin-top: 8rpx; opacity: 0.85; }

.add-btn {
  background: linear-gradient(135deg, #ff5722, #ff9800); color: #fff;
  text-align: center; padding: 20rpx 0; border-radius: 999rpx; font-size: 28rpx;
  margin: 20rpx;
}

.role-card { background: #fff; margin: 0 20rpx 20rpx; border-radius: 12rpx; padding: 16rpx; }
.r-row { display: flex; padding: 12rpx 0; border-bottom: 1rpx solid #f0f0f0; font-size: 26rpx; }
.r-row:last-child { border-bottom: none; }
.r-name { flex: 1; color: #333; font-weight: 600; }
.r-perm { color: #999; }

.list { padding: 0 20rpx; }
.emp { background: #fff; border-radius: 12rpx; padding: 24rpx; margin-bottom: 16rpx; display: flex; align-items: center; }
.e-info { flex: 1; }
.e-name { font-size: 28rpx; color: #333; font-weight: 600; }
.e-phone { font-size: 22rpx; color: #999; margin-top: 4rpx; }
.e-role {
  padding: 6rpx 16rpx; border-radius: 999rpx; font-size: 22rpx;
  background: #e3f2fd; color: #1976d2; margin-right: 16rpx;
}
.e-role.role-super_admin { background: #fce4ec; color: #c2185b; }
.e-role.role-admin { background: #fff3e0; color: #ef6c00; }
.e-role.role-finance { background: #e8f5e9; color: #2e7d32; }
.e-role.role-customer_service { background: #e1f5fe; color: #0277bd; }
.e-role.role-operator { background: #f3e5f5; color: #6a1b9a; }
.e-status { font-size: 22rpx; color: #999; margin-right: 16rpx; }
.e-act { display: flex; flex-direction: column; }
.e-btn { font-size: 22rpx; color: #1976d2; padding: 4rpx 0; }
.empty { text-align: center; color: #ccc; padding: 40rpx 0; }
