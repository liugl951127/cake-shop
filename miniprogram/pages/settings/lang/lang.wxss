.page { padding: 20rpx; }
.lang-list { background: #fff; border-radius: 16rpx; overflow: hidden; }
.lang-item {
  display: flex; align-items: center; justify-content: space-between;
  padding: 30rpx; border-bottom: 1rpx solid #f5f5f5; font-size: 30rpx;
}
.lang-item:last-child { border-bottom: none; }
.lang-item.active { color: var(--primary); }
.lang-name { font-size: 30rpx; }
.check { color: var(--primary); font-size: 32rpx; font-weight: bold; }
.footer {
  margin-top: 30rpx; text-align: center; color: #999; font-size: 24rpx;
}
