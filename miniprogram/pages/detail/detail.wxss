.page { padding-bottom: 120rpx; background: #f7f7f7; }
.top-swiper { width: 100%; height: 750rpx; background: #fff; }
.top-img { width: 100%; height: 750rpx; }

.info { background: #fff; padding: 30rpx; }
.price-row { display: flex; align-items: baseline; }
.big-price { color: var(--price); font-size: 44rpx; font-weight: bold; }
.big-price::before { content: ''; }
.origin { color: #bbb; text-decoration: line-through; font-size: 24rpx; margin-left: 12rpx; }
.sales { margin-left: auto; color: #999; font-size: 24rpx; }
.name { font-size: 32rpx; font-weight: 600; margin-top: 12rpx; line-height: 1.4; }
.tags { margin-top: 16rpx; }
.tag { background: var(--primary-light); color: var(--primary); font-size: 22rpx; padding: 4rpx 12rpx; border-radius: 6rpx; margin-right: 12rpx; }
.desc { margin-top: 16rpx; font-size: 26rpx; }

.card { background: #fff; margin: 20rpx; border-radius: 16rpx; padding: 24rpx; }
.card-title { font-size: 28rpx; font-weight: 600; margin-bottom: 16rpx; }
.card-row { display: flex; align-items: center; padding: 14rpx 0; }
.card-row .text-sub { width: 120rpx; }
.card-row text:nth-child(2) { flex: 1; }
.arrow { color: #ccc; }
.detail rich-text { font-size: 26rpx; line-height: 1.6; }
.detail-img { width: 100%; margin-top: 20rpx; border-radius: 8rpx; }

.also-list { white-space: nowrap; }
.also-item {
  display: inline-block; width: 200rpx; margin-right: 20rpx;
  background: #fff;
}
.also-img { width: 200rpx; height: 200rpx; border-radius: 12rpx; background: #f0f0f0; }
.also-name { font-size: 24rpx; margin: 8rpx 0; }
.also-price { font-size: 26rpx; font-weight: bold; }

.bottom-bar {
  position: fixed; left: 0; right: 0; bottom: 0;
  background: #fff; height: 100rpx; display: flex;
  border-top: 1rpx solid #eee; z-index: 100;
}
.bar-side { flex: 1; display: flex; flex-direction: column; align-items: center; justify-content: center; font-size: 20rpx; color: #666; }
.bar-side text:first-child { font-size: 36rpx; }
.bar-cart, .bar-buy {
  width: 220rpx; display: flex; align-items: center; justify-content: center;
  color: #fff; font-size: 28rpx;
}
.bar-cart { background: linear-gradient(135deg,#ffa726,#ff9800); border-bottom-left-radius: 0; }
.bar-buy { background: linear-gradient(135deg,#ff7b9c,#e85a82); border-bottom-right-radius: 0; }

/* 规格弹层 */
.mask { z-index: 1000; }
.spec-panel {
  position: fixed; left: 0; right: 0; bottom: -100%;
  background: #fff; border-top-left-radius: 24rpx; border-top-right-radius: 24rpx;
  transition: bottom 0.3s; z-index: 1001; max-height: 80vh;
  display: flex; flex-direction: column;
}
.spec-panel.show { bottom: 0; }
.spec-head {
  display: flex; padding: 30rpx; position: relative;
  border-bottom: 1rpx solid #f0f0f0;
}
.spec-img { width: 160rpx; height: 160rpx; border-radius: 12rpx; background: #f0f0f0; }
.spec-head-info { margin-left: 20rpx; flex: 1; }
.spec-price { color: var(--price); font-size: 36rpx; font-weight: bold; }
.spec-price::before { content: '¥'; }
.spec-close { position: absolute; right: 30rpx; top: 20rpx; font-size: 50rpx; color: #999; }
.spec-body { flex: 1; padding: 20rpx 30rpx; overflow: auto; }
.spec-group { margin-bottom: 30rpx; }
.spec-group-name { font-size: 28rpx; margin-bottom: 16rpx; }
.spec-options { display: flex; flex-wrap: wrap; }
.spec-opt {
  padding: 12rpx 30rpx; background: #f5f5f5; border-radius: 8rpx;
  margin: 0 16rpx 16rpx 0; font-size: 26rpx;
}
.spec-opt.active { background: var(--primary-light); color: var(--primary); border: 1rpx solid var(--primary); }
.qty-row { display: flex; align-items: center; }
.qty-btn {
  width: 60rpx; height: 60rpx; background: #f5f5f5; text-align: center;
  line-height: 60rpx; border-radius: 8rpx; font-size: 32rpx;
}
.qty-num { width: 100rpx; text-align: center; font-size: 28rpx; }
.spec-foot { display: flex; height: 100rpx; border-top: 1rpx solid #eee; }
.spec-foot .bar-cart, .spec-foot .bar-buy { flex: 1; }
