/* pages/detail/detail.wxss - 商品详情 浅色卡片 + indigo 渐变 + 大圆角 */
@import "/styles/theme.wxss";

.page { padding-bottom: 140rpx; background: var(--c-bg-page); }
.top-swiper {
  width: 100%; height: 750rpx;
  background: var(--c-bg-card);
  border-bottom-left-radius: var(--r-lg);
  border-bottom-right-radius: var(--r-lg);
  overflow: hidden;
}
.top-img { width: 100%; height: 750rpx; }

/* 顶部信息 - 浅色卡片 */
.info {
  background: var(--c-bg-card);
  margin: -40rpx 24rpx 0;
  border-radius: var(--r-lg);
  padding: 32rpx;
  position: relative;
  z-index: 2;
  box-shadow: var(--sh-2);
}
.price-row {
  display: flex; align-items: baseline; gap: 12rpx;
}
.big-price {
  color: var(--c-danger);
  font-size: 48rpx;
  font-weight: 700;
  display: flex; align-items: baseline; gap: 4rpx;
}
.big-price::before {
  content: '¥';
  font-size: 28rpx;
  color: var(--c-danger);
}
.origin {
  color: var(--c-text-3);
  text-decoration: line-through;
  font-size: 24rpx;
}
.sales {
  margin-left: auto;
  color: var(--c-text-3);
  font-size: 22rpx;
  background: var(--c-indigo-50);
  padding: 4rpx 12rpx;
  border-radius: var(--r-full);
}
.name {
  font-size: 32rpx;
  font-weight: 600;
  margin-top: 16rpx;
  line-height: 1.4;
  color: var(--c-text-1);
}
.tags { margin-top: 16rpx; display: flex; flex-wrap: wrap; gap: 8rpx; }
.tag {
  background: var(--c-indigo-50);
  color: var(--c-indigo-600);
  font-size: 22rpx;
  padding: 4rpx 14rpx;
  border-radius: var(--r-full);
  font-weight: 500;
}
.desc { margin-top: 16rpx; font-size: 26rpx; color: var(--c-text-2); line-height: 1.6; }

/* 卡片组 */
.card {
  background: var(--c-bg-card);
  margin: 24rpx;
  border-radius: var(--r-lg);
  padding: 28rpx;
  box-shadow: var(--sh-1);
}
.card-title { font-size: 28rpx; font-weight: 600; margin-bottom: 16rpx; color: var(--c-text-1); }
.card-row { display: flex; align-items: center; padding: 14rpx 0; }
.card-row .text-sub { width: 120rpx; color: var(--c-text-3); }
.card-row text:nth-child(2) { flex: 1; color: var(--c-text-1); }
.arrow { color: var(--c-text-3); }
.detail rich-text { font-size: 26rpx; line-height: 1.6; color: var(--c-text-1); }
.detail-img { width: 100%; margin-top: 20rpx; border-radius: var(--r-md); }

/* 看了又看 */
.also-list { white-space: nowrap; }
.also-item {
  display: inline-block; width: 200rpx; margin-right: 20rpx;
  background: var(--c-bg-card);
  border-radius: var(--r-md);
  padding: 12rpx;
  box-shadow: var(--sh-1);
}
.also-img { width: 200rpx; height: 200rpx; border-radius: var(--r-sm); background: var(--c-indigo-50); }
.also-name { font-size: 24rpx; margin: 8rpx 0; color: var(--c-text-1); }
.also-price {
  font-size: 26rpx; font-weight: 700;
  color: var(--c-danger);
}

/* 底部操作栏 - 渐变按钮 */
.bottom-bar {
  position: fixed; left: 0; right: 0; bottom: 0;
  background: var(--c-bg-card);
  height: 110rpx;
  display: flex;
  border-top: 1rpx solid var(--c-border-soft);
  z-index: 100;
  padding-bottom: env(safe-area-inset-bottom);
}
.bar-side {
  flex: 1;
  display: flex; flex-direction: column; align-items: center; justify-content: center;
  font-size: 20rpx; color: var(--c-text-2);
  position: relative;
}
.bar-side:active { background: var(--c-indigo-50); }
.bar-side text:first-child { font-size: 36rpx; }
.bar-cart, .bar-buy {
  width: 240rpx;
  display: flex; align-items: center; justify-content: center;
  color: #fff; font-size: 28rpx; font-weight: 500;
  height: 100%;
}
.bar-cart {
  background: linear-gradient(135deg, #f59e0b 0%, #f43f5e 100%);
}
.bar-buy {
  background: var(--grad-primary);
  box-shadow: inset 4rpx 0 0 rgba(255, 255, 255, 0.12);
}
.bar-cart:active, .bar-buy:active { opacity: 0.92; }

/* 规格弹层 */
.mask { z-index: 1000; background: rgba(0, 0, 0, 0.5); }
.spec-panel {
  position: fixed; left: 0; right: 0; bottom: -100%;
  background: #fff; border-top-left-radius: var(--r-lg);
  border-top-right-radius: var(--r-lg);
  transition: bottom 0.3s; z-index: 1001; max-height: 80vh;
  display: flex; flex-direction: column;
}
.spec-panel.show { bottom: 0; }
.spec-head {
  display: flex; padding: 32rpx; position: relative;
  border-bottom: 1rpx solid var(--c-border-soft);
}
.spec-img {
  width: 160rpx; height: 160rpx;
  border-radius: var(--r-md);
  background: var(--c-indigo-50);
  margin-top: -60rpx;
  box-shadow: var(--sh-2);
}
.spec-head-info { margin-left: 20rpx; flex: 1; padding-top: 8rpx; }
.spec-price {
  color: var(--c-danger);
  font-size: 36rpx; font-weight: 700;
  display: flex; align-items: baseline; gap: 2rpx;
}
.spec-price::before { content: '¥'; font-size: 24rpx; }
.spec-stock { color: var(--c-text-3); font-size: 22rpx; margin-top: 4rpx; display: block; }
.spec-close {
  position: absolute; right: 30rpx; top: 24rpx;
  font-size: 44rpx; color: var(--c-text-3);
  width: 60rpx; height: 60rpx; line-height: 56rpx;
  text-align: center;
  border-radius: 50%;
  background: var(--c-indigo-50);
}
.spec-body { flex: 1; padding: 24rpx 32rpx; overflow: auto; }
.spec-group { margin-bottom: 32rpx; }
.spec-group-name { font-size: 28rpx; margin-bottom: 16rpx; color: var(--c-text-1); font-weight: 500; }
.spec-options { display: flex; flex-wrap: wrap; gap: 16rpx; }
.spec-opt {
  padding: 14rpx 28rpx;
  background: var(--c-indigo-50);
  border-radius: var(--r-full);
  font-size: 26rpx;
  color: var(--c-text-1);
  border: 2rpx solid transparent;
  transition: all 0.15s;
}
.spec-opt:active { background: var(--c-indigo-100); }
.spec-opt.active {
  background: var(--c-indigo-50);
  color: var(--c-indigo-600);
  border-color: var(--c-indigo-500);
  font-weight: 500;
}
.qty-row { display: flex; align-items: center; gap: 16rpx; }
.qty-row text:first-child { font-size: 28rpx; color: var(--c-text-1); }
.qty-btn {
  width: 64rpx; height: 64rpx;
  background: var(--c-indigo-50);
  text-align: center;
  line-height: 60rpx;
  border-radius: var(--r-md);
  font-size: 36rpx;
  color: var(--c-indigo-600);
  font-weight: 500;
}
.qty-btn:active { background: var(--c-indigo-100); }
.qty-num { width: 100rpx; text-align: center; font-size: 30rpx; color: var(--c-text-1); font-weight: 500; }
.spec-foot { display: flex; height: 110rpx; border-top: 1rpx solid var(--c-border-soft); }
.spec-foot .bar-cart, .spec-foot .bar-buy { flex: 1; }
