.page { padding-bottom: 0; }
.info-bar {
  background: #fff; padding: 20rpx 30rpx; display: flex; align-items: center;
  justify-content: space-between; font-size: 28rpx;
  border-bottom: 1rpx solid #f0f0f0;
}
.close { color: #f5222d; font-size: 26rpx; }

.messages { background: #f5f5f5; height: calc(100vh - 200rpx); padding: 20rpx; }
.msg { display: flex; margin-bottom: 24rpx; align-items: flex-start; }
.msg.right { flex-direction: row-reverse; }
.m-avatar {
  width: 70rpx; height: 70rpx; border-radius: 50%;
  background: #5b8cff; color: #fff;
  display: flex; align-items: center; justify-content: center;
  font-size: 22rpx; flex-shrink: 0; margin: 0 16rpx;
}
.m-avatar.me { background: var(--primary); padding: 0; overflow: hidden; }
.m-avatar.me image { width: 100%; height: 100%; }
.m-bubble {
  max-width: 70%; background: #fff; border-radius: 12rpx;
  padding: 16rpx 20rpx;
}
.msg.right .m-bubble { background: #95d6f5; }
.m-text { font-size: 28rpx; line-height: 1.5; word-break: break-all; }
.m-time { font-size: 22rpx; color: #999; margin-top: 6rpx; }

.input-bar {
  position: fixed; left: 0; right: 0; bottom: 0;
  background: #fff; padding: 16rpx 20rpx;
  display: flex; align-items: center; border-top: 1rpx solid #eee;
}
.input { flex: 1; background: #f5f5f5; border-radius: 999rpx; padding: 16rpx 24rpx; font-size: 28rpx; }
.send-btn {
  margin-left: 16rpx; background: var(--primary); color: #fff;
  padding: 16rpx 32rpx; border-radius: 999rpx; font-size: 28rpx;
}
