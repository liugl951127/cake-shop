<view class="page">
  <!-- 顶部状态栏 -->
  <view class="status-bar {{stateClass}}">
    <view class="status-dot"></view>
    <text class="status-text">{{stateText}}</text>
    <text class="status-sub" wx:if="{{stateSub}}">{{stateSub}}</text>
  </view>

  <scroll-view scroll-y scroll-into-view="{{lastMessageId}}" class="messages"
               style="height: calc(100vh - 220rpx);">
    <view wx:for="{{messages}}" wx:key="messageId" id="msg-{{item.messageId}}"
          class="msg {{item.fromType === 'user' ? 'right' : 'left'}}">
      <view class="m-avatar" wx:if="{{item.fromType !== 'user'}}">
        {{item.fromName || '客服'}}
      </view>
      <view class="m-bubble {{item.fromType === 'system' ? 'system' : ''}}">
        <view class="m-text" wx:if="{{item.type === 'text'}}">{{item.content}}</view>
        <view class="m-text" wx:elif="{{item.fromType === 'system'}}" style="font-size:24rpx;color:#999;">{{item.content}}</view>
        <view class="m-time">{{item.timeText}}</view>
      </view>
      <view class="m-avatar me" wx:if="{{item.fromType === 'user'}}">
        <image src="{{userInfo.avatarUrl || '/images/default-avatar.png'}}" mode="aspectFill"/>
      </view>
    </view>

    <!-- 对方正在输入 -->
    <view class="typing" wx:if="{{peerTyping}}">
      <view class="t-dot"></view><view class="t-dot"></view><view class="t-dot"></view>
      <text>{{peerTypingName || '客服'}}正在输入...</text>
    </view>
  </scroll-view>

  <view class="input-bar">
    <input class="input" placeholder="输入消息" value="{{inputText}}"
           bindinput="onInput" bindconfirm="onSend" bindfocus="onFocus"
           confirm-type="send" hold-keyboard="{{false}}"/>
    <view class="send-btn {{inputText ? '' : 'disabled'}}" bindtap="onSend">发送</view>
  </view>
</view>
