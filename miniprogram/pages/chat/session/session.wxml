<view class="page">
  <view class="status-bar" wx:if="{{session.status === 2}}">
    <text>🕒 正在为您接入客服,排队第 {{session.waitingPosition || 1}} 位...</text>
  </view>
  <view class="status-bar connected" wx:elif="{{session.status === 1}}">
    <text>✓ 已接入客服 {{session.adminName || '客服'}}</text>
  </view>

  <scroll-view scroll-y scroll-into-view="{{lastMessageId}}" class="messages"
               style="height: calc(100vh - {{keyboardHeight}}rpx - 220rpx);">
    <view wx:for="{{messages}}" wx:key="messageId" id="msg-{{item.messageId}}"
          class="msg {{item.fromType === 'user' ? 'right' : 'left'}}">
      <view class="m-avatar" wx:if="{{item.fromType !== 'user'}}">
        {{item.fromName || '客服'}}
      </view>
      <view class="m-bubble">
        <view class="m-text" wx:if="{{item.type === 'text'}}">{{item.content}}</view>
        <image class="m-image" wx:elif="{{item.type === 'image'}}" src="{{item.content}}" mode="widthFix" />
        <view class="m-card" wx:elif="{{item.type === 'order' && item.payload}}">
          <view class="mc-title">订单 {{item.payload.orderNo}}</view>
          <view class="mc-text">实付 ¥{{item.payload.totalPrice}}</view>
        </view>
        <view class="m-card" wx:elif="{{item.type === 'goods' && item.payload}}">
          <image class="mc-img" src="{{item.payload.image}}" mode="aspectFill"/>
          <view class="mc-info">
            <view class="mc-title">{{item.payload.name}}</view>
            <view class="mc-text">¥{{item.payload.price}}</view>
          </view>
        </view>
        <view class="m-text" wx:elif="{{item.fromType === 'system'}}">{{item.content}}</view>
        <view class="m-time">{{item.timeText}}</view>
      </view>
      <view class="m-avatar me" wx:if="{{item.fromType === 'user'}}">
        <image src="{{userInfo.avatarUrl || '/images/default-avatar.png'}}" mode="aspectFill"/>
      </view>
    </view>
  </scroll-view>

  <view class="input-bar">
    <input class="input" placeholder="输入消息" value="{{inputText}}"
           bindinput="onInput" bindconfirm="onSend" hold-keyboard="{{false}}"
           confirm-type="send" adjust-position="{{false}}"/>
    <view class="send-btn" bindtap="onSend">发送</view>
  </view>
</view>
