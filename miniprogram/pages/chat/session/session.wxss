.page { padding-bottom: 0; }
.status-bar {
  background: #fff7e6; color: #ff9800; padding: 16rpx 30rpx;
  font-size: 26rpx; display: flex; align-items: center; gap: 10rpx;
  position: sticky; top: 0; z-index: 10;
}
.status-bar.connected { background: #e8f5e9; color: #4caf50; }
.status-bar.reconnecting { background: #ffebee; color: #f5222d; }
.status-bar.closed { background: #f5f5f5; color: #999; }
.status-bar.queue { background: #e3f2fd; color: #1976d2; }
.status-dot {
  width: 16rpx; height: 16rpx; border-radius: 50%; background: currentColor;
  flex-shrink: 0;
}
.status-bar.reconnecting .status-dot { animation: blink 1s infinite; }
@keyframes blink { 0%, 100% { opacity: 1; } 50% { opacity: 0.3; } }
.status-text { font-weight: 600; }
.status-sub { color: #999; font-size: 24rpx; margin-left: 12rpx; }

.messages { background: #f5f5f5; padding: 20rpx; }
.msg { display: flex; margin-bottom: 24rpx; align-items: flex-start; }
.msg.right { flex-direction: row-reverse; }
.m-avatar {
  width: 70rpx; height: 70rpx; border-radius: 50%;
  background: var(--primary); color: #fff;
  display: flex; align-items: center; justify-content: center;
  font-size: 22rpx; flex-shrink: 0; margin: 0 16rpx;
}
.m-avatar.me { background: #f0f0f0; padding: 0; overflow: hidden; }
.m-avatar.me image { width: 100%; height: 100%; }
.m-bubble {
  max-width: 70%; background: #fff; border-radius: 12rpx;
  padding: 16rpx 20rpx; position: relative;
}
.m-bubble.system { background: #fffbe6; max-width: 90%; text-align: center; }
.msg.right .m-bubble { background: #95d6f5; color: #333; }
.m-text { font-size: 28rpx; line-height: 1.5; word-break: break-all; }
.m-image { max-width: 400rpx; border-radius: 8rpx; }
.m-file { font-size: 28rpx; color: var(--primary); }
.m-time { font-size: 22rpx; color: #999; margin-top: 6rpx; }

.typing {
  display: flex; align-items: center; gap: 8rpx;
  font-size: 24rpx; color: #999; padding: 12rpx 24rpx;
  margin-bottom: 20rpx;
}
.typing .t-dot {
  width: 12rpx; height: 12rpx; border-radius: 50%; background: #ccc;
  animation: bounce 1.2s infinite;
}
.typing .t-dot:nth-child(2) { animation-delay: 0.2s; }
.typing .t-dot:nth-child(3) { animation-delay: 0.4s; }
@keyframes bounce {
  0%, 60%, 100% { transform: translateY(0); }
  30% { transform: translateY(-8rpx); }
}

.input-bar {
  position: fixed; left: 0; right: 0; bottom: 0;
  background: #fff; padding: 16rpx 20rpx;
  display: flex; align-items: center; gap: 12rpx;
  border-top: 1rpx solid #eee; z-index: 100;
}
.tool-btn {
  width: 70rpx; height: 70rpx; border-radius: 50%;
  background: #f5f5f5; display: flex; align-items: center; justify-content: center;
  font-size: 32rpx; flex-shrink: 0;
}
.input {
  flex: 1; background: #f5f5f5; border-radius: 999rpx;
  padding: 16rpx 24rpx; font-size: 28rpx;
}
.send-btn {
  background: var(--primary); color: #fff;
  padding: 16rpx 32rpx; border-radius: 999rpx; font-size: 28rpx;
  flex-shrink: 0;
}
.send-btn.disabled { background: #ccc; }

/* 评价弹层 */
.mask { z-index: 1000; }
.rate-panel {
  position: fixed; left: 30rpx; right: 30rpx; top: 30%;
  background: #fff; border-radius: 16rpx; padding: 40rpx 30rpx;
  z-index: 1001; transform: scale(0.9); opacity: 0;
  transition: all 0.2s;
}
.rate-panel.show { transform: scale(1); opacity: 1; }
.rate-title { text-align: center; font-size: 32rpx; font-weight: bold; margin-bottom: 30rpx; }
.rate-stars { text-align: center; margin-bottom: 30rpx; }
.star { font-size: 60rpx; color: #ddd; margin: 0 8rpx; }
.star.on { color: #ffa726; }
.rate-tags { text-align: center; margin-bottom: 20rpx; }
.rt {
  display: inline-block; padding: 8rpx 24rpx; margin: 6rpx;
  background: #f5f5f5; border-radius: 999rpx; font-size: 24rpx;
}
.rt.on { background: var(--primary-light); color: var(--primary); }
.rate-comment {
  width: 100%; height: 100rpx; background: #f9f9f9;
  border-radius: 8rpx; padding: 12rpx; box-sizing: border-box;
  font-size: 26rpx;
}
.rate-btns { display: flex; margin-top: 30rpx; }
.rate-btns .o-btn {
  flex: 1; margin: 0 8rpx; padding: 20rpx 0; text-align: center;
  border: 1rpx solid #ccc; border-radius: 999rpx; font-size: 28rpx;
}
.rate-btns .o-btn.primary { color: #fff; background: var(--primary); border-color: var(--primary); }
