.page { min-height: 100vh; padding-bottom: 120rpx; }
.empty { padding: 200rpx 0; text-align: center; color: #999; }
.empty view:first-child { font-size: 120rpx; }
.empty view:nth-child(2) { margin: 20rpx 0; }
.go-shop {
  display: inline-block; margin-top: 40rpx;
  background: var(--primary); color: #fff;
  padding: 16rpx 60rpx; border-radius: 999rpx;
  font-size: 28rpx;
}

.cart-list { background: #fff; }
.c-item {
  display: flex; align-items: center;
  padding: 20rpx; border-bottom: 1rpx solid #f5f5f5;
}
.checkbox {
  width: 40rpx; height: 40rpx; border-radius: 50%;
  border: 2rpx solid #ccc; flex-shrink: 0; margin-right: 20rpx;
  position: relative;
}
.checkbox.on { background: var(--primary); border-color: var(--primary); }
.checkbox.on::after {
  content: ''; position: absolute; left: 12rpx; top: 4rpx;
  width: 10rpx; height: 20rpx;
  border: solid #fff; border-width: 0 4rpx 4rpx 0; transform: rotate(45deg);
}
.c-img { width: 160rpx; height: 160rpx; border-radius: 12rpx; background: #f0f0f0; }
.c-info { flex: 1; margin-left: 20rpx; display: flex; flex-direction: column; min-width: 0; }
.c-name { font-size: 28rpx; font-weight: 500; line-height: 1.4; }
.c-spec { font-size: 22rpx; margin: 4rpx 0; }
.qty { display: flex; align-items: center; }
.qty-btn {
  width: 50rpx; height: 50rpx; background: #f5f5f5; text-align: center;
  line-height: 50rpx; border-radius: 8rpx;
}
.qty-n { width: 60rpx; text-align: center; font-size: 28rpx; }

.footer {
  position: fixed; left: 0; right: 0; bottom: 0; height: 100rpx;
  background: #fff; display: flex; align-items: center;
  padding: 0 20rpx; border-top: 1rpx solid #eee;
}
.total { flex: 1; margin-left: 20rpx; font-size: 26rpx; }
.total-price { font-size: 36rpx; }
.checkout {
  background: var(--primary); color: #fff;
  padding: 16rpx 40rpx; border-radius: 999rpx; font-size: 28rpx;
}
