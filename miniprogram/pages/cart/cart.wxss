/* 购物车 */
.head {
  display: flex; align-items: center; justify-content: space-between;
  padding: 30rpx 30rpx 20rpx;
}
.title { font-size: 44rpx; font-weight: 700; color: var(--text-primary); }
.edit { font-size: 26rpx; color: var(--primary); font-weight: 500; }

.shop-card {
  background: #fff;
  margin: 16rpx 24rpx;
  border-radius: var(--radius);
  overflow: hidden;
  box-shadow: var(--shadow-sm);
}
.shop-head { padding: 24rpx 24rpx 12rpx; }
.s-name { font-size: 28rpx; font-weight: 600; color: var(--text-primary); }

.g-item {
  display: flex;
  align-items: center;
  padding: 20rpx 24rpx;
  border-top: 1rpx solid var(--border-light);
}
.select { padding: 8rpx; }
.check {
  display: inline-block;
  width: 36rpx; height: 36rpx;
  border: 2rpx solid #ddd;
  border-radius: 50%;
  text-align: center; line-height: 32rpx;
  color: transparent;
  font-size: 24rpx;
  background: #fff;
}
.check.on {
  background: var(--primary);
  border-color: var(--primary);
  color: #fff;
}
.g-img {
  width: 180rpx; height: 180rpx;
  border-radius: var(--radius-sm);
  background: #f5f5f5;
  margin: 0 20rpx;
}
.g-info { flex: 1; min-width: 0; display: flex; flex-direction: column; }
.g-name { font-size: 26rpx; color: var(--text-primary); line-height: 1.4; }
.g-spec { font-size: 22rpx; color: var(--text-tertiary); margin-top: 6rpx; }
.g-foot {
  display: flex; justify-content: space-between; align-items: center;
  margin-top: 16rpx;
}
.g-price { display: flex; align-items: baseline; color: var(--danger); }
.gp-cur { font-size: 22rpx; }
.gp-num { font-size: 30rpx; font-weight: 700; }

.counter {
  display: flex; align-items: center;
  background: var(--bg-secondary);
  border-radius: var(--radius-full);
  padding: 4rpx;
}
.c-btn {
  width: 48rpx; height: 48rpx;
  text-align: center; line-height: 44rpx;
  font-size: 32rpx; color: var(--text-primary);
  background: #fff;
  border-radius: 50%;
}
.c-num {
  min-width: 64rpx; text-align: center;
  font-size: 26rpx; color: var(--text-primary);
  font-weight: 500;
  padding: 0 8rpx;
}

/* 推荐 */
.recommend { margin: 40rpx 0; }
.r-title {
  text-align: center;
  color: var(--text-tertiary);
  font-size: 24rpx;
  margin-bottom: 20rpx;
}
.r-scroll { white-space: nowrap; padding: 4rpx 24rpx 20rpx; }
.r-item {
  display: inline-block;
  width: 200rpx;
  background: #fff;
  border-radius: var(--radius);
  margin-right: 16rpx;
  overflow: hidden;
  box-shadow: var(--shadow-sm);
  vertical-align: top;
}
.r-img { width: 200rpx; height: 200rpx; background: #f5f5f5; }
.r-name { font-size: 24rpx; padding: 12rpx; color: var(--text-primary); }
.r-price { padding: 0 12rpx 12rpx; color: var(--danger); font-size: 28rpx; font-weight: 600; }

/* 空 */
.empty { padding-top: 200rpx; text-align: center; }
.empty-emoji { font-size: 200rpx; display: block; opacity: 0.6; }
.empty-title { font-size: 30rpx; color: var(--text-primary); font-weight: 600; margin-top: 24rpx; }
.empty-sub { font-size: 24rpx; color: var(--text-tertiary); margin-top: 12rpx; }
.empty-btn {
  display: inline-block;
  margin-top: 40rpx;
  padding: 20rpx 60rpx;
  background: var(--grad-primary);
  color: #fff;
  border-radius: var(--radius-full);
  font-size: 28rpx;
  font-weight: 500;
  box-shadow: var(--shadow-primary);
}

/* 结算栏 */
.checkout {
  position: fixed; left: 0; right: 0; bottom: 0;
  background: #fff;
  padding: 16rpx 24rpx;
  padding-bottom: calc(16rpx + env(safe-area-inset-bottom));
  display: flex; align-items: center;
  box-shadow: 0 -4rpx 16rpx rgba(0,0,0,0.06);
  z-index: 100;
}
.c-left { display: flex; align-items: center; padding: 0 12rpx; }
.all-text { font-size: 26rpx; color: var(--text-primary); margin-left: 8rpx; }
.c-mid { flex: 1; padding: 0 24rpx; }
.total-label { font-size: 24rpx; color: var(--text-tertiary); margin-right: 12rpx; }
.total-price { color: var(--danger); display: inline-flex; align-items: baseline; }
.tp-cur { font-size: 24rpx; }
.tp-num { font-size: 38rpx; font-weight: 700; }
.c-edit-text { font-size: 26rpx; color: var(--text-secondary); }
.c-btn {
  padding: 24rpx 48rpx;
  border-radius: var(--radius-full);
  font-size: 30rpx;
  font-weight: 600;
  color: #fff;
  text-align: center;
  min-width: 200rpx;
}
.c-btn.on { background: var(--grad-primary); box-shadow: var(--shadow-primary); }
.c-btn.off { background: #ccc; }
.c-num { font-size: 24rpx; opacity: 0.9; margin-left: 4rpx; }
