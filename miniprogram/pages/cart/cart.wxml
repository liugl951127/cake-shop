<view class="page">
  <view wx:if="{{list.length === 0}}" class="empty">
    <view>🛒</view>
    <view>购物车空空如也</view>
    <view class="go-shop" bindtap="goShopping">去逛逛</view>
  </view>

  <view wx:else>
    <view class="cart-list">
      <view class="c-item" wx:for="{{list}}" wx:key="_id">
        <view class="checkbox {{item.selected ? 'on' : ''}}" bindtap="toggleSelect" data-id="{{item._id}}"></view>
        <image src="{{item.image}}" mode="aspectFill" class="c-img"></image>
        <view class="c-info">
          <view class="c-name ellipsis-2">{{item.name}}</view>
          <view class="c-spec text-sub ellipsis" wx:if="{{item.spec}}">规格: {{item.spec}}</view>
          <view class="flex-between" style="margin-top:auto">
            <text class="price">{{item.price}}</text>
            <view class="qty">
              <text class="qty-btn" bindtap="changeCount" data-id="{{item._id}}" data-delta="-1">-</text>
              <text class="qty-n">{{item.count}}</text>
              <text class="qty-btn" bindtap="changeCount" data-id="{{item._id}}" data-delta="1">+</text>
            </view>
          </view>
        </view>
      </view>
    </view>

    <view class="footer">
      <view class="checkbox {{allSelected ? 'on' : ''}}" bindtap="toggleAll"></view>
      <text style="margin-left:10rpx">全选</text>
      <view class="total">
        合计: <text class="price total-price">{{totalPrice}}</text>
      </view>
      <view class="checkout" bindtap="checkout">结算({{selectedCount}})</view>
    </view>
  </view>
</view>
