.page { padding: 20rpx; }
.goods-list { display: flex; flex-wrap: wrap; }
.g-item {
  width: 345rpx; background: #fff; border-radius: 16rpx;
  margin: 10rpx; overflow: hidden;
  box-shadow: 0 4rpx 12rpx rgba(0,0,0,0.04);
  display: flex; flex-direction: column;
}
.g-img { width: 100%; height: 345rpx; background: #f0f0f0; }
.g-info { padding: 16rpx; flex: 1; display: flex; flex-direction: column; }
.g-name { font-size: 26rpx; line-height: 1.4; height: 72rpx; }
.unfavor { font-size: 24rpx; color: #999; border: 1rpx solid #ccc; padding: 4rpx 16rpx; border-radius: 999rpx; }
.empty { padding: 200rpx 0; text-align: center; color: #999; }
.empty view:first-child { font-size: 120rpx; }
