.page { padding-bottom: 120rpx; }

.addr {
  background: #fff; padding: 30rpx;
  display: flex; align-items: center; margin-bottom: 20rpx;
}
.addr-info { flex: 1; }
.a-name { font-size: 32rpx; font-weight: 600; }
.a-phone { margin-left: 20rpx; font-size: 28rpx; color: #666; }
.a-tag {
  margin-left: 16rpx; font-size: 22rpx;
  background: var(--primary-light); color: var(--primary);
  padding: 2rpx 12rpx; border-radius: 6rpx;
}
.a-region { margin-top: 10rpx; font-size: 26rpx; color: #666; }
.addr-empty { flex: 1; color: #999; }
.arrow { color: #ccc; font-size: 36rpx; }

.card { background: #fff; margin: 20rpx; border-radius: 16rpx; padding: 24rpx; }
.g-item { display: flex; padding: 16rpx 0; border-bottom: 1rpx solid #f5f5f5; }
.g-item:last-child { border-bottom: none; }
.g-img { width: 140rpx; height: 140rpx; border-radius: 12rpx; background: #f0f0f0; }
.g-info { flex: 1; margin-left: 20rpx; min-width: 0; display: flex; flex-direction: column; justify-content: space-between; }
.g-name { font-size: 28rpx; }
.g-spec { font-size: 22rpx; }

.row { display: flex; align-items: center; padding: 16rpx 0; }
.row .label { width: 160rpx; color: #666; font-size: 28rpx; }
.row text:nth-child(2) { flex: 1; text-align: right; font-size: 28rpx; }
.remark { flex: 1; text-align: right; font-size: 28rpx; }
.picker-val { font-size: 28rpx; text-align: right; }

.footer {
  position: fixed; left: 0; right: 0; bottom: 0; height: 100rpx;
  background: #fff; display: flex; align-items: center;
  padding: 0 20rpx; border-top: 1rpx solid #eee;
}
.total { flex: 1; font-size: 28rpx; }
.submit {
  background: var(--primary); color: #fff;
  padding: 16rpx 60rpx; border-radius: 999rpx; font-size: 30rpx;
}
