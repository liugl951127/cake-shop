.page { padding-bottom: 40rpx; }
.tabs {
  display: flex; background: #fff; border-bottom: 1rpx solid #f0f0f0;
  position: sticky; top: 0; z-index: 10;
}
.tab {
  flex: 1; text-align: center; padding: 24rpx 0; font-size: 28rpx;
  color: #666; position: relative;
}
.tab.active { color: var(--primary); font-weight: bold; }
.tab.active::after {
  content: ''; position: absolute; left: 50%; bottom: 0;
  transform: translateX(-50%);
  width: 40rpx; height: 4rpx; background: var(--primary);
  border-radius: 4rpx;
}

.o-list { padding: 20rpx; }
.o-item {
  background: #fff; border-radius: 16rpx; padding: 20rpx;
  margin-bottom: 20rpx;
}
.o-head { font-size: 24rpx; }
.o-goods { display: flex; padding: 20rpx 0; }
.og-img { width: 100rpx; height: 100rpx; border-radius: 8rpx; margin-right: 16rpx; background: #f0f0f0; }
.og-more {
  width: 100rpx; height: 100rpx; border-radius: 8rpx;
  background: #f5f5f5; text-align: center; line-height: 100rpx;
}
.o-bottom { padding-top: 16rpx; border-top: 1rpx solid #f0f0f0; }
.o-actions { display: flex; }
.o-btn {
  padding: 10rpx 24rpx; border: 1rpx solid #ccc; border-radius: 999rpx;
  font-size: 24rpx; margin-left: 16rpx;
}
.o-btn.primary { color: var(--primary); border-color: var(--primary); }

.empty { padding: 200rpx 0; text-align: center; color: #999; }
.empty view:first-child { font-size: 120rpx; }
.empty view:nth-child(2) { margin-top: 20rpx; }
