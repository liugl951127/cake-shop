<view class="page">
  <view class="tabs">
    <view class="tab {{status === item.value ? 'active' : ''}}"
          wx:for="{{tabs}}" wx:key="value"
          bindtap="switchTab" data-v="{{item.value}}">
      {{item.label}}
    </view>
  </view>

  <view wx:if="{{list.length === 0 && !loading}}" class="empty">
    <view>📭</view>
    <view>暂无订单</view>
  </view>

  <view class="o-list">
    <view class="o-item" wx:for="{{list}}" wx:key="_id" bindtap="goDetail" data-id="{{item._id}}">
      <view class="o-head flex-between">
        <text class="text-sub">订单号: {{item.orderNo}}</text>
        <text style="color:{{statusMap[item.status].color}}">{{statusMap[item.status].text}}</text>
      </view>
      <view class="o-goods">
        <view class="og" wx:for="{{item.items}}" wx:key="name" wx:for-item="g">
          <image src="{{g.image}}" class="og-img" mode="aspectFill"></image>
        </view>
        <view class="og-more text-sub" wx:if="{{item.items.length > 3}}">+{{item.items.length - 3}}</view>
      </view>
      <view class="o-bottom flex-between">
        <text class="text-sub">共 {{item.totalCount}} 件 实付: <text class="price" style="font-size:30rpx">{{item.totalPrice}}</text></text>
        <view class="o-actions">
          <view class="o-btn" wx:if="{{item.status === 0}}" catchtap="cancelOrder" data-id="{{item._id}}">取消</view>
          <view class="o-btn" wx:if="{{item.status === 0}}" catchtap="payOrder" data-id="{{item._id}}">付款</view>
          <view class="o-btn primary" wx:if="{{item.status === 3}}" catchtap="confirmOrder" data-id="{{item._id}}">确认收货</view>
          <view class="o-btn primary" wx:if="{{item.status === 4}}" catchtap="deleteOrder" data-id="{{item._id}}">删除</view>
        </view>
      </view>
    </view>
  </view>
</view>
