.page { padding-bottom: 60rpx; }
.status-bar {
  color: #fff; padding: 40rpx 30rpx;
}
.status-text { font-size: 36rpx; font-weight: bold; margin-bottom: 10rpx; }

.card { background: #fff; margin: 20rpx; border-radius: 16rpx; padding: 24rpx; }
.card-title { font-size: 28rpx; font-weight: 600; margin-bottom: 20rpx; }
.row { display: flex; padding: 12rpx 0; font-size: 28rpx; }
.row .label { width: 180rpx; color: #666; }
.row text:nth-child(2) { flex: 1; text-align: right; }
.icon { font-size: 36rpx; margin-right: 20rpx; }
.addr { flex: 1; }

.g-item { display: flex; padding: 16rpx 0; border-bottom: 1rpx solid #f5f5f5; }
.g-item:last-child { border-bottom: none; }
.g-img { width: 140rpx; height: 140rpx; border-radius: 12rpx; background: #f0f0f0; }
.g-info { flex: 1; margin-left: 20rpx; min-width: 0; display: flex; flex-direction: column; justify-content: space-between; }
.g-name { font-size: 28rpx; }
.g-spec { font-size: 22rpx; }
.copyable { color: var(--primary); }
