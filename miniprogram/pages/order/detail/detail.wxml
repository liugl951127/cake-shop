<view class="page" wx:if="{{order}}">
  <view class="status-bar" style="background:{{statusMap[order.status].color}}">
    <view class="status-text">{{statusMap[order.status].text}}</view>
    <view class="text-sub" style="color:rgba(255,255,255,0.9)">下单时间: {{order.createTime}}</view>
  </view>

  <view class="card">
    <view class="row">
      <text class="icon">📍</text>
      <view class="addr">
        <view>{{order.address.name}} {{order.address.phone}}</view>
        <view class="text-sub">{{order.address.region}} {{order.address.detail}}</view>
      </view>
    </view>
  </view>

  <view class="card">
    <view class="card-title">商品列表</view>
    <view class="g-item" wx:for="{{order.items}}" wx:key="name">
      <image src="{{item.image}}" class="g-img" mode="aspectFill"></image>
      <view class="g-info">
        <view class="g-name">{{item.name}}</view>
        <view class="g-spec text-sub" wx:if="{{item.spec}}">{{item.spec}}</view>
        <view class="flex-between">
          <text class="price">{{item.price}}</text>
          <text class="text-sub">x{{item.count}}</text>
        </view>
      </view>
    </view>
  </view>

  <view class="card">
    <view class="row"><text class="label">订单号</text><text class="copyable" bindtap="copyOrderNo">{{order.orderNo}}</text></view>
    <view class="row"><text class="label">下单时间</text><text>{{order.createTime}}</text></view>
    <view class="row"><text class="label">送达时间</text><text>{{order.timeText || '尽快送达'}}</text></view>
    <view class="row" wx:if="{{order.remark}}"><text class="label">备注</text><text>{{order.remark}}</text></view>
  </view>

  <view class="card">
    <view class="row"><text class="label">商品金额</text><text>¥{{order.goodsPrice}}</text></view>
    <view class="row"><text class="label">配送费</text><text>¥{{order.freight}}</text></view>
    <view class="row" style="font-weight:bold"><text class="label">实付</text><text style="color:var(--price)">¥{{order.totalPrice}}</text></view>
  </view>
</view>
