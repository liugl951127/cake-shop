.page { padding-bottom: 40rpx; }
.location-bar {
  display: flex; align-items: center; padding: 24rpx 30rpx;
  background: #fff; border-bottom: 1rpx solid #f0f0f0;
}
.loc-icon { font-size: 32rpx; margin-right: 12rpx; }
.loc-text { font-size: 28rpx; color: #333; }

.s-list { padding: 20rpx; }
.s-item {
  background: #fff; border-radius: 16rpx; padding: 24rpx;
  margin-bottom: 20rpx; box-shadow: 0 4rpx 12rpx rgba(0,0,0,0.05);
}
.s-name { font-size: 30rpx; font-weight: 600; }
.s-address { font-size: 26rpx; color: #666; margin-top: 10rpx; }
.s-meta { display: flex; gap: 30rpx; margin-top: 16rpx; font-size: 24rpx; color: #999; }
.empty { text-align: center; color: #999; padding: 200rpx 0; }
