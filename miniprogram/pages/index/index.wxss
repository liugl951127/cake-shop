/* 首页 - 樱花系清新设计 */

.hero {
  background: var(--grad-primary);
  padding: 30rpx 30rpx 100rpx;
  border-radius: 0 0 40rpx 40rpx;
}
.hero-row { display: flex; align-items: center; }
.brand { display: flex; align-items: center; margin-right: 20rpx; }
.brand .logo {
  font-size: 50rpx; margin-right: 12rpx;
  filter: drop-shadow(0 4rpx 8rpx rgba(0,0,0,0.1));
}
.b-info { line-height: 1.3; }
.b-name { color: #fff; font-size: 32rpx; font-weight: 700; }
.b-sub { color: rgba(255,255,255,0.85); font-size: 22rpx; margin-top: 2rpx; }

.search-bar {
  flex: 1;
  background: rgba(255,255,255,0.95);
  border-radius: var(--radius-full);
  padding: 16rpx 28rpx;
  display: flex; align-items: center;
  box-shadow: 0 4rpx 12rpx rgba(0,0,0,0.06);
}
.s-icon { font-size: 28rpx; color: var(--text-tertiary); margin-right: 12rpx; }
.s-placeholder { color: var(--text-tertiary); font-size: 26rpx; }

/* 轮播 */
.banner-wrap { margin: -60rpx 24rpx 0; position: relative; }
.banner { height: 280rpx; border-radius: var(--radius-md); overflow: hidden; box-shadow: var(--shadow-md); }
.banner-card { position: relative; width: 100%; height: 100%; }
.banner-img { width: 100%; height: 100%; }
.banner-mask {
  position: absolute; left: 0; right: 0; bottom: 0;
  padding: 24rpx 32rpx;
  background: linear-gradient(to top, rgba(0,0,0,0.6), transparent);
}
.banner-title { color: #fff; font-size: 32rpx; font-weight: 700; display: block; }
.banner-sub { color: rgba(255,255,255,0.9); font-size: 24rpx; display: block; margin-top: 4rpx; }

/* 金刚区 */
.icons {
  background: #fff;
  margin: 24rpx;
  padding: 32rpx 0;
  border-radius: var(--radius-md);
  display: grid;
  grid-template-columns: repeat(5, 1fr);
  box-shadow: var(--shadow-sm);
}
.icon-item {
  display: flex; flex-direction: column; align-items: center;
}
.icon-circle {
  width: 88rpx; height: 88rpx; border-radius: 50%;
  display: flex; align-items: center; justify-content: center;
  font-size: 44rpx;
  box-shadow: 0 4rpx 12rpx rgba(0,0,0,0.06);
  transition: transform 0.2s;
}
.icon-item:active .icon-circle { transform: scale(0.92); }
.icon-text { font-size: 22rpx; color: var(--text-secondary); margin-top: 12rpx; }

/* 公告 */
.notice {
  margin: 0 24rpx 24rpx;
  padding: 18rpx 24rpx;
  background: var(--warning-light);
  border-radius: var(--radius);
  display: flex; align-items: center;
}
.notice-icon { font-size: 28rpx; margin-right: 12rpx; }
.notice-text { color: #ef6c00; font-size: 24rpx; flex: 1; font-weight: 500; }

/* 功能宫格 */
.feature-bar {
  margin: 0 24rpx 24rpx;
  background: #fff;
  border-radius: var(--radius-md);
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  padding: 24rpx 0;
  box-shadow: var(--shadow-sm);
}
.f-item {
  display: flex; flex-direction: column; align-items: center;
  transition: transform 0.2s;
}
.f-item:active { transform: scale(0.95); }
.f-emoji { font-size: 44rpx; }
.f-name { font-size: 24rpx; color: var(--text-secondary); margin-top: 8rpx; }

/* 通用 section */
.section { margin: 0 24rpx 32rpx; }
.section-head {
  display: flex; justify-content: space-between; align-items: flex-end;
  margin-bottom: 20rpx; padding: 0 4rpx;
}
.h-left { display: flex; align-items: baseline; }
.h-title { font-size: 36rpx; font-weight: 700; color: var(--text-primary); }
.h-sub { font-size: 22rpx; color: var(--text-tertiary); margin-left: 12rpx; }
.h-time {
  background: linear-gradient(135deg, #ff5722, #ff9800);
  color: #fff;
  font-size: 20rpx;
  padding: 4rpx 12rpx;
  border-radius: var(--radius-sm);
  margin-left: 12rpx;
  font-weight: 600;
}
.h-more { font-size: 24rpx; color: var(--text-tertiary); }

/* 秒杀 */
.seckill-scroll { white-space: nowrap; padding: 4rpx 0 20rpx; }
.seckill-item {
  display: inline-block;
  width: 240rpx;
  background: #fff;
  border-radius: var(--radius);
  margin-right: 16rpx;
  overflow: hidden;
  box-shadow: var(--shadow-sm);
  vertical-align: top;
}
.seckill-img { width: 240rpx; height: 240rpx; background: #f0f0f0; }
.seckill-info { padding: 12rpx 16rpx; }
.seckill-name { font-size: 24rpx; color: var(--text-primary); }
.seckill-price-row { margin-top: 6rpx; }
.seckill-price { color: var(--danger); font-size: 32rpx; font-weight: 700; }
.seckill-origin { color: var(--text-tertiary); font-size: 22rpx; text-decoration: line-through; margin-left: 8rpx; }
.seckill-progress { margin-top: 8rpx; }
.sp-bar { height: 12rpx; background: #fff0f3; border-radius: 6rpx; overflow: hidden; }
.sp-fill { height: 100%; background: linear-gradient(90deg, #ff5722, #ff9a6e); }
.sp-text { font-size: 20rpx; color: var(--text-tertiary); margin-top: 4rpx; display: block; }

/* 商品网格(2 列) */
.goods-grid {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 20rpx;
}
.g-card {
  background: #fff;
  border-radius: var(--radius);
  overflow: hidden;
  box-shadow: var(--shadow-sm);
  transition: transform 0.2s;
}
.g-card:active { transform: scale(0.98); }
.g-img-wrap {
  position: relative;
  width: 100%;
  aspect-ratio: 1;
  background: #f5f5f5;
}
.g-img { width: 100%; height: 100%; }
.g-tag {
  position: absolute; left: 12rpx; top: 12rpx;
  background: linear-gradient(135deg, #ff5722, #ff9800);
  color: #fff;
  font-size: 20rpx;
  padding: 4rpx 12rpx;
  border-radius: var(--radius-sm);
  font-weight: 600;
}
.g-fav {
  position: absolute; right: 12rpx; top: 12rpx;
  width: 48rpx; height: 48rpx;
  background: rgba(255,255,255,0.9);
  border-radius: 50%;
  text-align: center; line-height: 44rpx;
  font-size: 28rpx;
  color: #ccc;
}
.g-fav .faved { color: var(--danger); }

.g-body { padding: 16rpx; }
.g-name { font-size: 26rpx; color: var(--text-primary); line-height: 1.4; height: 72rpx; }
.g-meta { font-size: 20rpx; color: var(--text-tertiary); margin-top: 8rpx; }
.g-foot {
  display: flex; align-items: center; justify-content: space-between;
  margin-top: 12rpx;
}
.g-price { display: flex; align-items: baseline; color: var(--danger); }
.gp-cur { font-size: 22rpx; }
.gp-num { font-size: 32rpx; font-weight: 700; }
.g-cart {
  width: 52rpx; height: 52rpx;
  background: var(--grad-primary);
  color: #fff;
  border-radius: 50%;
  text-align: center; line-height: 48rpx;
  font-size: 36rpx;
  font-weight: 300;
  box-shadow: 0 4rpx 12rpx rgba(255,123,156,0.4);
}

.loading, .end {
  text-align: center;
  padding: 32rpx 0;
  color: var(--text-tertiary);
  font-size: 24rpx;
}
