.page { padding-bottom: 40rpx; }

.search-bar { padding: 20rpx 30rpx 0; }
.search-input {
  background: #fff;
  border-radius: 999rpx;
  padding: 16rpx 30rpx;
  font-size: 26rpx;
  color: #999;
  display: flex; align-items: center;
  box-shadow: 0 2rpx 8rpx rgba(0,0,0,0.04);
}
.search-input text:first-child { margin-right: 12rpx; }

.banner { padding: 20rpx 30rpx; }
.banner-img { width: 100%; height: 280rpx; border-radius: 16rpx; }

.icons {
  display: flex; padding: 20rpx 0;
  background: #fff; margin: 0 20rpx; border-radius: 16rpx;
}
.icon-item { flex: 1; text-align: center; }
.icon-circle {
  width: 80rpx; height: 80rpx; border-radius: 50%;
  margin: 0 auto 10rpx; display: flex;
  align-items: center; justify-content: center;
  font-size: 40rpx;
}
.icon-text { font-size: 24rpx; }

.notice {
  margin: 20rpx; background: #fff; padding: 20rpx; border-radius: 16rpx;
  display: flex; align-items: center; font-size: 26rpx;
}
.notice-icon { margin-right: 12rpx; }

.seckill {
  margin: 20rpx; background: linear-gradient(135deg,#fff5f8,#fff0f3);
  border-radius: 16rpx; padding: 24rpx;
}
.seckill-title { font-size: 30rpx; font-weight: bold; margin-bottom: 20rpx; }
.seckill-list { white-space: nowrap; }
.seckill-item {
  display: inline-block; width: 200rpx; margin-right: 20rpx;
  background: #fff; border-radius: 12rpx; padding: 12rpx;
}
.seckill-item image { width: 176rpx; height: 176rpx; border-radius: 8rpx; }
.seckill-name { font-size: 24rpx; margin: 8rpx 0; }
.seckill-price { font-size: 28rpx; }
.seckill-old { font-size: 20rpx; }

.section { margin-top: 20rpx; }
.section-title {
  text-align: center; padding: 20rpx 0; color: #999; font-size: 28rpx;
}
.goods-grid {
  display: flex; flex-wrap: wrap; padding: 0 20rpx;
}
.grid-item {
  width: 345rpx; background: #fff; border-radius: 16rpx;
  margin: 10rpx; overflow: hidden;
  box-shadow: 0 4rpx 12rpx rgba(0,0,0,0.04);
}
.grid-img { width: 100%; height: 345rpx; background: #f0f0f0; }
.grid-info { padding: 16rpx; }
.grid-name { font-size: 26rpx; line-height: 1.4; height: 72rpx; }
.grid-sales { font-size: 22rpx; }
.no-more { text-align: center; padding: 30rpx 0; }
