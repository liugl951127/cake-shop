/* pages/index/index.wxss - 浅色卡片 + indigo 渐变 + 大圆角 */
@import "/styles/theme.wxss";

.container {
  background: var(--c-bg-page);
  padding-bottom: env(safe-area-inset-bottom);
}

/* 顶部品牌区 - 渐变背景 */
.hero {
  background: var(--grad-primary);
  padding: 60rpx 32rpx 80rpx;
  border-bottom-left-radius: 40rpx;
  border-bottom-right-radius: 40rpx;
  color: #fff;
  position: relative;
  overflow: hidden;
}
.hero::before {
  content: '';
  position: absolute;
  width: 320rpx;
  height: 320rpx;
  border-radius: 50%;
  background: rgba(255, 255, 255, 0.1);
  top: -100rpx;
  right: -100rpx;
}
.hero::after {
  content: '';
  position: absolute;
  width: 200rpx;
  height: 200rpx;
  border-radius: 50%;
  background: rgba(255, 255, 255, 0.08);
  bottom: -80rpx;
  left: -50rpx;
}
.hero-row {
  display: flex;
  align-items: center;
  gap: 24rpx;
  position: relative;
  z-index: 1;
}
.brand {
  display: flex;
  align-items: center;
  gap: 16rpx;
  flex-shrink: 0;
}
.logo {
  font-size: 56rpx;
  filter: drop-shadow(0 4rpx 8rpx rgba(0, 0, 0, 0.15));
}
.b-info {
  display: flex;
  flex-direction: column;
}
.b-name {
  font-size: 36rpx;
  font-weight: 700;
  color: #fff;
  letter-spacing: 1rpx;
}
.b-sub {
  font-size: 22rpx;
  color: rgba(255, 255, 255, 0.85);
  margin-top: 2rpx;
}
.search-bar {
  flex: 1;
  height: 64rpx;
  background: rgba(255, 255, 255, 0.22);
  border-radius: var(--r-full);
  display: flex;
  align-items: center;
  padding: 0 24rpx;
  color: rgba(255, 255, 255, 0.9);
  backdrop-filter: blur(8rpx);
  border: 2rpx solid rgba(255, 255, 255, 0.18);
}
.search-bar:active { background: rgba(255, 255, 255, 0.3); }
.s-icon { font-size: 24rpx; margin-right: 8rpx; }
.s-placeholder { font-size: 24rpx; }

/* 轮播 */
.banner-wrap {
  margin: -48rpx 24rpx 0;
  position: relative;
  z-index: 2;
}
.banner {
  height: 280rpx;
}
.banner-card {
  width: 100%;
  height: 100%;
  border-radius: var(--r-lg);
  overflow: hidden;
  position: relative;
  box-shadow: var(--sh-2);
  display: flex;
  align-items: center;
  justify-content: center;
}
.banner-emoji {
  font-size: 140rpx;
  line-height: 1;
}
.banner-img {
  width: 100%;
  height: 100%;
}
.banner-mask {
  position: absolute;
  bottom: 0;
  left: 0;
  right: 0;
  padding: 24rpx 32rpx;
  background: linear-gradient(180deg, transparent, rgba(0, 0, 0, 0.6));
  color: #fff;
}
.banner-title {
  font-size: 32rpx;
  font-weight: 600;
  display: block;
}
.banner-sub {
  font-size: 22rpx;
  opacity: 0.85;
  margin-top: 4rpx;
  display: block;
}

/* 金刚区 - 浅色卡片包裹 */
.icons {
  background: var(--c-bg-card);
  margin: 24rpx 24rpx 0;
  border-radius: var(--r-lg);
  padding: 32rpx 16rpx;
  display: grid;
  grid-template-columns: repeat(5, 1fr);
  gap: 16rpx;
  box-shadow: var(--sh-1);
}
.icon-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 12rpx;
}
.icon-circle {
  width: 88rpx;
  height: 88rpx;
  border-radius: 24rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 44rpx;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.06);
  transition: transform 0.15s ease;
}
.icon-item:active .icon-circle {
  transform: scale(0.92);
}
.icon-text {
  font-size: 22rpx;
  color: var(--c-text-2);
}

/* 公告条 - 软渐变 */
.notice {
  margin: 24rpx 24rpx 0;
  background: var(--grad-primary-soft);
  border-radius: var(--r-md);
  padding: 16rpx 24rpx;
  display: flex;
  align-items: center;
  gap: 12rpx;
  border: 1rpx solid var(--c-indigo-100);
}
.notice-icon { font-size: 28rpx; }
.notice-text {
  font-size: 24rpx;
  color: var(--c-indigo-700);
  flex: 1;
}

/* 功能宫格 - 4 个圆角卡片 */
.feature-bar {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 16rpx;
  margin: 24rpx;
}
.f-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 12rpx;
  background: var(--c-bg-card);
  border-radius: var(--r-lg);
  padding: 24rpx 8rpx;
  box-shadow: var(--sh-1);
  transition: all 0.15s ease;
}
.f-item:active {
  transform: scale(0.97);
  box-shadow: var(--sh-2);
}
.f-emoji {
  font-size: 40rpx;
}
.f-name {
  font-size: 24rpx;
  color: var(--c-text-1);
  font-weight: 500;
}

/* 通用 section */
.section {
  margin: 32rpx 0 0;
}
.section-head {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 0 32rpx;
  margin-bottom: 20rpx;
}
.h-left {
  display: flex;
  flex-direction: column;
  gap: 4rpx;
}
.h-title {
  font-size: 34rpx;
  font-weight: 700;
  color: var(--c-text-1);
  display: flex;
  align-items: center;
  gap: 8rpx;
}
.h-sub {
  font-size: 22rpx;
  color: var(--c-text-3);
}
.h-tip {
  display: flex;
  align-items: center;
  gap: 8rpx;
  margin-top: 4rpx;
}
.h-time {
  font-size: 22rpx;
  color: var(--c-danger);
  font-weight: 600;
  background: #fee2e2;
  padding: 2rpx 12rpx;
  border-radius: var(--r-full);
}
.h-more {
  font-size: 24rpx;
  color: var(--c-text-3);
  display: flex;
  align-items: center;
}

/* 秒杀 - 横向卡片滚动 */
.seckill-scroll {
  white-space: nowrap;
  padding: 0 24rpx;
}
.seckill-item {
  display: inline-block;
  width: 240rpx;
  margin-right: 16rpx;
  background: var(--c-bg-card);
  border-radius: var(--r-md);
  overflow: hidden;
  box-shadow: var(--sh-1);
  vertical-align: top;
  white-space: normal;
}
.seckill-img {
  width: 100%;
  height: 200rpx;
  background: var(--c-indigo-50);
}
.seckill-info {
  padding: 12rpx 16rpx 16rpx;
}
.seckill-name {
  font-size: 24rpx;
  color: var(--c-text-1);
  font-weight: 500;
}
.seckill-price-row {
  display: flex;
  align-items: baseline;
  gap: 8rpx;
  margin: 6rpx 0 4rpx;
}
.seckill-price {
  color: var(--c-danger);
  font-size: 30rpx;
  font-weight: 700;
}
.seckill-origin {
  color: var(--c-text-3);
  font-size: 20rpx;
  text-decoration: line-through;
}
.seckill-progress {
  display: flex;
  align-items: center;
  gap: 8rpx;
}
.sp-bar {
  flex: 1;
  height: 8rpx;
  background: var(--c-indigo-50);
  border-radius: var(--r-full);
  overflow: hidden;
}
.sp-fill {
  height: 100%;
  background: linear-gradient(90deg, var(--c-indigo-400), var(--c-indigo-500));
  border-radius: var(--r-full);
}
.sp-text {
  font-size: 20rpx;
  color: var(--c-text-3);
}

/* 商品网格 2 列 */
.goods-grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 16rpx;
  padding: 0 24rpx;
}
.g-card {
  background: var(--c-bg-card);
  border-radius: var(--r-lg);
  overflow: hidden;
  box-shadow: var(--sh-1);
  transition: all 0.15s ease;
}
.g-card:active {
  transform: scale(0.98);
  box-shadow: var(--sh-2);
}
.g-img-wrap {
  position: relative;
  width: 100%;
  height: 320rpx;
  background: var(--c-indigo-50);
}
.g-img {
  width: 100%;
  height: 100%;
}
.g-tag {
  position: absolute;
  top: 16rpx;
  left: 16rpx;
  background: var(--grad-warm);
  color: #fff;
  font-size: 20rpx;
  padding: 4rpx 12rpx;
  border-radius: var(--r-full);
  font-weight: 500;
  box-shadow: 0 2rpx 8rpx rgba(245, 158, 11, 0.3);
}
.g-fav {
  position: absolute;
  top: 16rpx;
  right: 16rpx;
  width: 48rpx;
  height: 48rpx;
  border-radius: 50%;
  background: rgba(255, 255, 255, 0.9);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 28rpx;
  color: var(--c-text-3);
  box-shadow: var(--sh-1);
}
.g-fav .faved { color: var(--c-danger); }
.g-body {
  padding: 16rpx 20rpx 20rpx;
}
.g-name {
  font-size: 26rpx;
  color: var(--c-text-1);
  font-weight: 500;
  min-height: 72rpx;
  line-height: 1.4;
}
.g-meta {
  font-size: 20rpx;
  color: var(--c-text-3);
  margin: 6rpx 0 8rpx;
}
.g-foot {
  display: flex;
  align-items: center;
  justify-content: space-between;
}
.g-price {
  display: flex;
  align-items: baseline;
  color: var(--c-danger);
}
.gp-cur {
  font-size: 22rpx;
}
.gp-num {
  font-size: 32rpx;
  font-weight: 700;
  margin-left: 2rpx;
}
.g-cart {
  width: 56rpx;
  height: 56rpx;
  border-radius: 50%;
  background: var(--grad-primary);
  color: #fff;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 36rpx;
  font-weight: 300;
  box-shadow: 0 4rpx 12rpx rgba(99, 102, 241, 0.32);
  transition: transform 0.15s ease;
}
.g-cart:active { transform: scale(0.9); }

.loading,
.end {
  text-align: center;
  color: var(--c-text-3);
  font-size: 24rpx;
  padding: 32rpx 0;
}
.font-num { font-family: -apple-system, "DIN Alternate", monospace; }
