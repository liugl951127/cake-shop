/* pages/index/index.wxss - 浅色卡片 + indigo 渐变 + 大圆角 */
@import "/styles/theme.wxss";

.container {
  background: var(--c-bg-page);
  padding-bottom: env(safe-area-inset-bottom);
}

/* 顶部品牌区 - 渐变背景 */
.hero {
  background: var(--grad-primary);
  padding: 60rpx 32rpx 80rpx;
  border-bottom-left-radius: 40rpx;
  border-bottom-right-radius: 40rpx;
  color: #fff;
  position: relative;
  overflow: hidden;
}
.hero::before {
  content: '';
  position: absolute;
  width: 320rpx;
  height: 320rpx;
  border-radius: 50%;
  background: rgba(255, 255, 255, 0.1);
  top: -100rpx;
  right: -100rpx;
}
.hero::after {
  content: '';
  position: absolute;
  width: 200rpx;
  height: 200rpx;
  border-radius: 50%;
  background: rgba(255, 255, 255, 0.08);
  bottom: -80rpx;
  left: -50rpx;
}
.hero-row {
  display: flex;
  align-items: center;
  gap: 24rpx;
  position: relative;
  z-index: 1;
}
.brand {
  display: flex;
  align-items: center;
  gap: 16rpx;
  flex-shrink: 0;
}
.logo {
  font-size: 56rpx;
  filter: drop-shadow(0 4rpx 8rpx rgba(0, 0, 0, 0.15));
}
.b-info {
  display: flex;
  flex-direction: column;
}
.b-name {
  font-size: 36rpx;
  font-weight: 700;
  color: #fff;
  letter-spacing: 1rpx;
}
.b-sub {
  font-size: 22rpx;
  color: rgba(255, 255, 255, 0.85);
  margin-top: 2rpx;
}
.search-bar {
  flex: 1;
  height: 64rpx;
  background: rgba(255, 255, 255, 0.22);
  border-radius: var(--r-full);
  display: flex;
  align-items: center;
  padding: 0 24rpx;
  color: rgba(255, 255, 255, 0.9);
  backdrop-filter: blur(8rpx);
  border: 2rpx solid rgba(255, 255, 255, 0.18);
}
.search-bar:active { background: rgba(255, 255, 255, 0.3); }
.s-icon { font-size: 24rpx; margin-right: 8rpx; }
.s-placeholder { font-size: 24rpx; }

/* 轮播 */
.banner-wrap {
  margin: -48rpx 24rpx 0;
  position: relative;
  z-index: 2;
}
.banner {
  height: 280rpx;
}
.banner-card {
  width: 100%;
  height: 100%;
  border-radius: var(--r-lg);
  overflow: hidden;
  position: relative;
  box-shadow: var(--sh-2);
  display: flex;
  align-items: center;
  justify-content: center;
}
.banner-emoji {
  font-size: 140rpx;
  line-height: 1;
}
.banner-img {
  width: 100%;
  height: 100%;
}
.banner-mask {
  position: absolute;
  bottom: 0;
  left: 0;
  right: 0;
  padding: 24rpx 32rpx;
  background: linear-gradient(180deg, transparent, rgba(0, 0, 0, 0.6));
  color: #fff;
}
.banner-title {
  font-size: 32rpx;
  font-weight: 600;
  display: block;
}
.banner-sub {
  font-size: 22rpx;
  opacity: 0.85;
  margin-top: 4rpx;
  display: block;
}

/* 金刚区 - 浅色卡片包裹 */
.icons {
  background: var(--c-bg-card);
  margin: 24rpx 24rpx 0;
  border-radius: var(--r-lg);
  padding: 32rpx 16rpx;
  display: grid;
  grid-template-columns: repeat(5, 1fr);
  gap: 16rpx;
  box-shadow: var(--sh-1);
}
.icon-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 12rpx;
}
.icon-circle {
  width: 88rpx;
  height: 88rpx;
  border-radius: 24rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 44rpx;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.06);
  transition: transform 0.15s ease;
}
.icon-item:active .icon-circle {
  transform: scale(0.92);
}
.icon-text {
  font-size: 22rpx;
  color: var(--c-text-2);
}

/* 公告条 - 软渐变 */
.notice {
  margin: 24rpx 24rpx 0;
  background: var(--grad-primary-soft);
  border-radius: var(--r-md);
  padding: 16rpx 24rpx;
  display: flex;
  align-items: center;
  gap: 12rpx;
  border: 1rpx solid var(--c-indigo-100);
}
.notice-icon { font-size: 28rpx; }
.notice-text {
  font-size: 24rpx;
  color: var(--c-indigo-700);
  flex: 1;
}

/* 功能宫格 - 4 个圆角卡片 */
.feature-bar {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 16rpx;
  margin: 24rpx;
}
.f-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 12rpx;
  background: var(--c-bg-card);
  border-radius: var(--r-lg);
  padding: 24rpx 8rpx;
  box-shadow: var(--sh-1);
  transition: all 0.15s ease;
}
.f-item:active {
  transform: scale(0.97);
  box-shadow: var(--sh-2);
}
.f-emoji {
  font-size: 40rpx;
}
.f-name {
  font-size: 24rpx;
  color: var(--c-text-1);
  font-weight: 500;
}

/* 通用 section */
.section {
  margin: 32rpx 0 0;
}
.section-head {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 0 32rpx;
  margin-bottom: 20rpx;
}
.h-left {
  display: flex;
  flex-direction: column;
  gap: 4rpx;
}
.h-title {
  font-size: 34rpx;
  font-weight: 700;
  color: var(--c-text-1);
  display: flex;
  align-items: center;
  gap: 8rpx;
}
.h-sub {
  font-size: 22rpx;
  color: var(--c-text-3);
}
.h-tip {
  display: flex;
  align-items: center;
  gap: 8rpx;
  margin-top: 4rpx;
}
.h-time {
  font-size: 22rpx;
  color: var(--c-danger);
  font-weight: 600;
  background: #fee2e2;
  padding: 2rpx 12rpx;
  border-radius: var(--r-full);
}
.h-more {
  font-size: 24rpx;
  color: var(--c-text-3);
  display: flex;
  align-items: center;
}

/* 秒杀 - 横向卡片滚动 */
.seckill-scroll {
  white-space: nowrap;
  padding: 0 24rpx;
}
.seckill-item {
  display: inline-block;
  width: 240rpx;
  margin-right: 16rpx;
  background: var(--c-bg-card);
  border-radius: var(--r-md);
  overflow: hidden;
  box-shadow: var(--sh-1);
  vertical-align: top;
  white-space: normal;
}
.seckill-img {
  width: 100%;
  height: 200rpx;
  background: var(--c-indigo-50);
}
.seckill-info {
  padding: 12rpx 16rpx 16rpx;
}
.seckill-name {
  font-size: 24rpx;
  color: var(--c-text-1);
  font-weight: 500;
}
.seckill-price-row {
  display: flex;
  align-items: baseline;
  gap: 8rpx;
  margin: 6rpx 0 4rpx;
}
.seckill-price {
  color: var(--c-danger);
  font-size: 30rpx;
  font-weight: 700;
}
.seckill-origin {
  color: var(--c-text-3);
  font-size: 20rpx;
  text-decoration: line-through;
}
.seckill-progress {
  display: flex;
  align-items: center;
  gap: 8rpx;
}
.sp-bar {
  flex: 1;
  height: 8rpx;
  background: var(--c-indigo-50);
  border-radius: var(--r-full);
  overflow: hidden;
}
.sp-fill {
  height: 100%;
  background: linear-gradient(90deg, var(--c-indigo-400), var(--c-indigo-500));
  border-radius: var(--r-full);
}
.sp-text {
  font-size: 20rpx;
  color: var(--c-text-3);
}

/* 商品网格 2 列 */
.goods-grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 16rpx;
  padding: 0 24rpx;
}
.g-card {
  background: var(--c-bg-card);
  border-radius: var(--r-lg);
  overflow: hidden;
  box-shadow: var(--sh-1);
  transition: all 0.15s ease;
}
.g-card:active {
  transform: scale(0.98);
  box-shadow: var(--sh-2);
}
.g-img-wrap {
  position: relative;
  width: 100%;
  height: 320rpx;
  background: var(--c-indigo-50);
}
.g-img {
  width: 100%;
  height: 100%;
}
.g-tag {
  position: absolute;
  top: 16rpx;
  left: 16rpx;
  background: var(--grad-warm);
  color: #fff;
  font-size: 20rpx;
  padding: 4rpx 12rpx;
  border-radius: var(--r-full);
  font-weight: 500;
  box-shadow: 0 2rpx 8rpx rgba(245, 158, 11, 0.3);
}
.g-fav {
  position: absolute;
  top: 16rpx;
  right: 16rpx;
  width: 48rpx;
  height: 48rpx;
  border-radius: 50%;
  background: rgba(255, 255, 255, 0.9);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 28rpx;
  color: var(--c-text-3);
  box-shadow: var(--sh-1);
}
.g-fav .faved { color: var(--c-danger); }
.g-body {
  padding: 16rpx 20rpx 20rpx;
}
.g-name {
  font-size: 26rpx;
  color: var(--c-text-1);
  font-weight: 500;
  min-height: 72rpx;
  line-height: 1.4;
}
.g-meta {
  font-size: 20rpx;
  color: var(--c-text-3);
  margin: 6rpx 0 8rpx;
}
.g-foot {
  display: flex;
  align-items: center;
  justify-content: space-between;
}
.g-price {
  display: flex;
  align-items: baseline;
  color: var(--c-danger);
}
.gp-cur {
  font-size: 22rpx;
}
.gp-num {
  font-size: 32rpx;
  font-weight: 700;
  margin-left: 2rpx;
}
.g-cart {
  width: 56rpx;
  height: 56rpx;
  border-radius: 50%;
  background: var(--grad-primary);
  color: #fff;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 36rpx;
  font-weight: 300;
  box-shadow: 0 4rpx 12rpx rgba(99, 102, 241, 0.32);
  transition: transform 0.15s ease;
}
.g-cart:active { transform: scale(0.9); }

.loading,
.end {
  text-align: center;
  color: var(--c-text-3);
  font-size: 24rpx;
  padding: 32rpx 0;
}
.font-num { font-family: -apple-system, "DIN Alternate", monospace; }

/* ============ 金刚区 6 格 (2x3) ============ */
.icons {
  display: flex;
  flex-wrap: wrap;
  background: var(--c-card);
  margin: 24rpx 24rpx 0;
  padding: 32rpx 0 16rpx;
  border-radius: 24rpx;
  box-shadow: var(--sh-2);
}
.icon-item {
  width: 33.333%;
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 16rpx 0;
  transition: transform 0.15s ease;
}
.icon-item:active { transform: scale(0.95); }
.icon-circle {
  width: 96rpx;
  height: 96rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 48rpx;
  margin-bottom: 12rpx;
  box-shadow: var(--sh-1);
}
.icon-text {
  font-size: 26rpx;
  color: var(--c-text);
  font-weight: 500;
}
.icon-en {
  font-size: 18rpx;
  color: var(--c-text-3);
  margin-top: 4rpx;
  letter-spacing: 0.5rpx;
}

/* ============ 公告条 ============ */
.notice {
  display: flex;
  align-items: center;
  gap: 12rpx;
  margin: 24rpx 24rpx 0;
  padding: 18rpx 24rpx;
  background: linear-gradient(90deg, #fff5e6 0%, #fff0f5 100%);
  border-radius: 16rpx;
  font-size: 24rpx;
  color: #b04a00;
}
.notice-icon { font-size: 28rpx; }
.notice-text { flex: 1; }

/* ============ 个性定制卡片 ============ */
.custom-card {
  display: flex;
  align-items: center;
  margin: 24rpx 24rpx 0;
  padding: 24rpx 28rpx;
  background: var(--c-card);
  border-radius: 24rpx;
  box-shadow: var(--sh-2);
  position: relative;
  overflow: hidden;
}
.custom-card::before {
  content: '';
  position: absolute;
  left: 0; top: 0; bottom: 0;
  width: 8rpx;
  background: var(--grad-primary);
  border-radius: 4rpx;
}
.cc-left {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}
.cc-badge {
  display: inline-block;
  width: fit-content;
  padding: 4rpx 12rpx;
  background: var(--grad-primary);
  color: #fff;
  font-size: 20rpx;
  border-radius: 8rpx;
  letter-spacing: 1rpx;
}
.cc-title {
  font-size: 30rpx;
  font-weight: 600;
  color: var(--c-text);
}
.cc-sub {
  font-size: 24rpx;
  color: var(--c-text-3);
}
.cc-right {
  width: 96rpx;
  height: 96rpx;
  background: linear-gradient(135deg, #ffe4ec, #fff0f5);
  border-radius: 24rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}
.cc-emoji { font-size: 56rpx; }

/* ============ 秒杀 + 推荐 section (复用已有) ============ */
.section {
  margin: 24rpx 24rpx 0;
}
.section-head {
  display: flex;
  justify-content: space-between;
  align-items: flex-end;
  padding: 8rpx 0 16rpx;
}
.h-left { display: flex; align-items: baseline; gap: 16rpx; }
.h-title { font-size: 32rpx; font-weight: 700; color: var(--c-text); }
.h-sub { font-size: 22rpx; color: var(--c-text-3); }
.h-tip .h-time {
  font-size: 22rpx;
  color: #ff5a5a;
  background: rgba(255, 90, 90, 0.1);
  padding: 4rpx 12rpx;
  border-radius: 8rpx;
  font-family: monospace;
}
.h-more {
  font-size: 24rpx;
  color: var(--c-text-3);
  padding: 8rpx 0;
}

.seckill-scroll {
  white-space: nowrap;
  padding-bottom: 8rpx;
}
.seckill-item {
  display: inline-block;
  width: 240rpx;
  margin-right: 16rpx;
  background: var(--c-card);
  border-radius: 20rpx;
  overflow: hidden;
  box-shadow: var(--sh-1);
  vertical-align: top;
}
.seckill-img {
  width: 240rpx;
  height: 240rpx;
  background: var(--c-bg-page);
}
.seckill-info { padding: 12rpx 16rpx; }
.seckill-name {
  font-size: 24rpx;
  color: var(--c-text);
  font-weight: 500;
  height: 32rpx;
}
.seckill-price-row {
  display: flex;
  align-items: baseline;
  gap: 8rpx;
  margin-top: 8rpx;
}
.seckill-price { font-size: 30rpx; color: #ff5a5a; font-weight: 700; }
.seckill-origin { font-size: 20rpx; color: var(--c-text-3); text-decoration: line-through; }
.seckill-progress { display: flex; align-items: center; gap: 12rpx; margin-top: 8rpx; }
.sp-bar { flex: 1; height: 8rpx; background: #ffe2e2; border-radius: 4rpx; overflow: hidden; }
.sp-fill { height: 100%; background: linear-gradient(90deg, #ff7eb3, #ff5a5a); }
.sp-text { font-size: 18rpx; color: var(--c-text-3); flex-shrink: 0; }

/* ============ 推荐商品 2 列网格 ============ */
.goods-grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 16rpx;
}
.g-card {
  background: var(--c-card);
  border-radius: 20rpx;
  overflow: hidden;
  box-shadow: var(--sh-1);
  transition: transform 0.15s ease;
}
.g-card:active { transform: scale(0.98); }
.g-img-wrap { position: relative; width: 100%; aspect-ratio: 1; }
.g-img { width: 100%; height: 100%; background: var(--c-bg-page); }
.g-tag {
  position: absolute;
  top: 12rpx; left: 12rpx;
  background: linear-gradient(90deg, #ff5a5a, #ff7eb3);
  color: #fff;
  font-size: 20rpx;
  padding: 4rpx 10rpx;
  border-radius: 8rpx;
}
.g-fav {
  position: absolute;
  top: 12rpx; right: 12rpx;
  width: 48rpx; height: 48rpx;
  background: rgba(255, 255, 255, 0.9);
  border-radius: 50%;
  display: flex; align-items: center; justify-content: center;
  font-size: 28rpx;
  color: var(--c-text-3);
  box-shadow: var(--sh-1);
}
.g-fav .faved { color: #ff5a5a; }
.g-body { padding: 12rpx 16rpx 16rpx; }
.g-name {
  font-size: 26rpx;
  color: var(--c-text);
  font-weight: 500;
  line-height: 1.4;
  height: 72rpx;
}
.g-meta { font-size: 20rpx; color: var(--c-text-3); margin-top: 4rpx; }
.g-foot {
  display: flex; justify-content: space-between; align-items: center;
  margin-top: 12rpx;
}
.g-price { display: flex; align-items: baseline; color: #ff5a5a; }
.gp-cur { font-size: 22rpx; font-weight: 600; }
.gp-num { font-size: 32rpx; font-weight: 700; }
.g-cart {
  width: 48rpx; height: 48rpx;
  background: var(--grad-primary);
  color: #fff;
  border-radius: 50%;
  display: flex; align-items: center; justify-content: center;
  font-size: 36rpx;
  font-weight: 300;
  box-shadow: 0 4rpx 12rpx rgba(99, 102, 241, 0.32);
}
.g-cart:active { transform: scale(0.9); }

/* ============ 底部双卡 (会员/须知) ============ */
.footer-cards {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 16rpx;
  margin: 24rpx 24rpx 100rpx;
}
.fc-card {
  display: flex;
  align-items: center;
  gap: 16rpx;
  padding: 28rpx 24rpx;
  background: var(--c-card);
  border-radius: 20rpx;
  box-shadow: var(--sh-2);
  position: relative;
  overflow: hidden;
}
.member-card { background: linear-gradient(135deg, #fff5e6 0%, #ffe4ec 100%); }
.notice-card { background: linear-gradient(135deg, #f0f4ff 0%, #e6f7ff 100%); }
.fc-icon { font-size: 40rpx; }
.fc-text { flex: 1; }
.fc-title {
  font-size: 26rpx;
  font-weight: 600;
  color: var(--c-text);
  line-height: 1.4;
}
.fc-arrow {
  position: absolute;
  right: 20rpx;
  top: 50%;
  transform: translateY(-50%);
  font-size: 32rpx;
  color: var(--c-text-3);
}

/* ============ 悬浮客服 (双按钮) ============ */
.fab-stack {
  position: fixed;
  right: 24rpx;
  bottom: 220rpx;  /* 避开 tabBar */
  display: flex;
  flex-direction: column;
  gap: 20rpx;
  z-index: 99;
}
.fab-btn {
  width: 88rpx;
  height: 88rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 44rpx;
  box-shadow: 0 8rpx 24rpx rgba(0, 0, 0, 0.15);
  transition: transform 0.15s ease;
}
.fab-btn:active { transform: scale(0.92); }
.fab-phone { background: linear-gradient(135deg, #ff5a5a, #ff7eb3); }
.fab-service { background: linear-gradient(135deg, #6366f1, #8b5cf6); }

/* ============ 旧样式覆盖: hero 圆角 + 兼容 ============ */
.hero {
  background: var(--grad-primary);
  padding: 32rpx 24rpx 0;
  border-bottom-left-radius: 0;
  border-bottom-right-radius: 0;
  color: #fff;
}
.banner-wrap {
  margin: 24rpx -8rpx 32rpx;
  border-radius: 24rpx;
  overflow: hidden;
  padding: 0 8rpx;
}
.banner {
  width: 100%;
  height: 360rpx;
}
.banner-card {
  width: 100%; height: 100%;
  border-radius: 24rpx;
  display: flex; align-items: center; justify-content: center;
  position: relative;
  box-shadow: var(--sh-2);
}
.banner-emoji { font-size: 140rpx; }
.banner-mask {
  position: absolute;
  left: 32rpx; bottom: 24rpx; right: 32rpx;
  color: #fff;
}
.banner-title { font-size: 32rpx; font-weight: 700; display: block; }
.banner-sub { font-size: 22rpx; opacity: 0.9; display: block; margin-top: 4rpx; }

.loading, .end { text-align: center; color: var(--c-text-3); font-size: 24rpx; padding: 32rpx 0; }
.font-num { font-family: -apple-system, "DIN Alternate", monospace; }
