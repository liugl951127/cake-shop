<view class="container">
  <!-- 头部用户卡 -->
  <view class="profile">
    <view class="bg-shape"></view>
    <view class="p-row" bindtap="goLogin">
      <image class="avatar" src="{{userInfo.avatarUrl || '/images/default-avatar.png'}}" mode="aspectFill"></image>
      <view class="info">
        <view class="name">{{userInfo.nickName || '点击登录'}}</view>
        <view class="level" wx:if="{{userInfo.level}}">Lv.{{userInfo.level}} 会员</view>
        <view class="phone" wx:if="{{userInfo.phone}}">📱 {{userInfo.phone}}</view>
      </view>
      <text class="arrow">›</text>
    </view>

    <!-- 资产区 -->
    <view class="assets">
      <view class="a-item" bindtap="goWallet">
        <text class="a-n font-num">{{userInfo.points || 0}}</text>
        <text class="a-l">积分</text>
      </view>
      <view class="a-item" bindtap="goCoupon">
        <text class="a-n font-num">{{couponCount || 0}}</text>
        <text class="a-l">优惠券</text>
      </view>
      <view class="a-item" bindtap="goBalance">
        <text class="a-n font-num">¥{{balance || 0}}</text>
        <text class="a-l">余额</text>
      </view>
      <view class="a-item" bindtap="goOrder">
        <text class="a-n font-num">{{orderCount || 0}}</text>
        <text class="a-l">全部订单</text>
      </view>
    </view>
  </view>

  <!-- 订单状态 -->
  <view class="card orders">
    <view class="card-head">
      <text class="ch-title">我的订单</text>
      <text class="ch-more" bindtap="goOrderList">全部订单 ›</text>
    </view>
    <view class="order-types">
      <view class="ot" wx:for="{{orderTypes}}" wx:key="id" data-i="{{item.id}}" bindtap="goOrderType">
        <view class="ot-icon-wrap">
          <text class="ot-icon">{{item.icon}}</text>
          <text class="ot-badge" wx:if="{{item.badge}}">{{item.badge}}</text>
        </view>
        <text class="ot-name">{{item.name}}</text>
      </view>
    </view>
  </view>

  <!-- 营销入口(2 大块) -->
  <view class="card promo">
    <view class="p-item" bindtap="goSeckill">
      <text class="p-icon">⚡</text>
      <view class="p-info">
        <text class="p-name">限时秒杀</text>
        <text class="p-sub">每日 10 点开抢</text>
      </view>
      <text class="p-arrow">›</text>
    </view>
    <view class="p-item" bindtap="goGroup">
      <text class="p-icon">👥</text>
      <text class="p-info">
        <text class="p-name">附近拼团</text>
        <text class="p-sub">2 人成团享低价</text>
      </text>
      <text class="p-arrow">›</text>
    </view>
    <view class="p-item" bindtap="goLuckyBag">
      <text class="p-icon">🎁</text>
      <text class="p-info">
        <text class="p-name">拼手气福袋</text>
        <text class="p-sub">100% 中奖</text>
      </text>
      <text class="p-arrow">›</text>
    </view>
    <view class="p-item" bindtap="goCustom">
      <text class="p-icon">✨</text>
      <text class="p-info">
        <text class="p-name">蛋糕定制</text>
        <text class="p-sub">1 对 1 服务</text>
      </text>
      <text class="p-arrow">›</text>
    </view>
  </view>

  <!-- 功能宫格(2 行 4 列) -->
  <view class="card">
    <view class="grid">
      <view class="g-cell" bindtap="goFavor">
        <text class="g-emoji">♥</text>
        <text class="g-name">我的收藏</text>
      </view>
      <view class="g-cell" bindtap="goCoupon">
        <text class="g-emoji">🎟️</text>
        <text class="g-name">领券中心</text>
      </view>
      <view class="g-cell" bindtap="goMember">
        <text class="g-emoji">👑</text>
        <text class="g-name">会员中心</text>
      </view>
      <view class="g-cell" bindtap="goStore">
        <text class="g-emoji">📍</text>
        <text class="g-name">附近门店</text>
      </view>
      <view class="g-cell" bindtap="goInvite">
        <text class="g-emoji">💌</text>
        <text class="g-name">邀请有礼</text>
      </view>
      <view class="g-cell" bindtap="goService">
        <text class="g-emoji">🌟</text>
        <text class="g-name">服务市场</text>
      </view>
      <view class="g-cell" bindtap="goVerify">
        <text class="g-emoji">🛡️</text>
        <text class="g-name">实名认证</text>
      </view>
      <view class="g-cell" bindtap="goFinance">
        <text class="g-emoji">💰</text>
        <text class="g-name">财务中心</text>
      </view>
    </view>
  </view>

  <!-- 工具列表 -->
  <view class="card list">
    <view class="l-row" bindtap="goChat">
      <text class="l-emoji">💬</text>
      <text class="l-name">在线客服</text>
      <text class="l-arrow">›</text>
    </view>
    <view class="l-row" bindtap="goAddress">
      <text class="l-emoji">📍</text>
      <text class="l-name">收货地址</text>
      <text class="l-arrow">›</text>
    </view>
    <view class="l-row" bindtap="goAgreement">
      <text class="l-emoji">📋</text>
      <text class="l-name">用户协议</text>
      <text class="l-arrow">›</text>
    </view>
    <view class="l-row" bindtap="goPrivacy">
      <text class="l-emoji">🔒</text>
      <text class="l-name">隐私政策</text>
      <text class="l-arrow">›</text>
    </view>
    <view class="l-row" bindtap="goAbout">
      <text class="l-emoji">ℹ️</text>
      <text class="l-name">关于我们</text>
      <text class="l-version">v{{version}}</text>
      <text class="l-arrow">›</text>
    </view>
  </view>

  <view class="footer-space"></view>
</view>
