<view class="page">
  <view class="header">
    <view class="avatar" bindtap="goLogin">
      <image src="{{userInfo.avatarUrl || '/images/default-avatar.png'}}" mode="aspectFill"></image>
    </view>
    <view class="user">
      <view class="u-name">{{userInfo.nickName || '点击登录'}}</view>
      <view class="u-level" wx:if="{{userInfo.isAdmin}}">👑 管理员</view>
      <view class="u-level" wx:else>普通会员</view>
    </view>
    <view class="u-code" wx:if="{{userInfo.openid}}">ID: {{userInfo.openid}}</view>
  </view>

  <view class="order-entry">
    <view class="oe-head flex-between">
      <text>我的订单</text>
      <text class="text-sub" bindtap="goOrderList">全部订单 ›</text>
    </view>
    <view class="oe-grid">
      <view class="oe-item" bindtap="goOrderList" data-v="0">
        <text>💰</text>
        <text>待付款</text>
      </view>
      <view class="oe-item" bindtap="goOrderList" data-v="2">
        <text>🎂</text>
        <text>制作中</text>
      </view>
      <view class="oe-item" bindtap="goOrderList" data-v="3">
        <text>🚚</text>
        <text>配送中</text>
      </view>
      <view class="oe-item" bindtap="goOrderList" data-v="4">
        <text>✓</text>
        <text>已完成</text>
      </view>
    </view>
  </view>

  <view class="menu card">
    <view class="menu-item" bindtap="goFavor">
      <text>♥ 我的收藏</text>
      <text class="arrow">›</text>
    </view>
    <view class="menu-item" bindtap="goAddress">
      <text>📍 收货地址</text>
      <text class="arrow">›</text>
    </view>
    <view class="menu-item" bindtap="goOrderList">
      <text>📦 全部订单</text>
      <text class="arrow">›</text>
    </view>
    <view class="menu-item" wx:if="{{userInfo.isAdmin}}" bindtap="goAdmin">
      <text>🛠 商家管理后台</text>
      <text class="arrow">›</text>
    </view>
    <view class="menu-item" wx:if="{{userInfo.isAdmin}}" bindtap="goAdminGoods">
      <text>🛠 商品管理</text>
      <text class="arrow">›</text>
    </view>
    <view class="menu-item" wx:if="{{userInfo.isAdmin}}" bindtap="goAdminOrders">
      <text>📋 订单管理</text>
      <text class="arrow">›</text>
    </view>
    <view class="menu-item" bindtap="contact">
      <text>💬 联系客服</text>
      <text class="arrow">›</text>
    </view>
    <view class="menu-item" bindtap="about">
      <text>ℹ 关于</text>
      <text class="arrow">›</text>
    </view>
  </view>
</view>
