/* pages/my/my.wxss - 个人中心 浅色卡片 + indigo 渐变 + 大圆角 */
@import "/styles/theme.wxss";

/* 顶部 profile - 渐变背景 */
.profile {
  position: relative;
  background: var(--grad-primary);
  padding: 50rpx 30rpx 80rpx;
  border-radius: 0 0 48rpx 48rpx;
  overflow: hidden;
}
.bg-shape {
  position: absolute;
  top: -100rpx; right: -100rpx;
  width: 400rpx; height: 400rpx;
  background: rgba(255, 255, 255, 0.1);
  border-radius: 50%;
}
.bg-shape::after {
  content: '';
  position: absolute;
  bottom: -150rpx; left: -80rpx;
  width: 300rpx; height: 300rpx;
  background: rgba(255, 255, 255, 0.06);
  border-radius: 50%;
}
.bg-shape::before {
  content: '';
  position: absolute;
  top: 100rpx; right: 50rpx;
  width: 100rpx; height: 100rpx;
  background: rgba(255, 255, 255, 0.05);
  border-radius: 50%;
}

.p-row {
  display: flex; align-items: center;
  position: relative; z-index: 1;
}
.avatar {
  width: 130rpx; height: 130rpx;
  border-radius: 50%;
  background: rgba(255, 255, 255, 0.3);
  border: 4rpx solid rgba(255, 255, 255, 0.5);
}
.info { flex: 1; margin-left: 24rpx; }
.name { color: #fff; font-size: 38rpx; font-weight: 700; }
.level {
  display: inline-block;
  background: rgba(255, 255, 255, 0.25);
  color: #fff;
  font-size: 22rpx;
  padding: 4rpx 16rpx;
  border-radius: var(--r-full);
  margin-top: 8rpx;
  font-weight: 500;
  backdrop-filter: blur(8rpx);
}
.phone { color: rgba(255, 255, 255, 0.85); font-size: 24rpx; margin-top: 8rpx; }
.arrow { color: rgba(255, 255, 255, 0.7); font-size: 40rpx; font-weight: 300; }

/* 资产卡片(浮在 profile 上) */
.assets {
  background: var(--c-bg-card);
  border-radius: var(--r-lg);
  margin: -50rpx 24rpx 0;
  padding: 32rpx 0;
  display: flex;
  position: relative; z-index: 2;
  box-shadow: var(--sh-2);
}
.a-item {
  flex: 1;
  text-align: center;
  border-right: 1rpx solid var(--c-border-soft);
  transition: transform 0.2s;
}
.a-item:last-child { border-right: none; }
.a-item:active { transform: scale(0.96); }
.a-n {
  display: block;
  font-size: 36rpx;
  font-weight: 700;
  color: var(--c-text-1);
}
.a-l {
  display: block;
  font-size: 22rpx;
  color: var(--c-text-3);
  margin-top: 6rpx;
}

/* 通用卡 */
.card {
  background: var(--c-bg-card);
  margin: 24rpx 24rpx 0;
  border-radius: var(--r-lg);
  padding: 28rpx;
  box-shadow: var(--sh-1);
}
.card-head {
  display: flex; justify-content: space-between; align-items: center;
  margin-bottom: 24rpx;
}
.ch-title {
  font-size: 30rpx;
  font-weight: 700;
  color: var(--c-text-1);
  display: flex; align-items: center; gap: 8rpx;
}
.ch-title::before {
  content: '';
  width: 6rpx; height: 26rpx;
  background: var(--grad-primary);
  border-radius: var(--r-full);
}
.ch-more { font-size: 24rpx; color: var(--c-text-3); display: flex; align-items: center; }

/* 订单状态 - 4 宫格 */
.orders { padding-bottom: 16rpx; }
.order-types { display: flex; }
.ot {
  flex: 1;
  display: flex; flex-direction: column; align-items: center;
  padding: 12rpx 0;
  transition: transform 0.2s;
}
.ot:active { transform: scale(0.95); }
.ot-icon-wrap {
  position: relative;
  width: 88rpx; height: 88rpx;
  display: flex; align-items: center; justify-content: center;
  background: var(--c-indigo-50);
  border-radius: 24rpx;
  transition: all 0.2s;
}
.ot:active .ot-icon-wrap {
  background: var(--c-indigo-100);
  transform: translateY(-2rpx);
}
.ot-icon { font-size: 44rpx; }
.ot-badge {
  position: absolute; top: -4rpx; right: -8rpx;
  min-width: 32rpx; height: 32rpx;
  background: var(--c-danger);
  color: #fff;
  font-size: 20rpx;
  text-align: center; line-height: 32rpx;
  border-radius: 16rpx;
  padding: 0 8rpx;
  font-weight: 500;
  box-shadow: 0 2rpx 8rpx rgba(239, 68, 68, 0.32);
}
.ot-name {
  font-size: 24rpx;
  color: var(--c-text-2);
  margin-top: 12rpx;
  font-weight: 500;
}

/* 营销入口 */
.promo { padding: 8rpx 0; }
.p-item {
  display: flex; align-items: center;
  padding: 24rpx 16rpx;
  border-radius: var(--r-md);
  transition: background 0.2s;
}
.p-item:active { background: var(--c-indigo-50); }
.p-icon {
  width: 72rpx; height: 72rpx;
  background: var(--grad-primary);
  border-radius: var(--r-md);
  text-align: center; line-height: 72rpx;
  font-size: 36rpx;
  margin-right: 20rpx;
  box-shadow: 0 4rpx 12rpx rgba(99, 102, 241, 0.24);
  color: #fff;
}
.p-info { flex: 1; }
.p-name { display: block; font-size: 28rpx; color: var(--c-text-1); font-weight: 500; }
.p-sub { display: block; font-size: 22rpx; color: var(--c-text-3); margin-top: 4rpx; }
.p-arrow { color: var(--c-text-3); font-size: 32rpx; }

/* 宫格 */
.grid {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 12rpx;
}
.g-cell {
  display: flex; flex-direction: column; align-items: center;
  padding: 16rpx 0;
  border-radius: var(--r-md);
  transition: all 0.2s;
}
.g-cell:active { background: var(--c-indigo-50); transform: scale(0.95); }
.g-emoji { font-size: 44rpx; }
.g-name { font-size: 22rpx; color: var(--c-text-2); margin-top: 8rpx; }

/* 列表 */
.list { padding: 0; }
.l-row {
  display: flex; align-items: center;
  padding: 28rpx 16rpx;
  border-bottom: 1rpx solid var(--c-border-soft);
  border-radius: var(--r-md);
  transition: background 0.2s;
}
.l-row:last-child { border-bottom: none; }
.l-row:active { background: var(--c-indigo-50); }
.l-emoji {
  font-size: 36rpx;
  margin-right: 20rpx;
  width: 56rpx; height: 56rpx;
  line-height: 56rpx;
  text-align: center;
  background: var(--c-indigo-50);
  border-radius: var(--r-md);
}
.l-name { flex: 1; font-size: 28rpx; color: var(--c-text-1); font-weight: 500; }
.l-version { font-size: 22rpx; color: var(--c-text-3); margin-right: 8rpx; }
.l-arrow { color: var(--c-text-3); font-size: 32rpx; font-weight: 300; }

.footer-space { height: 100rpx; }
