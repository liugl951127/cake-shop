/* 个人中心 - 樱花主题 */

.profile {
  position: relative;
  background: var(--grad-primary);
  padding: 50rpx 30rpx 60rpx;
  border-radius: 0 0 40rpx 40rpx;
  overflow: hidden;
}
.bg-shape {
  position: absolute;
  top: -100rpx; right: -100rpx;
  width: 400rpx; height: 400rpx;
  background: rgba(255,255,255,0.1);
  border-radius: 50%;
}
.bg-shape::after {
  content: '';
  position: absolute;
  bottom: -150rpx; left: -80rpx;
  width: 300rpx; height: 300rpx;
  background: rgba(255,255,255,0.06);
  border-radius: 50%;
}

.p-row {
  display: flex; align-items: center;
  position: relative; z-index: 1;
}
.avatar {
  width: 130rpx; height: 130rpx;
  border-radius: 50%;
  background: rgba(255,255,255,0.3);
  border: 4rpx solid rgba(255,255,255,0.5);
}
.info { flex: 1; margin-left: 24rpx; }
.name { color: #fff; font-size: 38rpx; font-weight: 700; }
.level {
  display: inline-block;
  background: rgba(255,255,255,0.25);
  color: #fff;
  font-size: 22rpx;
  padding: 4rpx 16rpx;
  border-radius: var(--radius-full);
  margin-top: 8rpx;
}
.phone { color: rgba(255,255,255,0.85); font-size: 24rpx; margin-top: 8rpx; }
.arrow { color: rgba(255,255,255,0.7); font-size: 40rpx; font-weight: 300; }

.assets {
  background: rgba(255,255,255,0.95);
  border-radius: var(--radius-md);
  margin-top: 40rpx;
  padding: 28rpx 0;
  display: flex;
  position: relative; z-index: 1;
  box-shadow: var(--shadow);
}
.a-item {
  flex: 1;
  text-align: center;
  border-right: 1rpx solid var(--border-light);
}
.a-item:last-child { border-right: none; }
.a-n {
  display: block;
  font-size: 34rpx;
  font-weight: 700;
  color: var(--text-primary);
}
.a-l {
  display: block;
  font-size: 22rpx;
  color: var(--text-tertiary);
  margin-top: 4rpx;
}

/* 通用卡 */
.card {
  background: #fff;
  margin: 20rpx 24rpx;
  border-radius: var(--radius);
  padding: 24rpx;
  box-shadow: var(--shadow-sm);
}

.card-head {
  display: flex; justify-content: space-between; align-items: center;
  margin-bottom: 24rpx;
}
.ch-title { font-size: 30rpx; font-weight: 700; color: var(--text-primary); }
.ch-more { font-size: 24rpx; color: var(--text-tertiary); }

/* 订单状态 */
.orders { padding-bottom: 16rpx; }
.order-types { display: flex; }
.ot {
  flex: 1;
  display: flex; flex-direction: column; align-items: center;
  padding: 12rpx 0;
  transition: transform 0.2s;
}
.ot:active { transform: scale(0.95); }
.ot-icon-wrap {
  position: relative;
  width: 80rpx; height: 80rpx;
  display: flex; align-items: center; justify-content: center;
  background: var(--primary-50);
  border-radius: 50%;
}
.ot-icon { font-size: 40rpx; }
.ot-badge {
  position: absolute; top: -4rpx; right: -4rpx;
  min-width: 32rpx; height: 32rpx;
  background: var(--danger);
  color: #fff;
  font-size: 20rpx;
  text-align: center; line-height: 32rpx;
  border-radius: 16rpx;
  padding: 0 8rpx;
}
.ot-name { font-size: 24rpx; color: var(--text-secondary); margin-top: 8rpx; }

/* 营销入口 */
.promo { padding: 8rpx 0; }
.p-item {
  display: flex; align-items: center;
  padding: 24rpx;
  transition: background 0.2s;
}
.p-item:active { background: var(--bg-secondary); }
.p-icon {
  width: 80rpx; height: 80rpx;
  background: var(--primary-50);
  border-radius: var(--radius);
  text-align: center; line-height: 80rpx;
  font-size: 40rpx;
  margin-right: 24rpx;
}
.p-info { flex: 1; }
.p-name { display: block; font-size: 28rpx; color: var(--text-primary); font-weight: 500; }
.p-sub { display: block; font-size: 22rpx; color: var(--text-tertiary); margin-top: 4rpx; }
.p-arrow { color: var(--text-tertiary); font-size: 32rpx; }

/* 宫格 */
.grid {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 12rpx;
}
.g-cell {
  display: flex; flex-direction: column; align-items: center;
  padding: 16rpx 0;
  transition: transform 0.2s;
}
.g-cell:active { transform: scale(0.92); }
.g-emoji { font-size: 44rpx; }
.g-name { font-size: 22rpx; color: var(--text-secondary); margin-top: 8rpx; }

/* 列表 */
.list { padding: 0; }
.l-row {
  display: flex; align-items: center;
  padding: 28rpx 24rpx;
  border-bottom: 1rpx solid var(--border-light);
  transition: background 0.2s;
}
.l-row:last-child { border-bottom: none; }
.l-row:active { background: var(--bg-secondary); }
.l-emoji { font-size: 36rpx; margin-right: 24rpx; }
.l-name { flex: 1; font-size: 28rpx; color: var(--text-primary); }
.l-version { font-size: 22rpx; color: var(--text-tertiary); margin-right: 8rpx; }
.l-arrow { color: var(--text-tertiary); font-size: 32rpx; font-weight: 300; }

.footer-space { height: 100rpx; }
