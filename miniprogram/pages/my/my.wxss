.page { padding-bottom: 40rpx; }

.header {
  background: linear-gradient(135deg, #ff7b9c, #e85a82);
  color: #fff; padding: 60rpx 30rpx 80rpx;
  display: flex; align-items: center; position: relative;
}
.avatar {
  width: 120rpx; height: 120rpx; border-radius: 50%;
  background: #fff; overflow: hidden; margin-right: 24rpx;
  border: 4rpx solid rgba(255,255,255,0.3);
}
.avatar image { width: 100%; height: 100%; }
.user { flex: 1; }
.u-name { font-size: 32rpx; font-weight: 600; }
.u-level { font-size: 22rpx; margin-top: 6rpx; opacity: 0.9; }
.member-btn {
  position: absolute; right: 30rpx; top: 70rpx;
  background: rgba(255,255,255,0.25); color: #fff;
  padding: 10rpx 20rpx; border-radius: 999rpx; font-size: 22rpx;
}

.quick-row {
  background: #fff; margin: -50rpx 20rpx 20rpx; border-radius: 16rpx;
  display: flex; padding: 30rpx 0; box-shadow: 0 4rpx 12rpx rgba(0,0,0,0.05);
  position: relative; z-index: 1;
}
.q-item { flex: 1; text-align: center; }
.q-num { font-size: 36rpx; font-weight: bold; color: var(--primary); display: block; }
.q-text { font-size: 24rpx; color: #999; margin-top: 6rpx; }

.order-entry {
  background: #fff; margin: 20rpx; border-radius: 16rpx; padding: 24rpx;
}
.oe-head { font-size: 28rpx; font-weight: 600; margin-bottom: 20rpx; }
.oe-grid { display: flex; }
.oe-item {
  flex: 1; display: flex; flex-direction: column; align-items: center;
  font-size: 22rpx; color: #666;
}
.oe-item text:first-child { font-size: 44rpx; margin-bottom: 8rpx; }

.feature-grid {
  display: flex; flex-wrap: wrap; background: #fff; margin: 0 20rpx 20rpx;
  border-radius: 16rpx; padding: 20rpx 0;
}
.f-item {
  width: 33.33%; text-align: center; padding: 16rpx 0;
  display: flex; flex-direction: column; align-items: center;
}
.f-icon {
  width: 90rpx; height: 90rpx; border-radius: 24rpx;
  display: flex; align-items: center; justify-content: center;
  font-size: 44rpx; margin-bottom: 12rpx;
}
.f-item text { font-size: 24rpx; color: #333; }

.menu { margin: 20rpx; }
.menu-item {
  display: flex; align-items: center; padding: 24rpx 0;
  border-bottom: 1rpx solid #f5f5f5; font-size: 28rpx;
}
.menu-item:last-child { border-bottom: none; }
.menu-item text:first-child { flex: 1; }
.arrow { color: #ccc; }
