.page { padding-bottom: 40rpx; }
.banner {
  background: linear-gradient(135deg, #ff5722, #ff9800);
  color: #fff; padding: 40rpx 30rpx; font-size: 36rpx; font-weight: bold; text-align: center;
}
.g-list { display: flex; flex-wrap: wrap; padding: 20rpx; }
.g-card {
  width: 340rpx; background: #fff; border-radius: 16rpx; margin: 10rpx;
  overflow: hidden; box-shadow: 0 4rpx 12rpx rgba(0,0,0,0.05);
}
.g-img { width: 100%; height: 340rpx; background: #f0f0f0; }
.g-info { padding: 16rpx; }
.g-name { font-size: 28rpx; font-weight: 600; line-height: 1.4; height: 80rpx; }
.g-price-row { display: flex; align-items: baseline; margin-top: 8rpx; }
.g-price { color: #ff5722; font-size: 36rpx; font-weight: bold; }
.g-old { color: #999; font-size: 24rpx; text-decoration: line-through; margin-left: 12rpx; }
.g-btn {
  margin-top: 12rpx; background: #fff5f0; color: #ff5722;
  text-align: center; padding: 10rpx 0; border-radius: 8rpx; font-size: 24rpx;
}
.empty { text-align: center; color: #999; padding: 200rpx 0; width: 100%; }
