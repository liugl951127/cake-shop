.page {
  min-height: 100vh; padding-top: 200rpx;
  display: flex; flex-direction: column; align-items: center;
  background: linear-gradient(180deg, #fff5f8 0%, #f7f7f7 50%);
}
.logo { font-size: 140rpx; }
.brand { font-size: 44rpx; font-weight: bold; margin-top: 20rpx; color: #333; }
.slogan { font-size: 26rpx; color: #999; margin-top: 10rpx; }

.wechat-login {
  margin: 100rpx 60rpx 0; background: #07c160; color: #fff;
  text-align: center; padding: 24rpx 0; border-radius: 999rpx;
  font-size: 30rpx; width: calc(100% - 120rpx);
}
.agreement {
  position: fixed; bottom: 60rpx; left: 0; right: 0;
  text-align: center; font-size: 24rpx; color: #999;
}
