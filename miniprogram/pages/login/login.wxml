<view class="container">
  <!-- 顶部品牌区 -->
  <view class="hero">
    <view class="bg-circle c1"></view>
    <view class="bg-circle c2"></view>
    <view class="bg-circle c3"></view>

    <view class="logo-wrap">
      <text class="logo">🎂</text>
    </view>
    <view class="brand">甜心蛋糕</view>
    <view class="slogan">用心做好每一块蛋糕</view>

    <view class="features">
      <view class="f">
        <text class="f-emoji">🌿</text>
        <text class="f-text">每日新鲜</text>
      </view>
      <view class="f">
        <text class="f-emoji">🚚</text>
        <text class="f-text">同城速达</text>
      </view>
      <view class="f">
        <text class="f-emoji">✨</text>
        <text class="f-text">私人定制</text>
      </view>
    </view>
  </view>

  <!-- 登录卡 -->
  <view class="login-card">
    <view wx:if="{{userInfo.openid}}" class="logged">
      <image class="avatar" src="{{userInfo.avatarUrl || '/images/default-avatar.png'}}" mode="aspectFill"></image>
      <view class="l-name">{{userInfo.nickName}}</view>
      <view class="l-tag" wx:if="{{userInfo.level}}">Lv.{{userInfo.level}} 会员</view>
      <view class="l-phone" wx:if="{{userInfo.phone}}">📱 {{userInfo.phone}}</view>
      <view class="l-tip" wx:if="{{loginTypeText}}">登录方式:{{loginTypeText}}</view>
      <view class="btn btn-primary" bindtap="onBack">进入小程序</view>
      <view class="btn btn-ghost" bindtap="onLogout">退出登录</view>
    </view>

    <view wx:else class="actions">
      <view class="action-btn primary" bindtap="onWxLogin">
        <text>💚</text>
        <text>微信一键登录</text>
      </view>
      <view class="action-btn ghost" bindtap="togglePhone">
        <text>📱</text>
        <text>手机号登录</text>
      </view>
      <view class="action-btn apple" bindtap="onAppleLogin" wx:if="{{showApple}}">
        <text>🍎</text>
        <text>Apple 登录</text>
      </view>
    </view>

    <view class="agreement">
      登录即表示同意 <text class="link" bindtap="goAgreement">《用户协议》</text> 和 <text class="link" bindtap="goAgreement">《隐私政策》</text>
    </view>
  </view>

  <!-- 手机号登录弹层 -->
  <view class="mask" wx:if="{{phonePanel}}" bindtap="togglePhone"></view>
  <view class="phone-panel {{phonePanel ? 'show' : ''}}">
    <view class="p-title">手机号登录</view>
    <view class="p-row">
      <text class="p-lab">+86</text>
      <input class="p-input" type="number" maxlength="11" placeholder="请输入手机号"
             value="{{phone}}" bindinput="onPhoneInput"/>
    </view>
    <view class="p-row">
      <input class="p-input code" type="number" maxlength="6" placeholder="6 位验证码"
             value="{{code}}" bindinput="onCodeInput"/>
      <view class="p-send {{countdown > 0 ? 'disabled' : ''}}" bindtap="onSendCode">
        {{countdown > 0 ? countdown + 's' : '获取验证码'}}
      </view>
    </view>
    <view class="p-btn" bindtap="onPhoneLogin">登录</view>
    <view class="p-close" bindtap="togglePhone">×</view>
  </view>
</view>
