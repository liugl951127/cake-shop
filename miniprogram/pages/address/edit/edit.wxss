.page { padding: 20rpx; }
.form { background: #fff; border-radius: 16rpx; padding: 0 24rpx; }
.form-row {
  display: flex; align-items: center; padding: 28rpx 0;
  border-bottom: 1rpx solid #f5f5f5;
}
.form-row:last-child { border-bottom: none; }
.form-label { width: 160rpx; font-size: 28rpx; color: #333; }
.form-input { flex: 1; font-size: 28rpx; }
.form-input.placeholder { color: #999; }
.arrow { color: #ccc; }
.avatar-picker {
  width: 100rpx; height: 100rpx; background: #f5f5f5; border-radius: 50%;
  display: flex; align-items: center; justify-content: center; overflow: hidden;
}
.avatar-picker image { width: 100%; height: 100%; }
.plus { font-size: 50rpx; color: #ccc; }
.btn-row { gap: 20rpx; padding: 16rpx 0; }
.btn-mini {
  font-size: 24rpx; color: var(--primary); background: var(--primary-light);
  padding: 10rpx 24rpx; border-radius: 999rpx;
}
.default .form-label { flex: 1; }

.save-btn {
  margin: 60rpx 20rpx; background: var(--primary); color: #fff;
  text-align: center; padding: 24rpx 0; border-radius: 999rpx; font-size: 30rpx;
}

/* 省市区弹层 */
.mask { z-index: 1000; }
.region-panel {
  position: fixed; left: 0; right: 0; bottom: -100%;
  background: #fff; border-top-left-radius: 24rpx; border-top-right-radius: 24rpx;
  transition: bottom 0.3s; z-index: 1001; max-height: 80vh;
  display: flex; flex-direction: column;
}
.region-panel.show { bottom: 0; }
.region-tabs {
  display: flex; padding: 20rpx; border-bottom: 1rpx solid #f0f0f0;
}
.rt {
  font-size: 26rpx; color: #666; margin-right: 20rpx; padding: 8rpx 20rpx;
  border-radius: 8rpx;
}
.rt.active { background: var(--primary-light); color: var(--primary); }
.rt.done { color: #333; }
.region-list { flex: 1; padding: 10rpx 0; }
.region-item {
  padding: 24rpx 30rpx; font-size: 28rpx;
  display: flex; justify-content: space-between; align-items: center;
}
.region-item.active { color: var(--primary); background: var(--primary-light); }
.check { color: var(--primary); }
.empty { text-align: center; color: #999; padding: 60rpx 0; }
