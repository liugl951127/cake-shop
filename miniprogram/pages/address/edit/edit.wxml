<view class="page">
  <view class="form">
    <view class="form-row">
      <text class="form-label">姓名</text>
      <input class="form-input" placeholder="收货人姓名" value="{{form.name}}" bindinput="onI" data-k="name"/>
    </view>
    <view class="form-row">
      <text class="form-label">手机号</text>
      <input class="form-input" type="number" maxlength="11" placeholder="收货人手机号" value="{{form.phone}}" bindinput="onI" data-k="phone"/>
    </view>
    <view class="form-row" bindtap="chooseRegion">
      <text class="form-label">省市区</text>
      <text class="form-input region-text">{{form.region || '请选择省/市/区'}}</text>
      <text class="arrow">›</text>
    </view>
    <view class="form-row">
      <text class="form-label">详细地址</text>
      <input class="form-input" placeholder="街道、楼栋、门牌号" value="{{form.detail}}" bindinput="onI" data-k="detail"/>
    </view>
    <view class="form-row default">
      <text class="form-label">设为默认</text>
      <switch checked="{{form.isDefault}}" bindchange="onSwitch" color="#ff7b9c"/>
    </view>
  </view>

  <view class="save-btn" bindtap="save">保存</view>
</view>
