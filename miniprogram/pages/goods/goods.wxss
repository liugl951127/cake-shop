/* 商品列表 - 樱花主题 */

.search-row {
  position: sticky; top: 0; z-index: 10;
  background: var(--bg-primary);
  padding: 20rpx 24rpx;
  border-bottom: 1rpx solid var(--border-light);
}
.search-input {
  display: flex; align-items: center;
  background: var(--bg-secondary);
  border-radius: var(--radius-full);
  padding: 14rpx 24rpx;
}
.si-icon { font-size: 26rpx; color: var(--text-tertiary); margin-right: 12rpx; }
.search-input input { flex: 1; font-size: 26rpx; }
.si-clear {
  width: 40rpx; height: 40rpx; line-height: 36rpx; text-align: center;
  background: #ccc; color: #fff; border-radius: 50%;
  font-size: 28rpx;
}

.body { display: flex; height: calc(100vh - 100rpx); }

.cat-side {
  width: 180rpx;
  background: var(--bg-secondary);
}
.cat-item {
  position: relative;
  padding: 30rpx 20rpx;
  text-align: center;
  font-size: 26rpx;
  color: var(--text-secondary);
  transition: all 0.2s;
}
.cat-item.active {
  background: #fff;
  color: var(--primary);
  font-weight: 600;
}
.cat-bar {
  position: absolute; left: 0; top: 50%;
  width: 6rpx; height: 40rpx;
  background: var(--primary);
  border-radius: 0 4rpx 4rpx 0;
  transform: translateY(-50%);
  opacity: 0;
  transition: opacity 0.2s;
}
.cat-item.active .cat-bar { opacity: 1; }

.goods-side { flex: 1; padding: 20rpx; background: #fff; }

.cat-banner {
  display: flex; align-items: center;
  background: var(--grad-primary-soft);
  border-radius: var(--radius);
  padding: 24rpx;
  margin-bottom: 20rpx;
}
.cb-emoji { font-size: 60rpx; margin-right: 20rpx; }
.cb-name { font-size: 30rpx; font-weight: 600; color: var(--text-primary); display: block; }
.cb-sub { font-size: 22rpx; color: var(--text-tertiary); display: block; margin-top: 4rpx; }

.g-card {
  display: flex;
  background: #fff;
  border-radius: var(--radius);
  padding: 20rpx;
  margin-bottom: 20rpx;
  box-shadow: var(--shadow-sm);
  transition: transform 0.2s;
}
.g-card:active { transform: scale(0.98); }
.g-img {
  width: 200rpx; height: 200rpx;
  border-radius: var(--radius-sm);
  background: #f5f5f5;
  flex-shrink: 0;
}
.g-info {
  flex: 1; min-width: 0;
  margin-left: 20rpx;
  display: flex; flex-direction: column;
}
.g-name { font-size: 28rpx; color: var(--text-primary); line-height: 1.4; }
.g-desc { font-size: 22rpx; color: var(--text-tertiary); margin-top: 6rpx; }
.g-meta { font-size: 22rpx; color: var(--text-tertiary); margin-top: 6rpx; }
.g-foot {
  display: flex; align-items: center; justify-content: space-between;
  margin-top: auto; padding-top: 12rpx;
}
.g-price { display: flex; align-items: baseline; color: var(--danger); }
.gp-cur { font-size: 22rpx; }
.gp-num { font-size: 32rpx; font-weight: 700; }
.gp-old {
  font-size: 22rpx;
  color: var(--text-tertiary);
  text-decoration: line-through;
  margin-left: 12rpx;
}
.g-cart {
  width: 56rpx; height: 56rpx;
  background: var(--grad-primary);
  color: #fff;
  border-radius: 50%;
  text-align: center; line-height: 52rpx;
  font-size: 36rpx;
  font-weight: 300;
  box-shadow: 0 4rpx 12rpx rgba(255,123,156,0.4);
}

.empty {
  text-align: center;
  padding: 100rpx 0;
  color: var(--text-tertiary);
}
.empty-emoji { display: block; font-size: 100rpx; opacity: 0.5; margin-bottom: 16rpx; }
.loading, .end {
  text-align: center;
  padding: 32rpx 0;
  color: var(--text-tertiary);
  font-size: 24rpx;
}
