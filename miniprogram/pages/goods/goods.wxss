/* pages/goods/goods.wxss - 商品列表 浅色卡片 + indigo 渐变 + 大圆角 */
@import "/styles/theme.wxss";

.search-row {
  position: sticky; top: 0; z-index: 10;
  background: var(--c-bg-card);
  padding: 20rpx 24rpx;
  border-bottom: 1rpx solid var(--c-border-soft);
}
.search-input {
  display: flex; align-items: center;
  background: var(--c-indigo-50);
  border-radius: var(--r-full);
  padding: 14rpx 24rpx;
  border: 2rpx solid var(--c-indigo-100);
  transition: all 0.2s;
}
.search-input:focus-within {
  border-color: var(--c-indigo-400);
  background: #fff;
}
.si-icon { font-size: 26rpx; color: var(--c-indigo-400); margin-right: 12rpx; }
.search-input input { flex: 1; font-size: 26rpx; color: var(--c-text-1); }
.si-clear {
  width: 40rpx; height: 40rpx; line-height: 36rpx; text-align: center;
  background: var(--c-text-3); color: #fff; border-radius: 50%;
  font-size: 24rpx;
}

.body { display: flex; height: calc(100vh - 100rpx); }

/* 左侧分类 */
.cat-side {
  width: 180rpx;
  background: var(--c-bg-card);
  border-top-right-radius: var(--r-lg);
}
.cat-item {
  position: relative;
  padding: 32rpx 20rpx;
  text-align: center;
  font-size: 26rpx;
  color: var(--c-text-2);
  transition: all 0.2s;
}
.cat-item.active {
  background: var(--c-indigo-50);
  color: var(--c-indigo-600);
  font-weight: 600;
}
.cat-bar {
  position: absolute; left: 0; top: 50%;
  width: 6rpx; height: 40rpx;
  background: var(--grad-primary);
  border-radius: 0 4rpx 4rpx 0;
  transform: translateY(-50%);
  opacity: 0;
  transition: opacity 0.2s;
}
.cat-item.active .cat-bar { opacity: 1; }

.goods-side { flex: 1; padding: 20rpx; background: var(--c-bg-page); }

/* 分类 banner */
.cat-banner {
  display: flex; align-items: center;
  background: var(--grad-card);
  border-radius: var(--r-lg);
  padding: 24rpx;
  margin-bottom: 20rpx;
  border: 1rpx solid var(--c-indigo-100);
  box-shadow: var(--sh-1);
}
.cb-emoji { font-size: 60rpx; margin-right: 20rpx; }
.cb-name { font-size: 30rpx; font-weight: 600; color: var(--c-text-1); display: block; }
.cb-sub { font-size: 22rpx; color: var(--c-text-3); display: block; margin-top: 4rpx; }

/* 商品卡片(横向) */
.g-card {
  display: flex;
  background: var(--c-bg-card);
  border-radius: var(--r-lg);
  padding: 20rpx;
  margin-bottom: 20rpx;
  box-shadow: var(--sh-1);
  transition: transform 0.2s;
}
.g-card:active { transform: scale(0.99); box-shadow: var(--sh-2); }
.g-img {
  width: 200rpx; height: 200rpx;
  border-radius: var(--r-md);
  background: var(--c-indigo-50);
  flex-shrink: 0;
}
.g-info {
  flex: 1; min-width: 0;
  margin-left: 20rpx;
  display: flex; flex-direction: column;
}
.g-name { font-size: 28rpx; color: var(--c-text-1); line-height: 1.4; font-weight: 500; }
.g-desc { font-size: 22rpx; color: var(--c-text-3); margin-top: 6rpx; }
.g-meta { font-size: 22rpx; color: var(--c-text-3); margin-top: 6rpx; }
.g-foot {
  display: flex; align-items: center; justify-content: space-between;
  margin-top: auto; padding-top: 12rpx;
}
.g-price { display: flex; align-items: baseline; color: var(--c-danger); }
.gp-cur { font-size: 22rpx; }
.gp-num { font-size: 32rpx; font-weight: 700; }
.gp-old {
  font-size: 22rpx;
  color: var(--c-text-3);
  text-decoration: line-through;
  margin-left: 12rpx;
}
.g-cart {
  width: 56rpx; height: 56rpx;
  background: var(--grad-primary);
  color: #fff;
  border-radius: 50%;
  text-align: center; line-height: 52rpx;
  font-size: 36rpx;
  font-weight: 300;
  box-shadow: 0 4rpx 12rpx rgba(99, 102, 241, 0.32);
}
.g-cart:active { transform: scale(0.9); }

.empty {
  text-align: center;
  padding: 100rpx 0;
  color: var(--c-text-3);
}
.empty-emoji { display: block; font-size: 100rpx; opacity: 0.5; margin-bottom: 16rpx; }
.loading, .end {
  text-align: center;
  padding: 32rpx 0;
  color: var(--c-text-3);
  font-size: 24rpx;
}
