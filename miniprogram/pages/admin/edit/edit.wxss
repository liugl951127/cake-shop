.page { padding: 20rpx; padding-bottom: 140rpx; }
.form { background: #fff; border-radius: 16rpx; padding: 0 24rpx; }
.form-row {
  display: flex; align-items: center; padding: 28rpx 0;
  border-bottom: 1rpx solid #f5f5f5;
}
.form-row:last-child { border-bottom: none; }
.form-label { width: 160rpx; font-size: 28rpx; }
.form-input { flex: 1; font-size: 28rpx; }
.img-picker {
  width: 140rpx; height: 140rpx; background: #f5f5f5;
  border-radius: 12rpx; display: flex; align-items: center; justify-content: center;
  overflow: hidden;
}
.img-picker image { width: 100%; height: 100%; }
.plus { font-size: 60rpx; color: #ccc; }
.save-btn {
  margin: 40rpx 20rpx; background: var(--primary); color: #fff;
  text-align: center; padding: 24rpx 0; border-radius: 999rpx; font-size: 30rpx;
}
