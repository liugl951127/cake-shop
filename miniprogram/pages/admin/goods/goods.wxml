<view class="page">
  <view class="g-item" wx:for="{{list}}" wx:key="_id">
    <image src="{{item.image}}" class="g-img" mode="aspectFill"></image>
    <view class="g-info">
      <view class="g-name ellipsis-2">{{item.name}}</view>
      <view class="flex-between">
        <text class="price">¥{{item.price}}</text>
        <text class="text-sub">库存 {{item.stock}} / 销量 {{item.sales || 0}}</text>
      </view>
      <view class="text-sub" style="margin-top:6rpx">状态: {{item.status === 1 ? '上架' : '下架'}}</view>
    </view>
    <view class="g-actions">
      <view class="a-btn" bindtap="edit" data-id="{{item._id}}">编辑</view>
      <view class="a-btn danger" bindtap="del" data-id="{{item._id}}">下架</view>
    </view>
  </view>
  <view class="empty" wx:if="{{!loading && list.length === 0}}">暂无商品</view>
  <view class="add-fab" bindtap="add">+ 添加商品</view>
</view>
