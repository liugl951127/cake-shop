.page { padding: 20rpx; padding-bottom: 140rpx; }
.g-item {
  background: #fff; border-radius: 16rpx; padding: 20rpx;
  margin-bottom: 20rpx; display: flex; align-items: center;
}
.g-img { width: 140rpx; height: 140rpx; border-radius: 12rpx; background: #f0f0f0; }
.g-info { flex: 1; margin: 0 20rpx; min-width: 0; }
.g-name { font-size: 28rpx; font-weight: 500; }
.g-actions { display: flex; flex-direction: column; }
.a-btn {
  padding: 10rpx 20rpx; border-radius: 8rpx;
  font-size: 24rpx; margin-bottom: 10rpx; text-align: center;
  background: var(--primary-light); color: var(--primary);
}
.a-btn.danger { background: #fee; color: #f5222d; }
.add-fab {
  position: fixed; right: 40rpx; bottom: 60rpx;
  width: 110rpx; height: 110rpx; border-radius: 50%;
  background: var(--primary); color: #fff;
  display: flex; align-items: center; justify-content: center;
  font-size: 28rpx; box-shadow: 0 8rpx 24rpx rgba(255,123,156,0.4);
}
.empty { padding: 200rpx 0; text-align: center; color: #999; }
