.page { padding-bottom: 40rpx; }
.tabs {
  display: flex; background: #fff; border-bottom: 1rpx solid #f0f0f0;
  position: sticky; top: 0; z-index: 10; overflow-x: auto;
}
.tab {
  padding: 24rpx 30rpx; font-size: 26rpx; color: #666; flex-shrink: 0;
  position: relative;
}
.tab.active { color: var(--primary); font-weight: bold; }
.tab.active::after {
  content: ''; position: absolute; left: 50%; bottom: 0;
  transform: translateX(-50%);
  width: 30rpx; height: 4rpx; background: var(--primary); border-radius: 4rpx;
}

.o-item {
  background: #fff; margin: 20rpx; border-radius: 16rpx; padding: 20rpx;
}
.o-head { font-size: 24rpx; }
.o-goods { padding: 16rpx 0; display: flex; flex-wrap: wrap; }
.og { display: flex; align-items: center; width: 50%; margin-bottom: 10rpx; }
.og image { width: 80rpx; height: 80rpx; border-radius: 8rpx; background: #f0f0f0; margin-right: 12rpx; }
.og-name { font-size: 24rpx; flex: 1; }
.o-info { font-size: 24rpx; margin-top: 6rpx; }
.o-foot { padding-top: 16rpx; border-top: 1rpx solid #f0f0f0; margin-top: 16rpx; }
.o-actions { display: flex; }
.o-btn {
  padding: 10rpx 24rpx; border: 1rpx solid #ccc; border-radius: 999rpx;
  font-size: 24rpx; margin-left: 12rpx;
}
.o-btn.primary { color: var(--primary); border-color: var(--primary); }
.empty { padding: 200rpx 0; text-align: center; color: #999; }
