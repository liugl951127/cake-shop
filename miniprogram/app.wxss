/* app.wxss - 全局样式 */
@import "/styles/theme.wxss";

page {
  background: var(--c-bg-page);
  font-family: -apple-system, BlinkMacSystemFont, "PingFang SC", "Microsoft YaHei", sans-serif;
  font-size: 28rpx;
  color: var(--c-text-1);
  line-height: 1.5;
  -webkit-font-smoothing: antialiased;
}

view, text, image, button, input, scroll-view, swiper, swiper-item, navigator {
  box-sizing: border-box;
}

button {
  margin: 0;
  padding: 0;
  background: transparent;
  line-height: 1.4;
  font-size: 28rpx;
}
button::after { border: none; }
button[disabled] { opacity: 0.4; }

navigator { color: var(--c-text-1); }

/* 文字行数限制 */
.line-1 {
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}
.line-2 {
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  overflow: hidden;
}
.line-3 {
  display: -webkit-box;
  -webkit-line-clamp: 3;
  -webkit-box-orient: vertical;
  overflow: hidden;
}

/* 兼容旧 token 别名 */
:root, page {
  --bg-secondary: var(--c-bg-page);
  --text-primary: var(--c-text-1);
  --text-secondary: var(--c-text-2);
  --text-tertiary: var(--c-text-3);
  --grad-primary: var(--grad-primary);
  --grad-warm: var(--grad-warm);
  --grad-night: var(--grad-primary);
  --grad-sky: var(--grad-primary-soft);
}

/* 通用容器 */
.container {
  min-height: 100vh;
  padding-bottom: env(safe-area-inset-bottom);
}
