.page { padding-bottom: 40rpx; }
.banner {
  background: linear-gradient(135deg, #ff5722, #ff9800);
  color: #fff; padding: 50rpx 30rpx; text-align: center;
}
.b-title { font-size: 48rpx; font-weight: bold; }
.b-desc { font-size: 28rpx; margin-top: 12rpx; opacity: 0.95; }
.b-stats { font-size: 24rpx; margin-top: 12rpx; opacity: 0.85; }

.draw-area { padding: 60rpx 30rpx; text-align: center; }
.bag {
  width: 280rpx; height: 280rpx; border-radius: 50%;
  background: linear-gradient(135deg, #ff5722, #e64a19);
  display: flex; flex-direction: column; align-items: center; justify-content: center;
  margin: 0 auto; color: #fff; box-shadow: 0 8rpx 24rpx rgba(255,87,34,0.4);
  transition: transform 0.1s;
}
.bag:active { transform: scale(0.95); }
.bag.shake { animation: shake 0.5s ease; }
@keyframes shake {
  0%, 100% { transform: rotate(0); }
  25% { transform: rotate(-10deg); }
  75% { transform: rotate(10deg); }
}
.bag-emoji { font-size: 120rpx; }
.bag-text { font-size: 30rpx; margin-top: 10rpx; font-weight: 600; }
.draw-tip { color: #999; font-size: 26rpx; margin-top: 24rpx; }

.drawing { text-align: center; padding: 100rpx 0; }
.spinner { font-size: 100rpx; animation: spin 1s linear infinite; margin-bottom: 20rpx; }
@keyframes spin { from { transform: rotate(0); } to { transform: rotate(360deg); } }

.result { padding: 20rpx 30rpx; }
.result-card {
  background: #fff; border-radius: 24rpx; padding: 50rpx 30rpx; text-align: center;
  box-shadow: 0 8rpx 24rpx rgba(0,0,0,0.08);
  animation: popIn 0.3s ease;
}
@keyframes popIn {
  0% { transform: scale(0.5); opacity: 0; }
  100% { transform: scale(1); opacity: 1; }
}
.result-card.win { background: linear-gradient(135deg, #fff3e0, #fff8e1); }
.result-card.lose { background: #f5f5f5; }
.r-emoji { font-size: 100rpx; }
.r-name { font-size: 36rpx; font-weight: bold; margin-top: 20rpx; color: #ff5722; }
.r-desc { color: #666; margin-top: 10rpx; }
.r-actions { display: flex; gap: 20rpx; margin-top: 40rpx; }
.r-btn {
  flex: 1; background: #f5f5f5; color: #333;
  text-align: center; padding: 24rpx 0; border-radius: 999rpx; font-size: 28rpx;
}
.r-btn.primary { background: linear-gradient(135deg, #ff5722, #ff9800); color: #fff; }

.card { background: #fff; margin: 20rpx; border-radius: 16rpx; padding: 24rpx; }
.card-title { font-size: 28rpx; font-weight: 600; margin-bottom: 20rpx; }

.prize-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 16rpx; }
.prize-item {
  background: #f9f9f9; border-radius: 12rpx; padding: 20rpx 0; text-align: center;
}
.p-emoji { font-size: 50rpx; }
.p-name { font-size: 22rpx; margin-top: 6rpx; display: block; }
.p-weight { font-size: 18rpx; color: #999; }

.my-record { }
.r-item {
  display: flex; align-items: center; padding: 16rpx 0;
  border-bottom: 1rpx solid #f5f5f5;
}
.r-item:last-child { border-bottom: none; }
.r-info { flex: 1; margin-left: 16rpx; }
.r-status { font-size: 24rpx; color: #999; }
.r-status.win { color: #4caf50; font-weight: 600; }
.empty { text-align: center; color: #999; padding: 30rpx 0; }
