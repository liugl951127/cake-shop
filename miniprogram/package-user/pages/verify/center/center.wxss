.page { background: #f7f7f7; min-height: 100vh; padding-bottom: 40rpx; }

.hero {
  text-align: center; padding: 60rpx 30rpx 40rpx; color: #fff;
  background: linear-gradient(135deg, #ff9800, #ff5722);
}
.hero.full { background: linear-gradient(135deg, #4caf50, #2e7d32); }
.hero.high { background: linear-gradient(135deg, #2196f3, #1565c0); }
.hero.basic { background: linear-gradient(135deg, #ff9800, #ff5722); }
.hero.none { background: linear-gradient(135deg, #999, #666); }

.hero-icon { font-size: 100rpx; }
.hero-text { font-size: 36rpx; font-weight: bold; margin-top: 12rpx; }
.hero-sub { font-size: 24rpx; opacity: 0.9; margin-top: 8rpx; }

.card { background: #fff; margin: 20rpx; border-radius: 16rpx; padding: 20rpx; }
.cell {
  display: flex; align-items: center; padding: 24rpx 0;
  border-bottom: 1rpx solid #f5f5f5;
}
.cell:last-child { border-bottom: none; }
.cell.done { opacity: 0.7; }
.c-icon {
  width: 80rpx; height: 80rpx; border-radius: 16rpx;
  text-align: center; line-height: 80rpx; font-size: 40rpx; color: #fff;
}
.c-icon.real { background: linear-gradient(135deg, #2196f3, #1565c0); }
.c-icon.live { background: linear-gradient(135deg, #4caf50, #2e7d32); }
.c-icon.bank { background: linear-gradient(135deg, #ff9800, #ff5722); }
.c-info { flex: 1; margin-left: 20rpx; }
.c-name { font-size: 28rpx; color: #333; font-weight: 600; }
.c-desc { font-size: 22rpx; color: #999; margin-top: 4rpx; }
.c-status { font-size: 24rpx; color: #4caf50; font-weight: 600; }
.c-status .to-do { color: #ff5722; }

.c-title { font-size: 28rpx; font-weight: 600; margin-bottom: 16rpx; }
.unlock-list { display: flex; flex-wrap: wrap; gap: 16rpx; }
.u {
  background: #fff5e0; color: #ff5722;
  padding: 12rpx 20rpx; border-radius: 999rpx; font-size: 24rpx;
}
.u .emoji { margin-right: 8rpx; }

.rules { margin: 20rpx; padding: 24rpx; background: #fff; border-radius: 16rpx; font-size: 24rpx; color: #666; }
.r-title { font-size: 28rpx; color: #333; font-weight: 600; margin-bottom: 16rpx; }
.rules view { line-height: 1.8; }
