.page { padding-bottom: 40rpx; }

.header { color: #fff; padding: 40rpx 30rpx 60rpx; }
.level-card { display: flex; align-items: center; }
.level-icon { font-size: 80rpx; margin-right: 20rpx; }
.level-info { flex: 1; }
.level-name { font-size: 40rpx; font-weight: bold; }
.level-desc { font-size: 24rpx; margin-top: 6rpx; opacity: 0.9; }
.level-num { font-size: 24rpx; background: rgba(255,255,255,0.25); padding: 8rpx 16rpx; border-radius: 999rpx; }
.progress-row { display: flex; align-items: center; margin-top: 30rpx; }
.progress-bar {
  flex: 1; height: 12rpx; background: rgba(255,255,255,0.3);
  border-radius: 999rpx; overflow: hidden;
}
.progress-fill { height: 100%; background: #fff; border-radius: 999rpx; }
.progress-text { font-size: 24rpx; margin-left: 16rpx; }
.next-text { font-size: 24rpx; margin-top: 12rpx; opacity: 0.9; }

.stats {
  background: #fff; margin: -40rpx 20rpx 0; border-radius: 16rpx;
  display: flex; padding: 30rpx 0; box-shadow: 0 4rpx 12rpx rgba(0,0,0,0.05);
  position: relative; z-index: 1;
}
.stat-item { flex: 1; text-align: center; }
.stat-num { font-size: 36rpx; font-weight: bold; color: var(--primary); }
.stat-text { font-size: 24rpx; color: #999; margin-top: 6rpx; }

.signin-card {
  margin: 20rpx; padding: 30rpx; text-align: center; border-radius: 16rpx;
  background: linear-gradient(135deg, #fff5f8, #fff0f3);
  color: var(--primary); font-size: 30rpx; font-weight: 500;
}
.signed { color: #4caf50; }

.card { background: #fff; margin: 20rpx; border-radius: 16rpx; padding: 24rpx; }
.card-title { font-size: 28rpx; font-weight: 600; margin-bottom: 20rpx; }

.level-list { display: flex; }
.lv {
  flex: 1; text-align: center; padding: 20rpx 0; border-radius: 12rpx;
  margin: 0 6rpx; background: #f5f5f5; transition: all 0.2s;
}
.lv.active { background: var(--primary-light); color: var(--primary); transform: scale(1.05); }
.lv-icon { font-size: 40rpx; }
.lv-name { font-size: 22rpx; margin-top: 6rpx; }
.lv-range { font-size: 20rpx; color: #999; margin-top: 4rpx; }
.lv-discount { font-size: 20rpx; color: var(--primary); margin-top: 4rpx; font-weight: 600; }

.log-item { display: flex; align-items: center; padding: 16rpx 0; border-bottom: 1rpx solid #f5f5f5; }
.log-item:last-child { border-bottom: none; }
.log-item > view:first-child { flex: 1; }
.log-text { font-size: 26rpx; }
.log-delta { font-size: 28rpx; font-weight: 600; }
.log-delta.plus { color: #4caf50; }
.log-delta.minus { color: #999; }
