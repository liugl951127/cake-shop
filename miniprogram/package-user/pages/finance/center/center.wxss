.page { padding-bottom: 40rpx; }
.hero {
  background: linear-gradient(135deg, #4caf50, #2e7d32);
  color: #fff; padding: 60rpx 30rpx 40rpx; text-align: center;
}
.h-label { font-size: 24rpx; opacity: 0.9; }
.h-amount { font-size: 80rpx; font-weight: bold; margin: 12rpx 0; font-family: 'Courier New', monospace; }
.h-tip { font-size: 22rpx; opacity: 0.8; }
.h-btns { display: flex; margin-top: 30rpx; gap: 16rpx; }
.b {
  flex: 1; background: rgba(255,255,255,0.95); color: #2e7d32;
  text-align: center; padding: 20rpx 0; border-radius: 999rpx; font-size: 28rpx; font-weight: 600;
}
.b.outline { background: transparent; color: #fff; border: 2rpx solid #fff; }

.stat { display: flex; background: #fff; margin: -20rpx 20rpx 0; border-radius: 12rpx; padding: 24rpx 0; box-shadow: 0 4rpx 12rpx rgba(0,0,0,0.05); }
.s { flex: 1; text-align: center; }
.s-n { display: block; font-size: 32rpx; color: #333; font-weight: 600; }
.s-l { display: block; font-size: 22rpx; color: #999; margin-top: 4rpx; }

.card { background: #fff; margin: 20rpx; border-radius: 12rpx; padding: 20rpx; }
.c-title { font-size: 28rpx; font-weight: 600; margin-bottom: 16rpx; }
.row { display: flex; justify-content: space-between; padding: 12rpx 0; border-bottom: 1rpx solid #f5f5f5; font-size: 26rpx; }
.row:last-child { border-bottom: none; }
.val { color: #333; font-weight: 500; }
.val.orange { color: #ff9800; }

.tab { display: flex; border-bottom: 1rpx solid #f0f0f0; }
.t { padding: 16rpx 24rpx; font-size: 24rpx; color: #666; position: relative; }
.t.on { color: #2e7d32; font-weight: 600; }
.t.on::after {
  content: ''; position: absolute; left: 24rpx; right: 24rpx; bottom: 0;
  height: 4rpx; background: #2e7d32; border-radius: 2rpx;
}

.withdraws { }
.w { padding: 16rpx 0; border-bottom: 1rpx solid #f5f5f5; }
.w:last-child { border-bottom: none; }
.w-top { display: flex; justify-content: space-between; align-items: center; }
.w-amt { font-size: 32rpx; color: #333; font-weight: 600; }
.w-status {
  padding: 4rpx 12rpx; border-radius: 999rpx; font-size: 22rpx;
  background: #f0f0f0; color: #666;
}
.w-status.status-0 { background: #fff3e0; color: #ef6c00; }
.w-status.status-1 { background: #e3f2fd; color: #1976d2; }
.w-status.status-2 { background: #e8f5e9; color: #2e7d32; }
.w-status.status--1 { background: #ffebee; color: #c62828; }
.w-time { font-size: 22rpx; color: #999; margin-top: 6rpx; }
.empty { text-align: center; color: #ccc; padding: 30rpx 0; }
