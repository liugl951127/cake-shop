.custom-tab-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  height: calc(100rpx + env(safe-area-inset-bottom));
  padding-bottom: env(safe-area-inset-bottom);
  background: #ffffff;
  display: flex;
  align-items: center;
  border-top: 1rpx solid #f0f0f0;
  z-index: 999;
}
.ctb-item {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 12rpx 0;
  transition: transform 0.15s ease;
}
.ctb-item.on { transform: translateY(-4rpx); }
.ctb-item:active { opacity: 0.6; }
.ctb-emoji {
  font-size: 40rpx;
  line-height: 1;
  margin-bottom: 4rpx;
}
.ctb-text {
  font-size: 22rpx;
  font-weight: 500;
}
