<view class="page">
  <view class="hero">
    <view class="title">🌟 蛋糕服务市场</view>
    <view class="sub">定制 · 团采 · 送礼 · 一站搞定</view>
  </view>

  <view class="grid">
    <view class="cell" bindtap="goCustom">
      <view class="emoji">🎂</view>
      <view class="name">蛋糕定制</view>
      <view class="desc">生日 · 婚礼 · 聚会</view>
    </view>
    <view class="cell" bindtap="goBulk">
      <view class="emoji">🏢</view>
      <view class="name">企业团采</view>
      <view class="desc">10 件起 · 开专票</view>
    </view>
    <view class="cell" bindtap="goBirthday">
      <view class="emoji">🎉</view>
      <view class="name">生日提醒</view>
      <view class="desc">不错过每个生日</view>
    </view>
    <view class="cell" bindtap="goSubscribe">
      <view class="emoji">🔔</view>
      <view class="name">消息订阅</view>
      <view class="desc">优惠上新不错过</view>
    </view>
    <view class="cell" bindtap="goGift">
      <view class="emoji">🎁</view>
      <view class="name">送礼服务</view>
      <view class="desc">匿名代送心意</view>
    </view>
    <view class="cell" bindtap="goCust">
      <view class="emoji">💬</view>
      <view class="name">专属顾问</view>
      <view class="desc">1v1 在线咨询</view>
    </view>
  </view>

  <!-- 我的需求 -->
  <view class="card">
    <view class="card-title">📋 我的需求</view>
    <view class="tabbar">
      <text class="t {{tab === 'custom' ? 'on' : ''}}" bindtap="setTab" data-k="custom">定制</text>
      <text class="t {{tab === 'bulk' ? 'on' : ''}}" bindtap="setTab" data-k="bulk">团采</text>
    </view>
    <view class="orders" wx:if="{{orders.length}}">
      <view class="o" wx:for="{{orders}}" wx:key="_id">
        <view class="o-top">
          <text class="o-type">{{item.typeText}}</text>
          <text class="o-status status-{{item.status}}">{{item.statusText}}</text>
        </view>
        <view class="o-desc">{{item.description || item.itemListText || '—'}}</view>
        <view class="o-time">{{item.createTimeText}}</view>
      </view>
    </view>
    <view class="empty" wx:else>暂无{{tab === 'custom' ? '定制' : '团采'}}需求</view>
  </view>
</view>
