.page { padding-bottom: 40rpx; }
.hero { background: linear-gradient(135deg, #e91e63, #9c27b0); color: #fff; padding: 60rpx 30rpx 40rpx; text-align: center; }
.hero .title { font-size: 40rpx; font-weight: bold; }
.hero .sub { font-size: 24rpx; margin-top: 12rpx; opacity: 0.9; }

.grid {
  display: grid; grid-template-columns: repeat(3, 1fr); gap: 16rpx;
  padding: 20rpx;
}
.cell {
  background: #fff; border-radius: 12rpx; padding: 30rpx 0;
  text-align: center; box-shadow: 0 2rpx 8rpx rgba(0,0,0,0.04);
}
.cell .emoji { font-size: 60rpx; }
.cell .name { font-size: 28rpx; font-weight: 600; margin-top: 8rpx; }
.cell .desc { font-size: 22rpx; color: #999; margin-top: 4rpx; }

.card { background: #fff; margin: 20rpx; border-radius: 16rpx; padding: 24rpx; }
.card-title { font-size: 28rpx; font-weight: 600; margin-bottom: 16rpx; }
.tabbar { display: flex; border-bottom: 1rpx solid #f0f0f0; margin-bottom: 16rpx; }
.tabbar .t { padding: 16rpx 24rpx; font-size: 26rpx; color: #666; position: relative; }
.tabbar .t.on { color: #e91e63; font-weight: 600; }
.tabbar .t.on::after {
  content: ''; position: absolute; left: 24rpx; right: 24rpx; bottom: 0;
  height: 4rpx; background: #e91e63; border-radius: 2rpx;
}

.orders { }
.o { padding: 16rpx 0; border-bottom: 1rpx solid #f5f5f5; }
.o:last-child { border-bottom: none; }
.o-top { display: flex; justify-content: space-between; }
.o-type { font-size: 26rpx; color: #333; font-weight: 600; }
.o-status { font-size: 22rpx; padding: 2rpx 16rpx; border-radius: 999rpx; background: #f0f0f0; color: #666; }
.o-status.status-2 { background: #e3f2fd; color: #1976d2; }
.o-status.status-3 { background: #e8f5e9; color: #4caf50; }
.o-status.status-0 { background: #fafafa; color: #999; }
.o-desc { font-size: 24rpx; color: #666; margin-top: 8rpx; line-height: 1.5; }
.o-time { font-size: 22rpx; color: #999; margin-top: 6rpx; }
.empty { text-align: center; color: #ccc; padding: 30rpx 0; }
