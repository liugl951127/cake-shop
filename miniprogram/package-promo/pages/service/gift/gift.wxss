.page { padding: 20rpx 20rpx 200rpx; background: #f7f7f7; min-height: 100vh; }
.head { background: linear-gradient(135deg, #ff5722, #ff9800); color: #fff; padding: 40rpx 30rpx; border-radius: 16rpx; }
.head .big { font-size: 40rpx; font-weight: 700; display: block; }
.head .sub { font-size: 24rpx; display: block; margin-top: 8rpx; opacity: 0.9; }

.card { background: #fff; border-radius: 12rpx; margin-top: 20rpx; padding: 24rpx; }
.form-item { padding: 16rpx 0; border-bottom: 1rpx solid #f5f5f5; }
.form-item:last-child { border-bottom: none; }
.lbl { font-size: 28rpx; color: #333; display: block; margin-bottom: 12rpx; }
.req { color: #ff5722; }
.in { width: 100%; height: 70rpx; font-size: 28rpx; }
.ta { width: 100%; height: 160rpx; font-size: 28rpx; padding: 12rpx 0; }
.anon { display: flex; align-items: center; }
.cb { width: 32rpx; height: 32rpx; border: 1rpx solid #ddd; border-radius: 4rpx; text-align: center; line-height: 30rpx; color: transparent; font-size: 22rpx; margin-right: 12rpx; }
.cb.on { background: #ff5722; color: #fff; border-color: #ff5722; }

.goods { display: flex; align-items: center; padding: 16rpx 0; }
.g-img { width: 140rpx; height: 140rpx; border-radius: 8rpx; background: #f5f5f5; }
.g-add { text-align: center; line-height: 140rpx; color: #ccc; font-size: 26rpx; border: 2rpx dashed #ddd; }
.g-info { margin-left: 20rpx; flex: 1; }
.g-name { font-size: 28rpx; color: #333; }
.g-price { font-size: 32rpx; color: #ff5722; font-weight: 700; margin-top: 8rpx; }

.picker { padding: 16rpx 0; font-size: 28rpx; color: #333; }

.submit {
  position: fixed; left: 20rpx; right: 20rpx; bottom: 30rpx;
  background: linear-gradient(135deg, #ff5722, #ff9800);
  color: #fff; text-align: center; padding: 26rpx 0;
  border-radius: 999rpx; font-size: 30rpx; font-weight: 500;
  box-shadow: 0 8rpx 24rpx rgba(255,123,156,0.3);
}
