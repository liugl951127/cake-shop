.page { padding: 20rpx 20rpx 200rpx; }
.head { font-size: 26rpx; color: #666; padding: 10rpx 0 20rpx; }

.block { background: #fff; border-radius: 12rpx; padding: 24rpx; margin-bottom: 20rpx; }
.label { font-size: 28rpx; color: #333; margin-bottom: 16rpx; }
.req { color: #ff5722; }
.radios { display: flex; flex-wrap: wrap; gap: 12rpx; }
.r {
  background: #f5f5f5; color: #666; padding: 12rpx 24rpx;
  border-radius: 999rpx; font-size: 24rpx;
}
.r.on { background: linear-gradient(135deg, #e91e63, #ff5722); color: #fff; }

.counter { display: flex; align-items: center; }
.counter .b {
  width: 60rpx; height: 60rpx; line-height: 56rpx; text-align: center;
  background: #f5f5f5; border-radius: 50%; font-size: 40rpx;
}
.counter .v { padding: 0 30rpx; font-size: 32rpx; font-weight: 600; min-width: 80rpx; text-align: center; }

.images { display: grid; grid-template-columns: repeat(4, 1fr); gap: 16rpx; }
.img-item { position: relative; aspect-ratio: 1; }
.img-item image { width: 100%; height: 100%; border-radius: 8rpx; }
.del { position: absolute; right: -10rpx; top: -10rpx; width: 36rpx; height: 36rpx; background: #333; color: #fff; border-radius: 50%; text-align: center; line-height: 32rpx; font-size: 28rpx; }
.img-add { aspect-ratio: 1; border: 2rpx dashed #ddd; border-radius: 8rpx; text-align: center; line-height: 1; font-size: 60rpx; color: #ddd; display: flex; align-items: center; justify-content: center; }

.ta { width: 100%; height: 180rpx; font-size: 28rpx; }
.ta.short { height: 100rpx; }
.counter-t { text-align: right; color: #999; font-size: 22rpx; }
.in { width: 100%; height: 80rpx; font-size: 28rpx; }
.picker { padding: 16rpx 0; font-size: 28rpx; color: #333; }

.submit {
  position: fixed; left: 20rpx; right: 20rpx; bottom: 30rpx;
  background: linear-gradient(135deg, #e91e63, #ff5722); color: #fff;
  text-align: center; padding: 24rpx 0; border-radius: 999rpx;
  font-size: 30rpx;
}
