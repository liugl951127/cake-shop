.page { padding: 20rpx 20rpx 40rpx; }
.head { font-size: 26rpx; color: #666; padding: 10rpx 0; }

.add {
  background: #fff; border-radius: 12rpx; text-align: center;
  padding: 28rpx 0; color: #e91e63; font-size: 28rpx; font-weight: 600;
  margin: 20rpx 0;
}

.list { }
.item {
  display: flex; align-items: center; background: #fff;
  border-radius: 12rpx; padding: 20rpx; margin-bottom: 16rpx;
}
.avatar {
  width: 80rpx; height: 80rpx; border-radius: 50%;
  background: linear-gradient(135deg, #ff9800, #e91e63);
  color: #fff; text-align: center; line-height: 80rpx;
  font-size: 32rpx; font-weight: 600;
}
.info { flex: 1; margin-left: 20rpx; }
.name { font-size: 28rpx; color: #333; font-weight: 600; display: flex; align-items: center; }
.tag { background: #ff5722; color: #fff; font-size: 18rpx; padding: 2rpx 12rpx; border-radius: 999rpx; margin-left: 10rpx; }
.bd { font-size: 22rpx; color: #999; margin-top: 6rpx; }

.days { text-align: center; }
.days .big { font-size: 40rpx; color: #e91e63; font-weight: bold; }
.days .unit { font-size: 20rpx; color: #999; display: block; }

.del { color: #ccc; font-size: 40rpx; padding: 0 20rpx; }

.empty {
  text-align: center; color: #ccc; padding: 100rpx 0; display: flex;
  flex-direction: column; font-size: 28rpx;
}
.empty .sub { font-size: 24rpx; margin-top: 12rpx; }

/* 弹层 */
.mask { position: fixed; inset: 0; background: rgba(0,0,0,0.5); z-index: 1000; }
.add-panel {
  position: fixed; left: 40rpx; right: 40rpx; top: 15%;
  background: #fff; border-radius: 16rpx; padding: 50rpx 30rpx 30rpx;
  z-index: 1001; transform: scale(0.9); opacity: 0; transition: all 0.2s;
}
.add-panel.show { transform: scale(1); opacity: 1; }
.p-title { text-align: center; font-size: 32rpx; font-weight: bold; margin-bottom: 30rpx; }
.p-row { padding: 16rpx 0; border-bottom: 1rpx solid #f5f5f5; }
.p-row .lab { font-size: 26rpx; color: #333; display: block; margin-bottom: 12rpx; }
.p-row .ipt { font-size: 28rpx; padding: 8rpx 0; }
.radios { display: flex; gap: 12rpx; flex-wrap: wrap; }
.radios .r { background: #f5f5f5; color: #666; padding: 8rpx 20rpx; border-radius: 999rpx; font-size: 24rpx; }
.radios .r.on { background: #e91e63; color: #fff; }
.p-btn {
  background: linear-gradient(135deg, #e91e63, #ff5722); color: #fff;
  text-align: center; padding: 24rpx 0; border-radius: 999rpx;
  font-size: 30rpx; margin-top: 30rpx;
}
.p-close { position: absolute; right: 20rpx; top: 16rpx; font-size: 40rpx; color: #999; width: 60rpx; text-align: center; }
