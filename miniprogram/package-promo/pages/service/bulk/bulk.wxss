.page { padding: 20rpx 20rpx 200rpx; }
.head { font-size: 26rpx; color: #666; padding: 10rpx 0 20rpx; }
.block { background: #fff; border-radius: 12rpx; padding: 24rpx; margin-bottom: 20rpx; }
.label { font-size: 28rpx; color: #333; margin-bottom: 16rpx; }
.req { color: #ff5722; }
.in { width: 100%; height: 70rpx; font-size: 28rpx; }
.in.narrow { display: inline-block; width: 30%; }
.row2 { display: flex; gap: 12rpx; }
.row2 .in { width: 50%; }

.items { }
.it { display: flex; gap: 12rpx; align-items: center; margin-bottom: 12rpx; }
.x { width: 60rpx; height: 60rpx; line-height: 56rpx; text-align: center; font-size: 36rpx; color: #999; }
.add-item {
  border: 2rpx dashed #ddd; border-radius: 8rpx;
  text-align: center; padding: 16rpx 0; color: #999; font-size: 24rpx;
  margin-top: 12rpx;
}

.counter { display: flex; align-items: center; }
.counter .b {
  width: 80rpx; height: 60rpx; line-height: 56rpx; text-align: center;
  background: #f5f5f5; border-radius: 8rpx; font-size: 26rpx;
  margin-right: 12rpx;
}
.counter .v { padding: 0 30rpx; font-size: 32rpx; font-weight: 600; min-width: 100rpx; text-align: center; }

.ta { width: 100%; height: 140rpx; font-size: 28rpx; }
.picker { padding: 16rpx 0; font-size: 28rpx; }

.check { display: flex; align-items: center; }
.cb { width: 32rpx; height: 32rpx; border: 1rpx solid #ddd; border-radius: 4rpx; text-align: center; line-height: 30rpx; color: transparent; font-size: 22rpx; margin-right: 12rpx; }
.cb.on { background: #e91e63; color: #fff; border-color: #e91e63; }

.submit {
  position: fixed; left: 20rpx; right: 20rpx; bottom: 30rpx;
  background: linear-gradient(135deg, #e91e63, #ff5722); color: #fff;
  text-align: center; padding: 24rpx 0; border-radius: 999rpx;
  font-size: 30rpx;
}
