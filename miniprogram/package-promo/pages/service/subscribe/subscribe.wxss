.page { padding: 20rpx; background: #f7f7f7; min-height: 100vh; }
.head { background: linear-gradient(135deg, #ff5722, #ff9800); color: #fff; padding: 40rpx 30rpx; border-radius: 16rpx; }
.head .big { font-size: 40rpx; font-weight: 700; display: block; }
.head .sub { font-size: 24rpx; display: block; margin-top: 8rpx; opacity: 0.9; }

.list { background: #fff; border-radius: 12rpx; margin-top: 20rpx; padding: 16rpx; }
.item { display: flex; align-items: center; padding: 20rpx 8rpx; border-bottom: 1rpx solid #f5f5f5; }
.item:last-child { border-bottom: none; }
.i-emoji { font-size: 50rpx; margin-right: 20rpx; }
.i-info { flex: 1; }
.i-name { font-size: 28rpx; color: #333; font-weight: 500; }
.i-desc { font-size: 22rpx; color: #999; margin-top: 4rpx; }
.i-btn {
  background: #ff5722; color: #fff;
  padding: 12rpx 24rpx; border-radius: 999rpx;
  font-size: 24rpx;
}
.i-btn.on { background: #4caf50; }

.notice {
  background: #fff5e0; color: #ff9800;
  padding: 20rpx; border-radius: 12rpx;
  margin-top: 20rpx; font-size: 24rpx;
  display: flex; flex-direction: column; gap: 6rpx;
}
