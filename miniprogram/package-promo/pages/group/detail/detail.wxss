.page { padding-bottom: 140rpx; }
.g-img { width: 100%; height: 500rpx; background: #f0f0f0; }
.info { background: #fff; padding: 24rpx; }
.g-name { font-size: 32rpx; font-weight: 600; }
.g-price-row { display: flex; align-items: baseline; margin-top: 12rpx; }
.g-price { color: #ff5722; font-size: 44rpx; font-weight: bold; }
.g-old { color: #999; font-size: 26rpx; text-decoration: line-through; margin-left: 16rpx; }
.g-tag {
  margin-top: 12rpx; display: inline-block; padding: 6rpx 16rpx;
  background: #fff5f0; color: #ff5722; border-radius: 8rpx; font-size: 24rpx;
}

.card { background: #fff; margin: 20rpx; border-radius: 16rpx; padding: 24rpx; }
.card-title { font-size: 28rpx; font-weight: 600; margin-bottom: 20rpx; }
.members { display: flex; flex-wrap: wrap; }
.member { width: 25%; text-align: center; margin-bottom: 20rpx; position: relative; }
.m-avatar {
  width: 100rpx; height: 100rpx; border-radius: 50%; background: #f0f0f0; margin: 0 auto;
}
.m-avatar.empty {
  background: #f5f5f5; color: #ccc; font-size: 40rpx;
  display: flex; align-items: center; justify-content: center;
}
.m-name { font-size: 22rpx; margin-top: 6rpx; display: block; }
.m-tag {
  position: absolute; top: -10rpx; right: 20rpx;
  background: var(--primary); color: #fff; font-size: 20rpx;
  padding: 2rpx 10rpx; border-radius: 6rpx;
}
.countdown { margin-top: 20rpx; text-align: center; color: #ff5722; font-size: 28rpx; }
.countdown .ct { font-weight: bold; }

.footer {
  position: fixed; left: 0; right: 0; bottom: 0;
  display: flex; background: #fff; height: 100rpx; border-top: 1rpx solid #eee;
}
.footer-side { width: 200rpx; display: flex; align-items: center; justify-content: center; font-size: 26rpx; color: #666; }
.footer-btn {
  flex: 1; background: linear-gradient(135deg, #ff5722, #ff9800);
  color: #fff; display: flex; align-items: center; justify-content: center;
  font-size: 30rpx; font-weight: bold;
}
