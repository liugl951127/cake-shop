.page { background: #f7f7f7; min-height: 100vh; }
.head {
  background: linear-gradient(135deg, #ff5722, #ff9800);
  color: #fff; padding: 24rpx 30rpx;
}
.loc { display: flex; align-items: center; font-size: 30rpx; }
.loc .icon { margin-right: 8rpx; }
.loc .text { font-weight: 600; }
.radii { display: flex; margin-top: 16rpx; }
.radii .r {
  background: rgba(255,255,255,0.2); padding: 6rpx 20rpx;
  border-radius: 999rpx; margin-right: 12rpx; font-size: 22rpx;
}
.radii .r.on { background: #fff; color: #ff5722; }

.list { padding: 0 20rpx; }
.g {
  display: flex; background: #fff; border-radius: 12rpx;
  margin-top: 20rpx; padding: 20rpx; align-items: center;
}
.g .img { width: 200rpx; height: 200rpx; border-radius: 8rpx; background: #f0f0f0; }
.g .info { flex: 1; margin-left: 20rpx; }
.g .name { font-size: 28rpx; color: #333; line-height: 1.4; }
.g .row { display: flex; justify-content: space-between; align-items: center; margin-top: 12rpx; }
.g .gp { color: #ff5722; font-size: 32rpx; font-weight: bold; }
.g .or { color: #999; text-decoration: line-through; font-size: 22rpx; }
.g .gt { font-size: 22rpx; color: #666; }
.g .dst { font-size: 22rpx; color: #4caf50; }
.g .et { font-size: 22rpx; color: #ff9800; }
.g .btn { background: #ff5722; color: #fff; padding: 6rpx 20rpx; border-radius: 999rpx; font-size: 22rpx; }

.empty {
  text-align: center; color: #ccc; padding: 100rpx 0;
  display: flex; flex-direction: column; font-size: 28rpx;
}
.empty .sub { font-size: 24rpx; margin-top: 16rpx; }
