/* order/detail/detail.wxss - 订单详情 浅色卡片 + indigo 渐变 + 大圆角 */
@import "/styles/theme.wxss";

.page { padding-bottom: 140rpx; background: var(--c-bg-page); }

/* 顶部状态条 - 渐变背景 */
.status-bar {
  background: var(--grad-primary);
  color: #fff;
  padding: 50rpx 30rpx 80rpx;
  position: relative;
  overflow: hidden;
  border-bottom-left-radius: 40rpx;
  border-bottom-right-radius: 40rpx;
}
.status-bar::before {
  content: '';
  position: absolute; top: -100rpx; right: -80rpx;
  width: 320rpx; height: 320rpx;
  background: rgba(255, 255, 255, 0.1);
  border-radius: 50%;
}
.status-bar::after {
  content: '';
  position: absolute; bottom: -120rpx; left: -60rpx;
  width: 240rpx; height: 240rpx;
  background: rgba(255, 255, 255, 0.08);
  border-radius: 50%;
}
.status-text { font-size: 44rpx; font-weight: 700; position: relative; }
.status-sub { font-size: 26rpx; margin-top: 12rpx; opacity: 0.9; position: relative; }

/* 进度条卡片 */
.progress {
  background: var(--c-bg-card);
  margin: -50rpx 24rpx 24rpx;
  border-radius: var(--r-lg);
  padding: 32rpx 24rpx;
  position: relative; z-index: 1;
  display: flex; align-items: center; justify-content: space-between;
  box-shadow: var(--sh-2);
}
.p-step { display: flex; flex-direction: column; align-items: center; flex: 0 0 auto; }
.p-step .dot {
  width: 56rpx; height: 56rpx; border-radius: 50%;
  background: var(--c-indigo-50);
  color: var(--c-text-3);
  font-size: 26rpx;
  display: flex; align-items: center; justify-content: center;
  margin-bottom: 12rpx;
  font-weight: 500;
  transition: all 0.2s;
}
.p-step text { font-size: 22rpx; color: var(--c-text-3); }
.p-step.done .dot {
  background: var(--grad-primary);
  color: #fff;
  box-shadow: 0 4rpx 12rpx rgba(99, 102, 241, 0.32);
}
.p-step.done text { color: var(--c-indigo-600); }
.p-step.current .dot {
  background: var(--grad-primary);
  color: #fff;
  box-shadow: 0 0 0 8rpx var(--c-indigo-100);
}
.p-step.current text { color: var(--c-indigo-600); font-weight: 500; }
.p-line {
  flex: 1; height: 4rpx;
  background: var(--c-indigo-50);
  margin: 0 8rpx; align-self: center; margin-bottom: 30rpx;
  border-radius: var(--r-full);
}
.p-line.done { background: var(--grad-primary); }

/* 卡片 */
.card {
  background: var(--c-bg-card);
  margin: 24rpx;
  border-radius: var(--r-lg);
  padding: 28rpx;
  box-shadow: var(--sh-1);
}
.card-title {
  font-size: 30rpx;
  font-weight: 600;
  margin-bottom: 20rpx;
  color: var(--c-text-1);
  display: flex; align-items: center; gap: 8rpx;
}
.card-title::before {
  content: '';
  width: 6rpx; height: 28rpx;
  background: var(--grad-primary);
  border-radius: var(--r-full);
}

.row { display: flex; align-items: center; padding: 12rpx 0; font-size: 26rpx; }
.row .text-sub { width: 160rpx; color: var(--c-text-3); }
.row text:nth-child(2) { flex: 1; text-align: right; color: var(--c-text-1); }
.row.total {
  font-weight: 600; font-size: 30rpx; padding-top: 20rpx;
  border-top: 1rpx solid var(--c-border-soft);
  margin-top: 12rpx;
  color: var(--c-danger);
}
.icon { font-size: 36rpx; margin-right: 20rpx; }
.addr { flex: 1; }

/* 商品行 */
.g-item {
  display: flex; padding: 16rpx 0;
  border-bottom: 1rpx solid var(--c-border-soft);
}
.g-item:last-child { border-bottom: none; }
.g-img {
  width: 160rpx; height: 160rpx;
  border-radius: var(--r-md);
  background: var(--c-indigo-50);
  flex-shrink: 0;
}
.g-info {
  flex: 1; margin-left: 20rpx; min-width: 0;
  display: flex; flex-direction: column; justify-content: space-between;
}
.g-name { font-size: 28rpx; color: var(--c-text-1); font-weight: 500; }
.g-spec { font-size: 22rpx; color: var(--c-text-3); }
.g-foot {
  display: flex; align-items: center; justify-content: space-between;
}
.g-price { color: var(--c-danger); font-weight: 600; font-size: 28rpx; }
.g-qty { color: var(--c-text-3); font-size: 24rpx; }

/* 日志 */
.log-item { display: flex; padding: 12rpx 0; }
.log-dot {
  width: 16rpx; height: 16rpx; border-radius: 50%;
  background: var(--grad-primary);
  margin: 10rpx 16rpx 0 0;
  flex-shrink: 0;
}
.log-info { flex: 1; }
.log-text { font-size: 26rpx; color: var(--c-text-1); }
.log-time { font-size: 22rpx; color: var(--c-text-3); margin-top: 4rpx; }

/* 底部操作 */
.footer {
  position: fixed; left: 0; right: 0; bottom: 0;
  padding: 20rpx 24rpx;
  background: var(--c-bg-card);
  border-top: 1rpx solid var(--c-border-soft);
  display: flex; justify-content: flex-end; gap: 16rpx;
  padding-bottom: calc(20rpx + env(safe-area-inset-bottom));
  z-index: 100;
}
.o-btn {
  padding: 16rpx 32rpx;
  border: 2rpx solid var(--c-indigo-200);
  border-radius: var(--r-full);
  font-size: 28rpx;
  background: var(--c-bg-card);
  color: var(--c-indigo-600);
  font-weight: 500;
}
.o-btn:active { background: var(--c-indigo-50); }
.o-btn.primary {
  background: var(--grad-primary);
  color: #fff;
  border-color: transparent;
  box-shadow: 0 4rpx 12rpx rgba(99, 102, 241, 0.32);
}
.o-btn.primary:active { transform: scale(0.98); }
