.page { padding-bottom: 140rpx; background: var(--bg-secondary); }
.status-bar {
  color: #fff;
  padding: 50rpx 30rpx 70rpx;
  position: relative;
  overflow: hidden;
}
.status-bar::before {
  content: '';
  position: absolute; top: -100rpx; right: -80rpx;
  width: 300rpx; height: 300rpx;
  background: rgba(255,255,255,0.1);
  border-radius: 50%;
}
.status-text { font-size: 44rpx; font-weight: 700; position: relative; }
.status-sub { font-size: 26rpx; margin-top: 12rpx; opacity: 0.9; position: relative; }

.progress {
  background: #fff; margin: -30rpx 20rpx 20rpx; border-radius: 16rpx;
  padding: 30rpx 20rpx; position: relative; z-index: 1;
  display: flex; align-items: center; justify-content: space-between;
  box-shadow: 0 4rpx 12rpx rgba(0,0,0,0.05);
}
.p-step { display: flex; flex-direction: column; align-items: center; flex: 0 0 auto; }
.p-step .dot {
  width: 50rpx; height: 50rpx; border-radius: 50%;
  background: #eee; color: #999; font-size: 24rpx;
  display: flex; align-items: center; justify-content: center;
  margin-bottom: 8rpx;
}
.p-step text { font-size: 22rpx; color: #999; }
.p-step.done .dot { background: var(--primary); color: #fff; }
.p-step.done text { color: var(--primary); }
.p-step.current .dot { background: var(--primary); color: #fff; box-shadow: 0 0 0 6rpx var(--primary-light); }
.p-line { flex: 1; height: 4rpx; background: #eee; margin: 0 8rpx; align-self: center; margin-bottom: 30rpx; }
.p-line.done { background: var(--primary); }

.card { background: #fff; margin: 20rpx; border-radius: 16rpx; padding: 24rpx; }
.card-title { font-size: 28rpx; font-weight: 600; margin-bottom: 20rpx; }
.row { display: flex; align-items: center; padding: 10rpx 0; font-size: 26rpx; }
.row .text-sub { width: 160rpx; }
.row text:nth-child(2) { flex: 1; text-align: right; }
.row.total { font-weight: bold; font-size: 30rpx; padding-top: 20rpx; border-top: 1rpx solid #f0f0f0; margin-top: 10rpx; }
.icon { font-size: 36rpx; margin-right: 20rpx; }
.addr { flex: 1; }
.g-item { display: flex; padding: 16rpx 0; border-bottom: 1rpx solid #f5f5f5; }
.g-item:last-child { border-bottom: none; }
.g-img { width: 140rpx; height: 140rpx; border-radius: 12rpx; background: #f0f0f0; }
.g-info { flex: 1; margin-left: 20rpx; min-width: 0; display: flex; flex-direction: column; justify-content: space-between; }
.g-name { font-size: 28rpx; }
.g-spec { font-size: 22rpx; }

.log-item { display: flex; padding: 12rpx 0; }
.log-dot { width: 16rpx; height: 16rpx; border-radius: 50%; background: var(--primary); margin: 8rpx 16rpx 0 0; flex-shrink: 0; }
.log-info { flex: 1; }
.log-text { font-size: 26rpx; }

.footer {
  position: fixed; left: 0; right: 0; bottom: 0; padding: 20rpx;
  background: #fff; border-top: 1rpx solid #eee; display: flex; justify-content: flex-end;
}
.o-btn {
  padding: 16rpx 32rpx; border: 1rpx solid #ccc; border-radius: 999rpx;
  font-size: 28rpx; margin-left: 16rpx;
}
.o-btn.primary { color: var(--primary); border-color: var(--primary); }
