<view class="page" wx:if="{{order}}">
  <!-- 状态栏 -->
  <view class="status-bar" style="background:{{statusMap[order.status].color}}">
    <view class="status-text">{{statusMap[order.status].text}}</view>
    <view class="status-sub" wx:if="{{order.status === 0 && order.expireTime}}">
      剩 {{countdown}} 自动关闭
    </view>
    <view class="status-sub" wx:elif="{{order.status === 1}}">商家已收到订单,准备制作中</view>
    <view class="status-sub" wx:elif="{{order.status === 2}}">蛋糕师正在用心制作中</view>
    <view class="status-sub" wx:elif="{{order.status === 3 && order.deliveryInfo}}">
      骑手 {{order.deliveryInfo.name}} {{order.deliveryInfo.phone}} 配送中
    </view>
    <view class="status-sub" wx:elif="{{order.status === 4}}">订单已完成,感谢您的支持</view>
    <view class="status-sub" wx:elif="{{order.status === -1}}">{{order.cancelReason || '订单已取消'}}</view>
    <view class="status-sub" wx:elif="{{order.status === -2}}">已退款</view>
    <view class="status-sub" wx:elif="{{order.status === 5}}">退款处理中</view>
  </view>

  <!-- 进度条 -->
  <view class="progress" wx:if="{{order.status >= 0 && order.status <= 4}}">
    <view class="p-step {{order.status >= 1 ? 'done' : ''}} {{order.status === 0 ? 'current' : ''}}">
      <view class="dot">1</view>
      <text>已付款</text>
    </view>
    <view class="p-line {{order.status >= 2 ? 'done' : ''}}"></view>
    <view class="p-step {{order.status >= 2 ? 'done' : ''}} {{order.status === 1 || order.status === 0 ? '' : 'current'}}" wx:if="{{order.status >= 1}}">
      <view class="dot">2</view>
      <text>制作中</text>
    </view>
    <view class="p-line {{order.status >= 3 ? 'done' : ''}}" wx:if="{{order.status >= 2}}"></view>
    <view class="p-step {{order.status >= 3 ? 'done' : ''}} {{order.status === 2 ? 'current' : ''}}" wx:if="{{order.status >= 2}}">
      <view class="dot">3</view>
      <text>配送中</text>
    </view>
    <view class="p-line {{order.status >= 4 ? 'done' : ''}}" wx:if="{{order.status >= 3}}"></view>
    <view class="p-step {{order.status >= 4 ? 'done' : ''}} {{order.status === 3 ? 'current' : ''}}" wx:if="{{order.status >= 3}}">
      <view class="dot">4</view>
      <text>已完成</text>
    </view>
  </view>

  <!-- 地址 -->
  <view class="card">
    <view class="row">
      <text class="icon">📍</text>
      <view class="addr">
        <view>{{order.address.name}} {{order.address.phone}}</view>
        <view class="text-sub">{{order.address.region}} {{order.address.detail}}</view>
      </view>
    </view>
  </view>

  <!-- 商品 -->
  <view class="card">
    <view class="card-title">商品列表</view>
    <view class="g-item" wx:for="{{order.items}}" wx:key="name">
      <image src="{{item.image}}" class="g-img" mode="aspectFill"></image>
      <view class="g-info">
        <view class="g-name">{{item.name}}</view>
        <view class="g-spec text-sub" wx:if="{{item.spec}}">{{item.spec}}</view>
        <view class="flex-between">
          <text class="price">{{item.price}}</text>
          <text class="text-sub">x{{item.count}}</text>
        </view>
      </view>
    </view>
  </view>

  <!-- 配送信息(配送中时显示) -->
  <view class="card" wx:if="{{order.deliveryInfo}}">
    <view class="card-title">配送信息</view>
    <view class="row"><text class="text-sub">配送员</text><text>{{order.deliveryInfo.name}}</text></view>
    <view class="row"><text class="text-sub">电话</text>
      <text class="text-primary" bindtap="callDelivery">{{order.deliveryInfo.phone}}</text>
    </view>
    <view class="row" wx:if="{{order.deliveryInfo.company}}"><text class="text-sub">物流</text><text>{{order.deliveryInfo.company}}</text></view>
  </view>

  <!-- 订单信息 -->
  <view class="card">
    <view class="card-title">订单信息</view>
    <view class="row"><text class="text-sub">订单号</text><text class="text-primary" bindtap="copyOrderNo">{{order.orderNo}}</text></view>
    <view class="row"><text class="text-sub">下单时间</text><text>{{order.createTime}}</text></view>
    <view class="row" wx:if="{{order.payTime}}"><text class="text-sub">支付时间</text><text>{{order.payTime}}</text></view>
    <view class="row" wx:if="{{order.shipTime}}"><text class="text-sub">发货时间</text><text>{{order.shipTime}}</text></view>
    <view class="row" wx:if="{{order.completeTime}}"><text class="text-sub">完成时间</text><text>{{order.completeTime}}</text></view>
    <view class="row"><text class="text-sub">送达时间</text><text>{{order.timeText || '尽快送达'}}</text></view>
    <view class="row" wx:if="{{order.remark}}"><text class="text-sub">备注</text><text>{{order.remark}}</text></view>
  </view>

  <!-- 金额 -->
  <view class="card">
    <view class="row"><text class="text-sub">商品金额</text><text>¥{{order.goodsPrice}}</text></view>
    <view class="row"><text class="text-sub">配送费</text><text>¥{{order.freight}}</text></view>
    <view class="row total"><text>实付</text><text class="price">¥{{order.totalPrice}}</text></view>
  </view>

  <!-- 状态流转日志 -->
  <view class="card" wx:if="{{order.logs && order.logs.length > 0}}">
    <view class="card-title">订单跟踪</view>
    <view class="log-item" wx:for="{{order.logs}}" wx:key="createTime">
      <view class="log-dot"></view>
      <view class="log-info">
        <view class="log-text">{{item.remark || item.action}}</view>
        <view class="text-sub">{{item.createTime}}</view>
      </view>
    </view>
  </view>

  <!-- 底部操作 -->
  <view class="footer" wx:if="{{hasActions}}">
    <view class="o-btn" wx:if="{{order.status === 0}}" bindtap="onPay">继续支付</view>
    <view class="o-btn" wx:if="{{order.status === 0}}" bindtap="onCancel">取消订单</view>
    <view class="o-btn primary" wx:if="{{order.status === 3}}" bindtap="onConfirm">确认收货</view>
    <view class="o-btn primary" wx:if="{{order.status === 1 || order.status === 2 || order.status === 3}}" bindtap="onRefund">申请退款</view>
    <view class="o-btn primary" wx:if="{{order.status === 3}}" bindtap="onReview">评价晒单</view>
    <view class="o-btn" wx:if="{{order.status === 3}}" bindtap="onViewReviews">查看评价</view>
    <view class="o-btn" wx:if="{{order.status === 4 || order.status === -1 || order.status === -2}}" bindtap="onDelete">删除订单</view>
  </view>
</view>
