<header class="header">
  <div class="container">
    <a href="/" class="logo">🎂 <%= SITE_NAME %></a>
    <nav class="nav">
      <a href="/">首页</a>
      <a href="/goods">全部商品</a>
      <% if (typeof categories !== 'undefined' && categories && categories.length) { %>
        <% categories.slice(0, 4).forEach(function(cat) { %>
          <a href="/category/<%= cat._id %>"><%= cat.name %></a>
        <% }); %>
      <% } %>
      <a href="/about">关于</a>
    </nav>
    <a href="javascript:;" class="mp-link" onclick="openMP()">小程序</a>
  </div>
</header>
<script>
function openMP() {
  // 微信内唤起小程序
  if (typeof wx !== 'undefined' && wx.miniProgram) {
    wx.miniProgram.navigateTo({ url: '/pages/index/index' });
  } else {
    alert('请在微信中打开,或搜索"甜心蛋糕"小程序');
  }
}
</script>
