<%- include('partials/head') %>
<%- include('partials/header') %>

<div class="container">
  <h1 class="page-title"><%= currentCat.name || '全部商品' %></h1>
  <% if (keyword) { %>
    <p class="page-meta">搜索: <strong><%= keyword %></strong>,共 <%= list.length %> 个结果</p>
  <% } %>

  <div class="goods-grid goods-list">
    <% (list || []).forEach(function(g) { %>
      <a href="/goods/<%= g._id %>" class="goods-card">
        <img src="<%= g.image %>" alt="<%= g.name %>" loading="lazy">
        <div class="g-info">
          <h3 class="g-name"><%= g.name %></h3>
          <p class="g-desc"><%= g.desc || '' %></p>
          <div class="g-price">¥<%= g.price %></div>
        </div>
      </a>
    <% }); %>
  </div>
</div>

<%- include('partials/footer') %>
