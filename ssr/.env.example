# 服务端渲染配置
PORT=3000
NODE_ENV=production

# 微信云开发 HTTP API(用于调用云函数)
# 在云开发控制台 -> 环境 -> HTTP 触发器 启用
CLOUD_BASE_URL=https://你的环境ID.ap-shanghai.app.tcloudbase.com
# 或者直接访问 wx.cloud.callFunction 不行,所以 SSR 走 HTTP 触发器或直连数据库

# 直连云开发数据库(可选,绕过 HTTP 触发器)
# 推荐用环境 ID + access token

# Redis 缓存
REDIS_URL=redis://localhost:6379

# 站点
SITE_NAME=甜心蛋糕
SITE_URL=https://www.example.com
SITE_DESC=用心做好每一块蛋糕
SITE_KEYWORDS=蛋糕,生日蛋糕,面包,甜点,甜心蛋糕

# 微信 JSSDK
WX_APPID=wx你的appid
WX_SECRET=你的secret
